        }

        public DefaultHandler(
            com.statespec.backend.Backend backend,
            ApiHandlers.BusinessHandler businessHandler
        ) {
            this.backend = backend;
            this.businessHandler = businessHandler;
        }

        public com.statespec.backend.Backend backend() {
            return backend;
        }

        public ApiHandlers.BusinessHandler businessHandler() {
            return businessHandler;
        }
    }

    public static DefaultHandler defaultHandler(com.statespec.backend.Backend backend) {
        return new DefaultHandler(backend);
    }

    public static DefaultHandler defaultHandler(
        com.statespec.backend.Backend backend,
        ApiHandlers.BusinessHandler businessHandler
    ) {
        return new DefaultHandler(backend, businessHandler);
    }

