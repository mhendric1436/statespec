package com.statespec.generated;

import com.statespec.backend.Backend;
import com.statespec.generated.descriptors.types.ApiServerDescriptor;

import java.time.Instant;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;
import java.util.concurrent.atomic.AtomicBoolean;

public final class ApiProcess {
    @FunctionalInterface
    public interface EntityGcWorkerTask {
        void run(String now) throws Backend.BackendException;
    }

    public static final class Config {
        private final List<String> serverNames;
        private final boolean bootstrapOnStart;
        private final boolean entityGcEnabled;
        private final int shutdownTimeoutMs;
        private final int entityGcPollIntervalMs;

        public Config(List<String> serverNames, boolean bootstrapOnStart, int shutdownTimeoutMs) {
            this(serverNames, bootstrapOnStart, true, shutdownTimeoutMs, 60000);
        }

        public Config(
            List<String> serverNames,
            boolean bootstrapOnStart,
            boolean entityGcEnabled,
            int shutdownTimeoutMs,
            int entityGcPollIntervalMs
        ) {
            this.serverNames = List.copyOf(serverNames);
            this.bootstrapOnStart = bootstrapOnStart;
            this.entityGcEnabled = entityGcEnabled;
            this.shutdownTimeoutMs = shutdownTimeoutMs;
            this.entityGcPollIntervalMs = entityGcPollIntervalMs;
        }

        public static Config allServers() {
            var names = new ArrayList<String>();
            for (ApiServerDescriptor descriptor : ApiDescriptors.apiServerDescriptors()) {
                names.add(descriptor.name());
            }
            return new Config(names, true, 30000);
        }

        public List<String> serverNames() {
            return serverNames;
        }

        public boolean bootstrapOnStart() {
            return bootstrapOnStart;
        }

        public boolean entityGcEnabled() {
            return entityGcEnabled;
        }

        public int shutdownTimeoutMs() {
            return shutdownTimeoutMs;
        }

        public int entityGcPollIntervalMs() {
            return entityGcPollIntervalMs;
        }
    }

    private final Config config;
    private final Backend backend;
    private final ApiHandlerRegistry.DefaultHandler handler;
    private final ApiTransport transport;
    private final List<ApiApplication> applications = new ArrayList<>();
    private final List<EntityGcWorkerTask> entityGcWorkers = new ArrayList<>();
    private final List<Thread> entityGcThreads = new ArrayList<>();
    private final AtomicBoolean stopRequested = new AtomicBoolean(false);
    private final AtomicBoolean entityGcStopRequested = new AtomicBoolean(false);
    private Thread thread;
    private int exitStatus = 1;
    private Exception exitException;
    private boolean started = false;
    private boolean running = false;
    private boolean bootstrapped = false;

    public ApiProcess(
        Config config,
        Backend backend,
        ApiHandlerRegistry.DefaultHandler handler,
        ApiTransport transport
    ) {
        this.config = config.serverNames().isEmpty() ? Config.allServers() : config;
        this.backend = backend;
        this.handler = handler;
        this.transport = transport;
        for (String serverName : this.config.serverNames()) {
            applications.add(new ApiApplication(backend, serverName, handler));
        }
    }

    public ApiProcess(
        Backend backend,
        ApiHandlerRegistry.DefaultHandler handler,
        ApiTransport transport
    ) {
        this(Config.allServers(), backend, handler, transport);
    }

    public static ApiProcess createDefault(Backend backend) {
        return new ApiProcess(
            Config.allServers(),
            backend,
            ApiHandlerRegistry.defaultHandler(backend),
            new ApiTransport.LocalBlocking()
        );
    }

    public Config config() {
        return config;
    }

    public Backend backend() {
        return backend;
    }

    public ApiHandlerRegistry.DefaultHandler handler() {
        return handler;
    }

    public ApiTransport transport() {
        return transport;
    }

    public List<ApiApplication> applications() {
        return Collections.unmodifiableList(applications);
    }

    public synchronized void addEntityGcWorker(EntityGcWorkerTask worker) {
        if (started) {
            throw new IllegalStateException("cannot add entity GC worker after API process start");
        }
        entityGcWorkers.add(worker);
    }

    public synchronized void bootstrap() throws Backend.BackendException {
        if (bootstrapped) {
            return;
        }
        for (ApiApplication application : applications) {
            application.bootstrap();
        }
        bootstrapped = true;
    }

    public int run() throws Backend.BackendException, InterruptedException {
        if (config.bootstrapOnStart()) {
            bootstrap();
        }
        return transport.run();
    }

    public synchronized void start() {
        if (started) {
            throw new IllegalStateException("generated API process already started");
        }
        started = true;
        running = true;
        exitStatus = 1;
        exitException = null;
        startEntityGcWorkers();
        thread = new Thread(
            () -> {
                int status = 1;
                Exception exception = null;
                try {
                    status = run();
                } catch (InterruptedException error) {
                    Thread.currentThread().interrupt();
                    status = 130;
                    exception = error;
                } catch (Backend.BackendException error) {
                    status = 1;
                    exception = error;
                }
                requestStop();
                synchronized (ApiProcess.this) {
                    exitStatus = status;
                    exitException = exception;
                    running = false;
                    ApiProcess.this.notifyAll();
                }
            },
            "statespec-api-process"
        );
        thread.start();
    }

    private synchronized void startEntityGcWorkers() {
        if (!config.entityGcEnabled()) {
            return;
        }
        entityGcStopRequested.set(false);
        for (EntityGcWorkerTask worker : entityGcWorkers) {
            Thread gcThread = new Thread(
                () -> {
                    while (!entityGcStopRequested.get()) {
                        try {
                            worker.run(Instant.now().toString());
                        } catch (Backend.BackendException error) {
                        }
                        try {
                            Thread.sleep(Math.max(1, config.entityGcPollIntervalMs()));
                        } catch (InterruptedException error) {
                            Thread.currentThread().interrupt();
                            return;
                        }
                    }
                },
                "statespec-api-entity-gc"
            );
            gcThread.start();
            entityGcThreads.add(gcThread);
        }
    }

    private void joinEntityGcWorkers() throws InterruptedException {
        List<Thread> threads;
        synchronized (this) {
            threads = new ArrayList<>(entityGcThreads);
            entityGcThreads.clear();
        }
        for (Thread gcThread : threads) {
            gcThread.join();
        }
    }

    public int join() throws Backend.BackendException, InterruptedException {
        Thread processThread;
        synchronized (this) {
            if (!started) {
                throw new IllegalStateException("generated API process not started");
            }
            processThread = thread;
        }
        processThread.join();
        joinEntityGcWorkers();

        synchronized (this) {
            if (exitException instanceof Backend.BackendException) {
                throw (Backend.BackendException) exitException;
            }
            return exitStatus;
        }
    }

    public synchronized boolean isRunning() {
        return running;
    }

    public void requestStop() {
        stopRequested.set(true);
        entityGcStopRequested.set(true);
        synchronized (this) {
            for (Thread gcThread : entityGcThreads) {
                gcThread.interrupt();
            }
        }
        transport.requestStop();
    }

    public boolean stopRequested() {
        return stopRequested.get();
    }
}
