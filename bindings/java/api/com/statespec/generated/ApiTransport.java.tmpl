package com.statespec.generated;

import java.util.Optional;
import java.util.concurrent.CountDownLatch;

public interface ApiTransport {
    Optional<Descriptors.ApiResponse> handle(
        ApiServer server,
        String routeName,
        Descriptors.ApiRequestContext context
    ) throws Exception;

    int run() throws InterruptedException;

    void requestStop();

    final class LocalBlocking implements ApiTransport {
        private final CountDownLatch stopRequested = new CountDownLatch(1);

        @Override
        public Optional<Descriptors.ApiResponse> handle(
            ApiServer server,
            String routeName,
            Descriptors.ApiRequestContext context
        ) throws Exception {
            return server.handle(routeName, context);
        }

        @Override
        public int run() throws InterruptedException {
            stopRequested.await();
            return 0;
        }

        @Override
        public void requestStop() {
            stopRequested.countDown();
        }
    }
}
