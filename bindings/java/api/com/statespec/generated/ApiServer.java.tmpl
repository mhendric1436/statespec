package com.statespec.generated;

import com.statespec.generated.descriptors.types.ApiRouteDescriptor;
import com.statespec.generated.descriptors.types.ApiServerDescriptor;
import java.util.Optional;

public final class ApiServer {
    private final ApiServerDescriptor descriptor;
    private final ApiHandlerRegistry.DefaultHandler handler;

    public ApiServer(ApiServerDescriptor descriptor, ApiHandlerRegistry.DefaultHandler handler) {
        this.descriptor = descriptor;
        this.handler = handler;
    }

    public ApiServerDescriptor descriptor() {
        return descriptor;
    }

    public static Optional<ApiServerDescriptor> findApiServer(String serverName) {
        for (ApiServerDescriptor server : ApiDescriptors.apiServerDescriptors()) {
            if (server.name().equals(serverName)) {
                return Optional.of(server);
            }
        }
        return Optional.empty();
    }

    public Optional<ApiResponse> handle(
        String routeName,
        ApiRequestContext context
    ) throws Exception {
        Optional<ApiRouteDescriptor> route = ApiDispatcher.findApiRoute(routeName);
        if (!route.isPresent() || !route.get().serverName().equals(descriptor.name())) {
            return Optional.empty();
        }
        return ApiDispatcher.dispatchApiRoute(
            handler.backend(),
            handler.businessHandler(),
            routeName,
            context
        );
    }
}
