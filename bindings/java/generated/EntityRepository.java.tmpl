package com.statespec.generated.entities;

import com.statespec.backend.Backend;
import com.statespec.backend.Json;
import com.statespec.generated.descriptors.types.EntityDescriptor;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Optional;

public
interface EntityRepository
{
    Optional<Backend.VersionedRecord> createEntityTx(
        Backend.Transaction tx, EntityCreateRequest request
    ) throws Backend.BackendException;

    Optional<Backend.VersionedRecord> upsertEntityTx(
        Backend.Transaction tx, EntityUpsertRequest request
    ) throws Backend.BackendException;

    Optional<Backend.VersionedRecord> getEntityTx(Backend.Transaction tx, EntityGetRequest request)
        throws Backend.BackendException;

    Optional<Backend.VersionedRecord> deleteEntityTx(
        Backend.Transaction tx, EntityDeleteRequest request
    ) throws Backend.BackendException;

    List<Backend.VersionedRecord> listEntitiesByIndexTx(
        Backend.Transaction tx, EntityListByIndexRequest request
    ) throws Backend.BackendException;

    static Optional<String> entityKey(EntityLookup lookup)
    {
        if (!lookup.keyComplete())
        {
            return Optional.empty();
        }
        HashMap<String, Json> values = new HashMap<>();
        for (EntityKeyValue keyValue : lookup.keyValues())
        {
            values.put(keyValue.field(), keyValue.value());
        }
        StringBuilder key = new StringBuilder();
        for (String keyField : lookup.keyFields())
        {
            Json value = values.get(keyField);
            if (value == null)
            {
                return Optional.empty();
            }
            key.append(keyField).append('=').append(value.canonicalString()).append('\n');
        }
        return Optional.of(key.toString());
    }

    static EntityLookup entityLookupFromDocument(EntityDescriptor entity, Json document)
    {
        ArrayList<EntityKeyValue> keyValues = new ArrayList<>();
        if (document instanceof Json.ObjectValue object)
        {
            for (String keyField : entity.keyFields())
            {
                Json value = object.values().get(keyField);
                if (value != null)
                {
                    keyValues.add(new EntityKeyValue(keyField, value));
                }
            }
        }
        return new EntityLookup(entity.name(), entity.keyFields(), List.copyOf(keyValues));
    }

    static Json entityDocumentWithKeys(Json document, EntityLookup lookup)
    {
        HashMap<String, Json> values = new HashMap<>();
        if (document instanceof Json.ObjectValue object)
        {
            values.putAll(object.values());
        }
        for (EntityKeyValue keyValue : lookup.keyValues())
        {
            values.put(keyValue.field(), keyValue.value());
        }
        return Json.object(values);
    }
}
