JAVAC ?= javac
JAR ?= jar
BUILD_DIR ?= build/classes
DIST_DIR ?= dist
COMMON_SOURCES :={{common_sources}}
API_SOURCES :={{api_sources}}
WORKER_SOURCES :={{worker_sources}}
COMMON_EXTENSION_SOURCES := $(filter-out $(COMMON_SOURCES),$(wildcard common/com/statespec/generated/*.java common/com/statespec/backend/memory/*.java))
API_EXTENSION_SOURCES := $(filter-out $(API_SOURCES),$(wildcard api/com/statespec/generated/*.java))
WORKER_EXTENSION_SOURCES := $(filter-out $(WORKER_SOURCES),$(wildcard worker/com/statespec/generated/*.java))

BUILD_TARGETS := build-common{{build_target_additions}}
PACKAGE_TARGETS := package-common{{package_target_additions}}

.PHONY: all help check build package build-common package-common{{phony_targets}} clean

all: check

help:
	@printf '%s\n' 'StateSpec generated Java bindings Makefile'
	@printf '%s\n' ''
	@printf '%s\n' 'Default target: all -> check -> build'
	@printf '%s\n' '  check   Alias for build; compiles generated Java sources.'
	@printf '%s\n' '  build   Compiles generated Java sources into $(BUILD_DIR).'
	@printf '%s\n' '  package Builds and archives generated artifacts under $(DIST_DIR).'
	@printf '%s\n' '  clean   Removes build and $(DIST_DIR).'
	@printf '%s\n' ''
	@printf '%s\n' 'Tier targets:'
	@printf '%s\n' '  build-common  package-common'
	@printf '%s\n' '  build-api     package-api     when API tier is generated'
	@printf '%s\n' '  build-worker  package-worker  when Worker tier is generated'

check: build

build: $(BUILD_TARGETS)

package: $(PACKAGE_TARGETS)

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

$(DIST_DIR):
	mkdir -p $(DIST_DIR)

build-common: $(BUILD_DIR)
	$(JAVAC) -d $(BUILD_DIR) $(COMMON_SOURCES) $(COMMON_EXTENSION_SOURCES)

package-common: build-common $(DIST_DIR)
	$(JAR) --create --file $(DIST_DIR)/statespec-generated-common-java.jar -C $(BUILD_DIR) .

{{api_rules}}{{worker_rules}}
clean:
	rm -rf build $(DIST_DIR)
