public
static void registerLogDefinitionsTx(
    Backend.Transaction tx,
    Log sink
) throws Backend.BackendException
{
    for (var definition : logDefinitions())
    {
        sink.registerDefinitionTx(
            tx, new Log.Definition(
                    definition.name(), logLevelFromDescriptor(definition.level()),
                    definition.eventName(), definition.fields()
                )
        );
    }
}
