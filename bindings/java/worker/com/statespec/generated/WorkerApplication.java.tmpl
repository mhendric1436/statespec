package com.statespec.generated;

import com.statespec.generated.descriptors.types.WorkerContext;
import java.util.Map;

public final class WorkerApplication {
    private final WorkerContext context;
    private final WorkerRuntime runtime;
    private final Map<String, WorkflowStepHandlers.WorkflowStepInvoker> invokers;

    public WorkerApplication(
        WorkerContext context,
        WorkerRuntime runtime,
        Map<String, WorkflowStepHandlers.WorkflowStepInvoker> invokers
    ) {
        this.context = context;
        this.runtime = runtime;
        this.invokers = Map.copyOf(invokers);
    }

    public WorkerContext context() {
        return context;
    }

    public java.util.Optional<com.statespec.backend.Workflow.WorkflowExecutionRecord> runOnce(
        String workflowExecutionId
    ) throws Exception {
        return runtime.runOnce(context, invokers, workflowExecutionId);
    }
}
