package com.statespec.generated;

import com.statespec.backend.Backend;
import com.statespec.backend.Json;
import com.statespec.backend.Workflow;
import java.time.Duration;
import java.time.Instant;
import java.util.List;
import java.util.Map;
import java.util.Optional;

public final class WorkflowRunner {
    private final Backend backend;
    private final Workflow workflowStore;
    private final Map<String, WorkflowStepHandlers.WorkflowStepInvoker> invokers;
    private final String workerName;
    private final Duration leaseDuration;
    private final int maxAttempts;

    public WorkflowRunner(
        Backend backend,
        Workflow workflowStore,
        Map<String, WorkflowStepHandlers.WorkflowStepInvoker> invokers,
        String workerName,
        Duration leaseDuration,
        int maxAttempts
    ) {
        this.backend = backend;
        this.workflowStore = workflowStore;
        this.invokers = Map.copyOf(invokers);
        this.workerName = workerName;
        this.leaseDuration = leaseDuration;
        this.maxAttempts = maxAttempts;
    }

    public Optional<Workflow.WorkflowExecutionRecord> runOnce(
        String workflowExecutionId,
        String workflowName,
        long workflowVersion
    ) throws Exception {
        List<Workflow.WorkflowExecutionRecord> claimed = workflowStore.claimSteps(
            backend,
            new Workflow.ClaimWorkflowStepRequest(
                workflowExecutionId,
                workflowName,
                workflowVersion,
                workerName,
                Instant.now(),
                leaseDuration,
                1
            )
        );
        if (claimed.isEmpty()) {
            return Optional.empty();
        }
        Workflow.WorkflowExecutionRecord record = claimed.get(0);
        workflowStore.keepAliveStep(
            backend,
            new Workflow.KeepAliveWorkflowStepRequest(
                record.workflowExecutionId(),
                workerName,
                record.currentStep(),
                Instant.now(),
                leaseDuration
            )
        );
        Backend.Transaction tx = backend.begin();
        boolean committed = false;
        try {
            Workflow.WorkflowExecutionRecord current = revalidateClaimedStep(tx, record);
            WorkflowStepHandlers.Context context =
                new WorkflowStepHandlers.Context(
                    current.workflowName(),
                    current.workflowVersion(),
                    current.currentStep(),
                    Optional.of(current.workflowExecutionId()),
                    Json.parse(current.stateJson())
                );
            String stepKey =
                WorkflowStepHandlers.workflowStepKey(
                    current.workflowName(),
                    current.workflowVersion(),
                    current.currentStep()
                );
            WorkflowStepHandlers.WorkflowStepInvoker invoker =
                invokers.get(stepKey);
            WorkflowStepHandlers.WorkflowStepResult result;
            if (invoker == null) {
                result = WorkflowStepHandlers.fail(
                    "unknown generated workflow step handler: " + stepKey
                );
            } else {
                try {
                    result = invoker.invoke(backend, tx, context);
                } catch (Exception ex) {
                    result = WorkflowStepHandlers.fail(ex.getMessage());
                }
            }
            if (result.kind() == WorkflowStepHandlers.WorkflowStepResultKind.FAIL) {
                Workflow.WorkflowExecutionRecord failed =
                    workflowStore.failStepTx(
                        tx,
                        new Workflow.FailWorkflowStepRequest(
                            current.workflowExecutionId(),
                            workerName,
                            current.currentStep(),
                            result.reason(),
                            Instant.now(),
                            maxAttempts
                        )
                    );
                backend.commit(tx);
                committed = true;
                return Optional.of(failed);
            }
            if (result.kind() == WorkflowStepHandlers.WorkflowStepResultKind.CANCEL) {
                Workflow.WorkflowExecutionRecord canceled =
                    workflowStore.cancelTx(
                        tx,
                        new Workflow.CancelWorkflowRequest(
                            current.workflowExecutionId(),
                            result.reason()
                        )
                    );
                backend.commit(tx);
                committed = true;
                return Optional.of(canceled);
            }
            Workflow.WorkflowExecutionRecord completed =
                workflowStore.completeStepTx(
                    tx,
                    new Workflow.CompleteWorkflowStepRequest(
                        current.workflowExecutionId(),
                        workerName,
                        current.currentStep(),
                        result.nextStep(),
                        current.stateJson()
                    )
                );
            backend.commit(tx);
            committed = true;
            return Optional.of(completed);
        } finally {
            if (!committed && tx.isOpen()) {
                tx.abort();
            }
        }
    }

    private Workflow.WorkflowExecutionRecord revalidateClaimedStep(
        Backend.Transaction tx,
        Workflow.WorkflowExecutionRecord claimed
    ) throws Exception {
        Optional<Workflow.WorkflowExecutionRecord> current =
            workflowStore.inspectTx(tx, claimed.workflowExecutionId());
        if (current.isEmpty()) {
            throw new Backend.BackendException("claimed workflow execution disappeared");
        }
        Workflow.WorkflowExecutionRecord record = current.get();
        if (!claimed.workflowName().equals(record.workflowName()) ||
            claimed.workflowVersion() != record.workflowVersion() ||
            !claimed.currentStep().equals(record.currentStep()))
        {
            throw new Backend.BackendException("claimed workflow execution changed before execution");
        }
        if (record.claimedBy().isEmpty() || !record.claimedBy().get().equals(workerName))
        {
            throw new Backend.BackendException("claimed workflow execution is no longer owned by worker");
        }
        if (record.claimExpiresAt().isEmpty() || !record.claimExpiresAt().get().isAfter(Instant.now()))
        {
            throw new Backend.BackendException("claimed workflow execution lease expired before execution");
        }
        return record;
    }
}
