package com.statespec.generated;

import com.statespec.backend.Backend;
import com.statespec.backend.Json;
import java.util.Optional;

public final class WorkflowStepHandlers {
    private WorkflowStepHandlers() {}

    public record WorkflowStepKey(String workflowName, long workflowVersion, String stepName) {
        public String encode() {
            return workflowStepKey(workflowName, workflowVersion, stepName);
        }
    }

    public static String workflowStepKey(
        String workflowName,
        long workflowVersion,
        String stepName
    ) {
        return workflowName + ":" + workflowVersion + ":" + stepName;
    }

    public record Context(
        String workflowName,
        long workflowVersion,
        String stepName,
        Optional<String> executionId,
        Json input
    ) {}

    public enum WorkflowStepResultKind {
        COMPLETE,
        FAIL,
        CANCEL
    }

    public record WorkflowStepResult(
        WorkflowStepResultKind kind,
        Optional<String> nextStep,
        String reason
    ) {}

    public static WorkflowStepResult complete(Optional<String> nextStep) {
        return new WorkflowStepResult(
            WorkflowStepResultKind.COMPLETE,
            nextStep,
            ""
        );
    }

    public static WorkflowStepResult complete(String nextStep) {
        return complete(Optional.of(nextStep));
    }

    public static WorkflowStepResult complete() {
        return complete(Optional.empty());
    }

    public static WorkflowStepResult fail(String reason) {
        return new WorkflowStepResult(
            WorkflowStepResultKind.FAIL,
            Optional.empty(),
            reason
        );
    }

    public static WorkflowStepResult cancel(String reason) {
        return new WorkflowStepResult(
            WorkflowStepResultKind.CANCEL,
            Optional.empty(),
            reason
        );
    }

    @FunctionalInterface
    public interface WorkflowStepInvoker {
        WorkflowStepResult invoke(Backend backend, Context context) throws Exception;
    }
}
