public final class WorkerRuntime {
    @FunctionalInterface
    public interface EntityGcWorkerTask {
        void run(String now) throws Backend.BackendException;
    }

    public record Config(boolean entityGcEnabled, int entityGcPollIntervalMs) {
        public static Config defaults() {
            return new Config(true, 60000);
        }
    }

    private final Backend backend;
    private final Config config;
{{runtime_store_fields}}
    private final List<EntityGcWorkerTask> entityGcWorkers = new ArrayList<>();
    private final List<Thread> entityGcThreads = new ArrayList<>();
    private final AtomicBoolean entityGcStopRequested = new AtomicBoolean(false);
    private boolean entityGcStarted = false;

    public WorkerRuntime(Backend backend) {
        this(backend, Config.defaults());
    }

    public WorkerRuntime(Backend backend, Config config) {
        this.backend = backend;
        this.config = config;
{{runtime_store_initializers}}
    }

    public Backend backend() {
        return backend;
    }

    public void registerDefinitions() throws Exception {
        bootstrap();
    }

    public void bootstrap() throws Backend.BackendException {
        RuntimeRegistration.bootstrapRuntimeCatalog(backend{{runtime_bootstrap_arguments}});
    }

    public synchronized void addEntityGcWorker(EntityGcWorkerTask worker) {
        if (entityGcStarted) {
            throw new IllegalStateException("cannot add entity GC worker after Worker runtime start");
        }
        entityGcWorkers.add(worker);
    }

    public synchronized void startEntityGcWorkers(int pollIntervalMs) {
        if (entityGcStarted) {
            throw new IllegalStateException("Worker runtime entity GC workers already started");
        }
        if (!config.entityGcEnabled()) {
            entityGcStarted = true;
            return;
        }
        entityGcStarted = true;
        entityGcStopRequested.set(false);
        int configuredInterval = pollIntervalMs > 0 ? pollIntervalMs : config.entityGcPollIntervalMs();
        int interval = Math.max(1, configuredInterval);
        for (EntityGcWorkerTask worker : entityGcWorkers) {
            Thread gcThread = new Thread(
                () -> {
                    while (!entityGcStopRequested.get()) {
                        try {
                            worker.run(Instant.now().toString());
                        } catch (Backend.BackendException error) {
                        }
                        try {
                            Thread.sleep(interval);
                        } catch (InterruptedException error) {
                            Thread.currentThread().interrupt();
                            return;
                        }
                    }
                },
                "statespec-worker-entity-gc"
            );
            gcThread.start();
            entityGcThreads.add(gcThread);
        }
    }

    public void requestStop() {
        entityGcStopRequested.set(true);
        synchronized (this) {
            for (Thread gcThread : entityGcThreads) {
                gcThread.interrupt();
            }
        }
    }

    public void joinEntityGcWorkers() throws InterruptedException {
        List<Thread> threads;
        synchronized (this) {
            threads = new ArrayList<>(entityGcThreads);
            entityGcThreads.clear();
        }
        for (Thread gcThread : threads) {
            gcThread.join();
        }
    }

