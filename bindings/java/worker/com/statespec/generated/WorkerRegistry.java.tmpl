package com.statespec.generated;

import com.statespec.generated.descriptors.types.WorkerContext;
import com.statespec.generated.descriptors.types.WorkerDescriptor;
import java.util.Optional;

public final class WorkerRegistry {
    private WorkerRegistry() {}

    public static Optional<WorkerDescriptor> findWorkerDescriptor(String workerName) {
        for (WorkerDescriptor worker : WorkerDescriptors.workerDescriptors()) {
            if (worker.name().equals(workerName)) {
                return Optional.of(worker);
            }
        }
        return Optional.empty();
    }

    public static Optional<WorkerContext> findWorkerContext(String workerName) {
        for (WorkerContext context : WorkerContexts.workerContexts()) {
            if (context.workerName().equals(workerName)) {
                return Optional.of(context);
            }
        }
        return Optional.empty();
    }
}
