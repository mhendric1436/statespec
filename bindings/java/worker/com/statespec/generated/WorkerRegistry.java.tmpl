package com.statespec.generated;

import java.util.Optional;

public final class WorkerRegistry {
    private WorkerRegistry() {}

    public static Optional<Descriptors.WorkerDescriptor> findWorkerDescriptor(String workerName) {
        for (Descriptors.WorkerDescriptor worker : WorkerDescriptors.workerDescriptors()) {
            if (worker.name().equals(workerName)) {
                return Optional.of(worker);
            }
        }
        return Optional.empty();
    }

    public static Optional<Descriptors.WorkerContext> findWorkerContext(String workerName) {
        for (Descriptors.WorkerContext context : WorkerContexts.workerContexts()) {
            if (context.workerName().equals(workerName)) {
                return Optional.of(context);
            }
        }
        return Optional.empty();
    }
}
