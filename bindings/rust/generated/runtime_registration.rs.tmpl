pub fn register_runtime_catalog<B{{generic_parameters}}>(
    backend: &B{{runtime_parameters}},
) -> BackendResult<()>
where
    B: Backend{{generic_bounds}},
{
    let mut tx = backend.begin()?;
    let result = register_runtime_catalog_tx(&mut tx{{runtime_arguments}});
    if let Err(error) = result {
        let _ = tx.abort();
        return Err(error);
    }
    backend.commit(tx)
}

