CARGO ?= cargo
DIST_DIR ?= dist

CHECK_TARGETS := check-common
BUILD_TARGETS := build-common
PACKAGE_TARGETS := package-common{{target_additions}}

.PHONY: all help check build package format check-common build-common package-common{{phony_targets}} clean

all: check

help:
	@printf '%s\n' 'StateSpec generated Rust bindings Makefile'
	@printf '%s\n' ''
	@printf '%s\n' 'Default target: all -> check'
	@printf '%s\n' '  check   Runs cargo test for generated crate.'
	@printf '%s\n' '  build   Runs cargo build for generated crate.'
	@printf '%s\n' '  package Builds and archives generated artifacts under $(DIST_DIR).'
	@printf '%s\n' '  format  Formats generated Rust sources with cargo fmt.'
	@printf '%s\n' '  clean   Runs cargo clean and removes $(DIST_DIR).'
	@printf '%s\n' ''
	@printf '%s\n' 'Tier targets:'
	@printf '%s\n' '  check-common  build-common  package-common'
{{help_target_additions}}

check: $(CHECK_TARGETS)

build: $(BUILD_TARGETS)

package: $(PACKAGE_TARGETS)

format:
	$(CARGO) fmt

$(DIST_DIR):
	mkdir -p $(DIST_DIR)

check-common:
	$(CARGO) test

build-common:
	$(CARGO) build

package-common: build-common $(DIST_DIR)
	tar -czf $(DIST_DIR)/statespec-generated-common-rust.tgz common Cargo.toml lib.rs Makefile

{{api_rules}}{{worker_rules}}clean:
	$(CARGO) clean
	rm -rf $(DIST_DIR)
