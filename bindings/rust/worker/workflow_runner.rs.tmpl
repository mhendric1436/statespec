use std::sync::{mpsc, Arc, Mutex};
use std::thread;
use std::time::{Duration, SystemTime};

use crate::backend::{Backend, BackendError, BackendResult, ConflictKind, Transaction};
use crate::workflow::{
    CancelWorkflowRequest, ClaimWorkflowStepRequest, CompleteWorkflowStepRequest,
    FailWorkflowStepRequest, KeepAliveWorkflowStepRequest, WorkflowExecutionRecord, WorkflowStore,
};
use crate::workflow_step_handlers::{
    workflow_step_key, WorkflowStepHandlerContext, WorkflowStepInvokerMap, WorkflowStepResult,
};

pub struct WorkflowRunner<'a, B: Backend, S: WorkflowStore<B>> {
    pub backend: &'a B,
    pub workflow_store: &'a S,
    pub workflow_step_invokers: &'a WorkflowStepInvokerMap<B>,
    pub worker_name: String,
    pub lease_duration: Duration,
    pub max_attempts: u32,
}

impl<'a, B, S> WorkflowRunner<'a, B, S>
where
    B: Backend + Sync,
    S: WorkflowStore<B> + Sync,
{
    pub fn run_once(
        &self,
        workflow_execution_id: &str,
        workflow_name: &str,
        workflow_version: i64,
    ) -> BackendResult<Option<WorkflowExecutionRecord>> {
        let claimed = self.workflow_store.claim_steps(
            self.backend,
            &ClaimWorkflowStepRequest {
                workflow_execution_id: workflow_execution_id.to_string(),
                workflow_name: workflow_name.to_string(),
                workflow_version,
                worker: self.worker_name.clone(),
                now: SystemTime::now(),
                lease_duration: self.lease_duration,
                max_steps: 1,
            },
        )?;
        let Some(record) = claimed.into_iter().next() else {
            return Ok(None);
        };
        thread::scope(|scope| {
            let (stop_tx, stop_rx) = mpsc::channel::<()>();
            let keep_alive_error = Arc::new(Mutex::new(None));
            self.keep_alive_once(&record, &keep_alive_error);

            let keep_alive_record = record.clone();
            let thread_error = Arc::clone(&keep_alive_error);
            let interval = workflow_keep_alive_interval(self.lease_duration);
            let handle = scope.spawn(move || loop {
                match stop_rx.recv_timeout(interval) {
                    Ok(_) | Err(mpsc::RecvTimeoutError::Disconnected) => return,
                    Err(mpsc::RecvTimeoutError::Timeout) => {
                        self.keep_alive_once(&keep_alive_record, &thread_error);
                    }
                }
            });

            let mut tx = match self.backend.begin() {
                Ok(tx) => tx,
                Err(err) => {
                    let _ = stop_tx.send(());
                    if handle.join().is_err() {
                        return Err(BackendError::Internal {
                            message: "workflow keep alive thread panicked".to_string(),
                        });
                    }
                    return Err(err);
                }
            };
            let result = self.run_claimed_step_tx(&mut tx, record);

            let _ = stop_tx.send(());
            let keep_alive_result = if handle.join().is_err() {
                Err(BackendError::Internal {
                    message: "workflow keep alive thread panicked".to_string(),
                })
            } else {
                take_keep_alive_error(&keep_alive_error)
            };

            match (result, keep_alive_result) {
                (Ok(record), Ok(())) => {
                    self.backend.commit(tx)?;
                    Ok(Some(record))
                }
                (Ok(_), Err(err)) | (Err(err), _) => {
                    if tx.is_open() {
                        let _ = tx.abort();
                    }
                    Err(err)
                }
            }
        })
    }

    fn keep_alive_once(
        &self,
        record: &WorkflowExecutionRecord,
        error: &Arc<Mutex<Option<String>>>,
    ) {
        if let Err(err) = self.workflow_store.keep_alive_step(
            self.backend,
            &KeepAliveWorkflowStepRequest {
                workflow_execution_id: record.workflow_execution_id.clone(),
                worker: self.worker_name.clone(),
                current_step: record.current_step.clone(),
                claim_token: record.claim_token.clone().unwrap_or_default(),
                now: SystemTime::now(),
                lease_duration: self.lease_duration,
            },
        ) {
            record_keep_alive_error(error, format!("{:?}", err));
        }
    }

    fn run_claimed_step_tx(
        &self,
        tx: &mut B::Tx,
        claimed: WorkflowExecutionRecord,
    ) -> BackendResult<WorkflowExecutionRecord> {
        let record = self.revalidate_claimed_step(tx, &claimed)?;
        let context = WorkflowStepHandlerContext {
            workflow_name: record.workflow_name.clone(),
            workflow_version: record.workflow_version,
            step_name: record.current_step.clone(),
            execution_id: Some(record.workflow_execution_id.clone()),
            input: record.state.clone(),
        };
        let key = workflow_step_key(
            &record.workflow_name,
            record.workflow_version,
            &record.current_step,
        );
        let handler_result = match self.workflow_step_invokers.get(&key) {
            Some(invoker) => invoker(self.backend, tx, &context),
            None => Ok(WorkflowStepResult::fail(format!(
                "unknown generated workflow step handler: {}",
                key
            ))),
        };
        let result =
            handler_result.unwrap_or_else(|err| WorkflowStepResult::fail(format!("{:?}", err)));
        match result {
            WorkflowStepResult::Complete { next_step } => self.workflow_store.complete_step_tx(
                tx,
                &CompleteWorkflowStepRequest {
                    workflow_execution_id: record.workflow_execution_id,
                    worker: self.worker_name.clone(),
                    completed_step: record.current_step,
                    next_step,
                    state: record.state,
                    claim_token: record.claim_token.unwrap_or_default(),
                },
            ),
            WorkflowStepResult::Fail { reason } => self.workflow_store.fail_step_tx(
                tx,
                &FailWorkflowStepRequest {
                    workflow_execution_id: record.workflow_execution_id,
                    worker: self.worker_name.clone(),
                    failed_step: record.current_step,
                    reason,
                    now: SystemTime::now(),
                    max_attempts: self.max_attempts,
                    claim_token: record.claim_token.unwrap_or_default(),
                },
            ),
            WorkflowStepResult::Cancel { reason } => self.workflow_store.cancel_tx(
                tx,
                &CancelWorkflowRequest {
                    workflow_execution_id: record.workflow_execution_id,
                    reason,
                },
            ),
        }
    }

    fn revalidate_claimed_step(
        &self,
        tx: &mut B::Tx,
        claimed: &WorkflowExecutionRecord,
    ) -> BackendResult<WorkflowExecutionRecord> {
        let Some(current) = self
            .workflow_store
            .inspect_tx(tx, &claimed.workflow_execution_id)?
        else {
            return Err(BackendError::NotFound {
                message: "claimed workflow execution disappeared".to_string(),
            });
        };
        if current.workflow_name != claimed.workflow_name
            || current.workflow_version != claimed.workflow_version
            || current.current_step != claimed.current_step
        {
            return Err(BackendError::Conflict {
                kind: ConflictKind::WorkflowClaimConflict,
                message: "claimed workflow execution changed before execution".to_string(),
            });
        }
        if current.claimed_by.as_deref() != Some(&self.worker_name) {
            return Err(BackendError::Conflict {
                kind: ConflictKind::WorkflowClaimConflict,
                message: "claimed workflow execution is no longer owned by worker".to_string(),
            });
        }
        if current.claim_token.as_deref() != claimed.claim_token.as_deref()
            || current.claim_token.is_none()
        {
            return Err(BackendError::Conflict {
                kind: ConflictKind::WorkflowClaimConflict,
                message: "claimed workflow execution token changed before execution".to_string(),
            });
        }
        if !current
            .claim_expires_at
            .map(|expires| expires > SystemTime::now())
            .unwrap_or(false)
        {
            return Err(BackendError::Conflict {
                kind: ConflictKind::WorkflowClaimConflict,
                message: "claimed workflow execution lease expired before execution".to_string(),
            });
        }
        Ok(current)
    }
}

fn record_keep_alive_error(error: &Arc<Mutex<Option<String>>>, message: String) {
    if let Ok(mut guard) = error.lock() {
        if guard.is_none() {
            *guard = Some(message);
        }
    }
}

fn take_keep_alive_error(error: &Arc<Mutex<Option<String>>>) -> BackendResult<()> {
    let mut guard = error.lock().map_err(|_| BackendError::Internal {
        message: "workflow keep alive error lock poisoned".to_string(),
    })?;
    let message = guard.take();
    if let Some(message) = message {
        return Err(BackendError::Conflict {
            kind: ConflictKind::WorkflowClaimConflict,
            message: format!("workflow keep alive failed: {}", message),
        });
    }
    Ok(())
}

fn workflow_keep_alive_interval(lease_duration: Duration) -> Duration {
    let mut interval = lease_duration / 3;
    if interval < Duration::from_millis(250) {
        interval = Duration::from_millis(250);
    }
    if lease_duration > Duration::from_millis(250) && interval >= lease_duration {
        interval = lease_duration / 2;
    }
    interval
}
