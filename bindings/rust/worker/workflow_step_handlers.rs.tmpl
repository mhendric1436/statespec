#[derive(Clone, Debug, Eq, Hash, PartialEq)]
pub struct WorkflowStepKey {
    pub workflow_name: String,
    pub workflow_version: i64,
    pub step_name: String,
}

impl WorkflowStepKey {
    pub fn encode(&self) -> String {
        workflow_step_key(&self.workflow_name, self.workflow_version, &self.step_name)
    }
}

pub fn workflow_step_key(workflow_name: &str, workflow_version: i64, step_name: &str) -> String {
    format!("{}:{}:{}", workflow_name, workflow_version, step_name)
}

#[derive(Debug, Clone)]
pub struct WorkflowStepHandlerContext {
    pub workflow_name: String,
    pub workflow_version: i64,
    pub step_name: String,
    pub execution_id: Option<String>,
    pub input: Json,
}

#[derive(Clone, Debug, Eq, PartialEq)]
pub enum WorkflowStepResult {
    Complete { next_step: Option<String> },
    Fail { reason: String },
    Cancel { reason: String },
}

impl WorkflowStepResult {
    pub fn complete(next_step: Option<String>) -> Self {
        Self::Complete { next_step }
    }

    pub fn fail(reason: impl Into<String>) -> Self {
        Self::Fail {
            reason: reason.into(),
        }
    }

    pub fn cancel(reason: impl Into<String>) -> Self {
        Self::Cancel {
            reason: reason.into(),
        }
    }
}

pub type WorkflowStepInvoker<B> =
    fn(
        &dyn WorkflowStepHandlerBundle,
        &B,
        &WorkflowStepHandlerContext,
    ) -> BackendResult<WorkflowStepResult>;

