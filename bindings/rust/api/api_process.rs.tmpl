use crate::api_application::ApiApplication;
use crate::api_descriptors;
use crate::api_handler_registry::DefaultApiHandler;
use crate::api_handlers::ApiHandler;
use crate::api_transport::{ApiTransport, LocalBlockingApiTransport};
use crate::backend::{Backend, BackendError, BackendResult};

use std::sync::atomic::{AtomicBool, Ordering};
use std::sync::{Arc, Mutex};
use std::thread::JoinHandle;
use std::time::{Duration, SystemTime, UNIX_EPOCH};

pub type EntityGcWorkerTask = Arc<dyn Fn(String) -> BackendResult<()> + Send + Sync>;

#[derive(Debug, Clone)]
pub struct ApiProcessConfig {
    pub server_names: Vec<String>,
    pub bootstrap_on_start: bool,
    pub entity_gc_enabled: bool,
    pub shutdown_timeout_ms: u64,
    pub entity_gc_poll_interval_ms: u64,
}

impl ApiProcessConfig {
    pub fn all_servers() -> Self {
        Self {
            server_names: api_descriptors::api_server_descriptors()
                .into_iter()
                .map(|descriptor| descriptor.name)
                .collect(),
            bootstrap_on_start: true,
            entity_gc_enabled: true,
            shutdown_timeout_ms: 30000,
            entity_gc_poll_interval_ms: 60000,
        }
    }
}

pub struct ApiProcess<B: Backend + Clone, H: ApiHandler + Clone, T: ApiTransport<H>> {
    pub config: ApiProcessConfig,
    pub backend: B,
    pub handler: H,
    pub transport: T,
    pub applications: Vec<ApiApplication<B, H>>,
    entity_gc_workers: Mutex<Vec<EntityGcWorkerTask>>,
    entity_gc_stop: Arc<AtomicBool>,
    entity_gc_handles: Mutex<Vec<JoinHandle<()>>>,
    bootstrapped: Mutex<bool>,
    lifecycle: Arc<Mutex<ApiProcessLifecycle>>,
}

struct ApiProcessLifecycle {
    started: bool,
    running: bool,
    handle: Option<JoinHandle<BackendResult<()>>>,
}

impl<B: Backend + Clone, H: ApiHandler + Clone, T: ApiTransport<H>> ApiProcess<B, H, T> {
    pub fn new(
        config: ApiProcessConfig,
        backend: B,
        handler: H,
        transport: T,
    ) -> BackendResult<Self> {
        let config = if config.server_names.is_empty() {
            ApiProcessConfig::all_servers()
        } else {
            config
        };
        let mut applications = Vec::new();
        for server_name in &config.server_names {
            let application = ApiApplication::new(server_name, handler.clone(), backend.clone())
                .ok_or_else(|| BackendError::Internal {
                    message: format!("unknown generated API server {server_name}"),
                })?;
            applications.push(application);
        }
        Ok(Self {
            config,
            backend,
            handler,
            transport,
            applications,
            entity_gc_workers: Mutex::new(Vec::new()),
            entity_gc_stop: Arc::new(AtomicBool::new(false)),
            entity_gc_handles: Mutex::new(Vec::new()),
            bootstrapped: Mutex::new(false),
            lifecycle: Arc::new(Mutex::new(ApiProcessLifecycle {
                started: false,
                running: false,
                handle: None,
            })),
        })
    }

    pub fn add_entity_gc_worker(&self, task: EntityGcWorkerTask) -> BackendResult<()> {
        let lifecycle = self.lifecycle.lock().map_err(|_| BackendError::Internal {
            message: "API process lifecycle lock poisoned".to_string(),
        })?;
        if lifecycle.started {
            return Err(BackendError::Internal {
                message: "cannot add entity GC worker after generated API process start".to_string(),
            });
        }
        drop(lifecycle);
        self.entity_gc_workers
            .lock()
            .map_err(|_| BackendError::Internal {
                message: "API process entity GC worker lock poisoned".to_string(),
            })?
            .push(task);
        Ok(())
    }

    pub fn bootstrap(&self) -> BackendResult<()> {
        let mut bootstrapped = self
            .bootstrapped
            .lock()
            .map_err(|_| BackendError::Internal {
                message: "API process bootstrap lock poisoned".to_string(),
            })?;
        if *bootstrapped {
            return Ok(());
        }
        for application in &self.applications {
            application.bootstrap()?;
        }
        *bootstrapped = true;
        Ok(())
    }

    pub fn run(&self) -> BackendResult<()> {
        if self.config.bootstrap_on_start {
            self.bootstrap()?;
        }

        self.transport.run()
    }

    pub fn start(self: &Arc<Self>) -> BackendResult<()>
    where
        B: Send + Sync + 'static,
        H: Send + Sync + 'static,
        T: Send + Sync + 'static,
    {
        let mut lifecycle = self.lifecycle.lock().map_err(|_| BackendError::Internal {
            message: "API process lifecycle lock poisoned".to_string(),
        })?;
        if lifecycle.started {
            return Err(BackendError::Internal {
                message: "generated API process already started".to_string(),
            });
        }

        lifecycle.started = true;
        lifecycle.running = true;
        drop(lifecycle);
        self.start_entity_gc_workers()?;
        let mut lifecycle = self.lifecycle.lock().map_err(|_| BackendError::Internal {
            message: "API process lifecycle lock poisoned".to_string(),
        })?;
        let process = Arc::clone(self);
        lifecycle.handle = Some(std::thread::spawn(move || {
            let result = process.run();
            process.request_stop();
            if let Ok(mut lifecycle) = process.lifecycle.lock() {
                lifecycle.running = false;
            }
            result
        }));
        Ok(())
    }

    fn start_entity_gc_workers(&self) -> BackendResult<()> {
        if !self.config.entity_gc_enabled {
            return Ok(());
        }
        self.entity_gc_stop.store(false, Ordering::SeqCst);
        let workers = self
            .entity_gc_workers
            .lock()
            .map_err(|_| BackendError::Internal {
                message: "API process entity GC worker lock poisoned".to_string(),
            })?
            .clone();
        let interval = Duration::from_millis(self.config.entity_gc_poll_interval_ms.max(1));
        let mut handles = self
            .entity_gc_handles
            .lock()
            .map_err(|_| BackendError::Internal {
                message: "API process entity GC handle lock poisoned".to_string(),
            })?;
        for worker in workers {
            let stop = Arc::clone(&self.entity_gc_stop);
            handles.push(std::thread::spawn(move || {
                while !stop.load(Ordering::SeqCst) {
                    let _ = worker(current_time_string());
                    let mut slept = Duration::from_millis(0);
                    while slept < interval && !stop.load(Ordering::SeqCst) {
                        let step = Duration::from_millis(100).min(interval - slept);
                        std::thread::sleep(step);
                        slept += step;
                    }
                }
            }));
        }
        Ok(())
    }

    pub fn join(&self) -> BackendResult<()> {
        let handle = {
            let mut lifecycle = self.lifecycle.lock().map_err(|_| BackendError::Internal {
                message: "API process lifecycle lock poisoned".to_string(),
            })?;
            if !lifecycle.started {
                return Err(BackendError::Internal {
                    message: "generated API process not started".to_string(),
                });
            }
            lifecycle.handle.take()
        };

        match handle {
            Some(handle) => handle.join().map_err(|_| BackendError::Internal {
                message: "generated API process thread panicked".to_string(),
            })?,
            None => Ok(()),
        }?;
        self.join_entity_gc_workers()
    }

    fn join_entity_gc_workers(&self) -> BackendResult<()> {
        let handles = {
            let mut handles =
                self.entity_gc_handles
                    .lock()
                    .map_err(|_| BackendError::Internal {
                        message: "API process entity GC handle lock poisoned".to_string(),
                    })?;
            std::mem::take(&mut *handles)
        };
        for handle in handles {
            handle.join().map_err(|_| BackendError::Internal {
                message: "generated API entity GC thread panicked".to_string(),
            })?;
        }
        Ok(())
    }

    pub fn is_running(&self) -> bool {
        self.lifecycle
            .lock()
            .map(|lifecycle| lifecycle.running)
            .unwrap_or(false)
    }

    pub fn request_stop(&self) {
        self.entity_gc_stop.store(true, Ordering::SeqCst);
        self.transport.request_stop();
    }
}

fn current_time_string() -> String {
    SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .map(|duration| duration.as_secs().to_string())
        .unwrap_or_else(|_| "0".to_string())
}

impl<B: Backend + Clone> ApiProcess<B, DefaultApiHandler<B>, LocalBlockingApiTransport> {
    pub fn new_default(backend: B) -> BackendResult<Self> {
        Self::new(
            ApiProcessConfig::all_servers(),
            backend.clone(),
            DefaultApiHandler::new(backend),
            LocalBlockingApiTransport::new(),
        )
    }
}
