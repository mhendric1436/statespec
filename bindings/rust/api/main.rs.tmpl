use crate::api_handler_registry::DefaultApiHandler;
use crate::api_process::{ApiProcess, ApiProcessConfig};
use crate::api_transport::LocalBlockingApiTransport;
use crate::backend::{Backend, BackendResult};
use crate::memory_backend::InMemoryBackend;

pub fn main() {
    if let Err(error) = run() {
        eprintln!("statespec generated API process failed: {error:?}");
        std::process::exit(1);
    }
}

pub fn run() -> BackendResult<()> {
    let backend = InMemoryBackend::new();
    let handler = DefaultApiHandler {
        backend: backend.clone(),
    };
    let transport = LocalBlockingApiTransport::new();
    let config = ApiProcessConfig::all_servers();
    let process = std::sync::Arc::new(ApiProcess::new(config, backend, handler, transport)?);
    process.start()?;
    install_signal_handling(process.clone());
    process.join()
}

#[cfg(unix)]
fn install_signal_handling<B, H, T>(process: std::sync::Arc<ApiProcess<B, H, T>>)
where
    B: Backend + Clone + Send + Sync + 'static,
    H: crate::api_handlers::ApiHandler + Clone + Send + Sync + 'static,
    T: crate::api_transport::ApiTransport<H> + Send + Sync + 'static,
{
    use std::sync::atomic::{AtomicBool, Ordering};
    use std::time::Duration;

    static STOP_REQUESTED: AtomicBool = AtomicBool::new(false);
    const SIGINT: i32 = 2;
    const SIGTERM: i32 = 15;

    extern "C" fn request_stop(_: i32) {
        STOP_REQUESTED.store(true, Ordering::SeqCst);
    }

    unsafe extern "C" {
        fn signal(signum: i32, handler: extern "C" fn(i32)) -> extern "C" fn(i32);
    }

    unsafe {
        signal(SIGINT, request_stop);
        signal(SIGTERM, request_stop);
    }

    std::thread::spawn(move || loop {
        if STOP_REQUESTED.load(Ordering::SeqCst) {
            process.request_stop();
            break;
        }
        std::thread::sleep(Duration::from_millis(100));
    });
}

#[cfg(not(unix))]
fn install_signal_handling<B, H, T>(_process: std::sync::Arc<ApiProcess<B, H, T>>)
where
    B: Backend + Clone + Send + Sync + 'static,
    H: crate::api_handlers::ApiHandler + Clone + Send + Sync + 'static,
    T: crate::api_transport::ApiTransport<H> + Send + Sync + 'static,
{
}
