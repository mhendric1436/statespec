use std::collections::HashMap;
use std::sync::OnceLock;

use crate::api_handler_registry;
use crate::api_handlers::BusinessApiHandler;
use crate::api_routes;
use crate::backend::{Backend, BackendResult};
use crate::descriptor_types::{ApiRequestContext, ApiResponse, ApiRouteDescriptor};

pub type ApiHandlerInvoker<B> = fn(&B, &ApiRequestContext) -> BackendResult<ApiResponse>;
pub type BusinessApiHandlerInvoker =
    fn(&(dyn BusinessApiHandler + Send + Sync), &ApiRequestContext) -> BackendResult<ApiResponse>;

pub fn api_route_lookup_map() -> &'static HashMap<String, ApiRouteDescriptor> {
    static ROUTES: OnceLock<HashMap<String, ApiRouteDescriptor>> = OnceLock::new();
    ROUTES.get_or_init(|| {
        let mut routes = HashMap::new();
        for route in api_routes::api_route_descriptors() {
            routes.insert(route.name.clone(), route);
        }
        routes
    })
}

pub fn api_handler_lookup_map<B: Backend>() -> HashMap<&'static str, ApiHandlerInvoker<B>> {
    let mut handlers: HashMap<&'static str, ApiHandlerInvoker<B>> = HashMap::new();
    api_handler_registry::register_handler_invokers::<B>(&mut handlers);
    handlers
}

pub fn business_api_handler_lookup_map(
) -> &'static HashMap<&'static str, BusinessApiHandlerInvoker> {
    static HANDLERS: OnceLock<HashMap<&'static str, BusinessApiHandlerInvoker>> = OnceLock::new();
    HANDLERS.get_or_init(|| {
        let mut handlers: HashMap<&'static str, BusinessApiHandlerInvoker> = HashMap::new();
        api_handler_registry::register_business_handler_invokers(&mut handlers);
        handlers
    })
}

pub fn find_api_route(route_name: &str) -> Option<ApiRouteDescriptor> {
    api_route_lookup_map().get(route_name).cloned()
}

pub fn dispatch_api_route<B: Backend>(
    backend: &B,
    business_handler: Option<&(dyn BusinessApiHandler + Send + Sync)>,
    route_name: &str,
    context: &ApiRequestContext,
) -> BackendResult<Option<ApiResponse>> {
    let Some(route) = find_api_route(route_name) else {
        return Ok(None);
    };
    let handlers = api_handler_lookup_map::<B>();
    if let Some(invoker) = handlers.get(route.api_name.as_str()) {
        return invoker(backend, context).map(Some);
    }

    let Some(invoker) = business_api_handler_lookup_map().get(route.api_name.as_str()) else {
        return Ok(None);
    };
    let Some(business_handler) = business_handler else {
        return Ok(Some(ApiResponse {
            status_code: 501,
            body: crate::json::Json::Object(std::collections::BTreeMap::new()),
        }));
    };
    invoker(business_handler, context).map(Some)
}
