package runtime

import (
	"fmt"
	"time"

	common "statespec-generated/common/backend"
)

func optionalString(value *string) common.JSON {
	if value == nil {
		return common.JSONNull()
	}
	return common.JSONString(*value)
}

func definitionKey(parts ...any) string {
	out := ""
	for index, part := range parts {
		if index > 0 {
			out += ":"
		}
		out += fmt.Sprint(part)
	}
	return out
}

func conflict(kind common.ConflictKind, message string) error {
	return common.ConflictError{Kind: kind, Message: message}
}

func stringPtrFromJSON(value common.JSON) *string {
	if value.IsNull() {
		return nil
	}
	out, _ := value.AsString()
	return &out
}

func intFromJSON(value common.JSON) int64 {
	out, _ := value.AsInt()
	return out
}

func floatFromJSON(value common.JSON) float64 {
	out, _ := value.AsFloat()
	return out
}

func boolFromJSON(value common.JSON) bool {
	out, _ := value.AsBool()
	return out
}

func stringFromJSON(value common.JSON) string {
	out, _ := value.AsString()
	return out
}

func durationToJSON(value time.Duration) common.JSON {
	return common.JSONInt(value.Nanoseconds())
}

func durationFromJSON(value common.JSON) time.Duration {
	return time.Duration(intFromJSON(value))
}

func optionalDurationToJSON(value *time.Duration) common.JSON {
	if value == nil {
		return common.JSONNull()
	}
	return durationToJSON(*value)
}

func optionalDurationFromJSON(value common.JSON) *time.Duration {
	if value.IsNull() {
		return nil
	}
	out := durationFromJSON(value)
	return &out
}

func timeToJSON(value time.Time) common.JSON {
	return common.JSONInt(value.UnixNano())
}

func timeFromJSON(value common.JSON) time.Time {
	return time.Unix(0, intFromJSON(value))
}

func optionalTimeToJSON(value *time.Time) common.JSON {
	if value == nil {
		return common.JSONNull()
	}
	return timeToJSON(*value)
}

func optionalTimeFromJSON(value common.JSON) *time.Time {
	if value.IsNull() {
		return nil
	}
	out := timeFromJSON(value)
	return &out
}

func eventKey(prefix string, next *uint64) string {
	*next = *next + 1
	return fmt.Sprintf("%s:%d", prefix, *next)
}
