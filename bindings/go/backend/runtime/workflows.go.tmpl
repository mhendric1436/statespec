package runtime

import (
	"context"
	"fmt"
	"time"

	common "statespec-generated/common/backend"
)

const (
	workflowDefinitionsCollection = common.RuntimeCollectionWorkflowDefinitions
	workflowExecutionsCollection  = common.RuntimeCollectionWorkflowExecutions
	workflowHeartbeatsCollection  = common.RuntimeCollectionWorkflowHeartbeats
)

type WorkflowStore struct{}

func NewWorkflowStore() *WorkflowStore {
	return &WorkflowStore{}
}

func (s *WorkflowStore) RegisterDefinition(ctx context.Context, backend common.Backend, request common.RegisterWorkflowDefinitionRequest) (common.WorkflowDefinitionRegistration, error) {
	if err := ensureWorkflowCollections(ctx, backend); err != nil {
		return common.WorkflowDefinitionRegistration{}, err
	}
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowDefinitionRegistration{}, err
	}
	result, err := s.RegisterDefinitionTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowDefinitionRegistration{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) RegisterDefinitionTx(ctx context.Context, tx common.Transaction, request common.RegisterWorkflowDefinitionRequest) (common.WorkflowDefinitionRegistration, error) {
	existing, err := s.InspectDefinitionTx(ctx, tx, request.Definition.WorkflowName, request.Definition.WorkflowVersion)
	if err != nil {
		return common.WorkflowDefinitionRegistration{}, err
	}
	if err := tx.Put(ctx, workflowDefinitionsCollection, common.Key(workflowDefinitionKey(request.Definition.WorkflowName, request.Definition.WorkflowVersion)), workflowDefinitionToJSON(request.Definition)); err != nil {
		return common.WorkflowDefinitionRegistration{}, err
	}
	return common.WorkflowDefinitionRegistration{Definition: request.Definition, Created: existing == nil}, nil
}

func (s *WorkflowStore) InspectDefinition(ctx context.Context, backend common.Backend, workflowName string, workflowVersion int64) (*common.WorkflowDefinition, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.InspectDefinitionTx(ctx, tx, workflowName, workflowVersion)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) InspectDefinitionTx(ctx context.Context, tx common.Transaction, workflowName string, workflowVersion int64) (*common.WorkflowDefinition, error) {
	record, err := tx.Get(ctx, workflowDefinitionsCollection, common.Key(workflowDefinitionKey(workflowName, workflowVersion)))
	if err != nil || record == nil {
		return nil, err
	}
	definition := workflowDefinitionFromJSON(record.Document)
	return &definition, nil
}

func (s *WorkflowStore) Start(ctx context.Context, backend common.Backend, request common.StartWorkflowRequest) (common.WorkflowExecutionRecord, error) {
	if err := ensureWorkflowCollections(ctx, backend); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.StartTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) StartTx(ctx context.Context, tx common.Transaction, request common.StartWorkflowRequest) (common.WorkflowExecutionRecord, error) {
	existing, err := s.InspectTx(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if existing != nil {
		return *existing, nil
	}
	record := common.WorkflowExecutionRecord{
		WorkflowExecutionID: request.WorkflowExecutionID,
		WorkflowName:        request.WorkflowName,
		WorkflowVersion:     request.WorkflowVersion,
		CurrentStep:         request.StartStep,
		Status:              "Running",
		State:               request.State,
	}
	if err := tx.Put(ctx, workflowExecutionsCollection, common.Key(record.WorkflowExecutionID), workflowExecutionToJSON(record)); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	return record, nil
}

func (s *WorkflowStore) ClaimSteps(ctx context.Context, backend common.Backend, request common.ClaimWorkflowStepRequest) ([]common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.ClaimStepsTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) ClaimStepsTx(ctx context.Context, tx common.Transaction, request common.ClaimWorkflowStepRequest) ([]common.WorkflowExecutionRecord, error) {
	executions, err := s.allExecutions(ctx, tx)
	if err != nil {
		return nil, err
	}
	var claimed []common.WorkflowExecutionRecord
	for _, execution := range executions {
		if uint32(len(claimed)) >= request.MaxSteps {
			break
		}
		matchesExecutionID := request.WorkflowExecutionID == "" || execution.WorkflowExecutionID == request.WorkflowExecutionID
		if !matchesExecutionID || execution.WorkflowName != request.WorkflowName || execution.WorkflowVersion != request.WorkflowVersion || execution.Status != "Running" {
			continue
		}
		visible := execution.ClaimedBy == nil || (execution.ClaimExpiresAt != nil && !execution.ClaimExpiresAt.After(request.Now))
		if !visible {
			continue
		}
		execution.ClaimedBy = &request.Worker
		expires := request.Now.Add(request.LeaseDuration)
		execution.ClaimExpiresAt = &expires
		execution.Attempt++
		token := workflowClaimToken(execution, request.Worker)
		execution.ClaimToken = &token
		if err := tx.Put(ctx, workflowExecutionsCollection, common.Key(execution.WorkflowExecutionID), workflowExecutionToJSON(execution)); err != nil {
			return nil, err
		}
		if err := putWorkflowHeartbeat(ctx, tx, execution, request.Worker, expires); err != nil {
			return nil, err
		}
		claimed = append(claimed, execution)
	}
	return claimed, nil
}

func (s *WorkflowStore) KeepAliveStep(ctx context.Context, backend common.Backend, request common.KeepAliveWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.KeepAliveStepTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) KeepAliveStepTx(ctx context.Context, tx common.Transaction, request common.KeepAliveWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaim(execution, request.Worker, request.CurrentStep); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaimToken(execution, request.ClaimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	expires := request.Now.Add(request.LeaseDuration)
	if err := putWorkflowHeartbeat(ctx, tx, execution, request.Worker, expires); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution.ClaimExpiresAt = &expires
	return execution, nil
}

func (s *WorkflowStore) CompleteStep(ctx context.Context, backend common.Backend, request common.CompleteWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.CompleteStepTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) CompleteStepTx(ctx context.Context, tx common.Transaction, request common.CompleteWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaim(execution, request.Worker, request.CompletedStep); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaimToken(execution, request.ClaimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution.State = request.State
	claimToken := execution.ClaimToken
	execution.ClaimedBy = nil
	execution.ClaimToken = nil
	execution.ClaimExpiresAt = nil
	if request.NextStep == nil {
		execution.Status = "Completed"
	} else {
		execution.CurrentStep = *request.NextStep
		execution.Status = "Running"
	}
	if err := tx.Put(ctx, workflowExecutionsCollection, common.Key(execution.WorkflowExecutionID), workflowExecutionToJSON(execution)); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := eraseWorkflowHeartbeat(ctx, tx, execution.WorkflowExecutionID, claimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	return execution, nil
}

func (s *WorkflowStore) FailStep(ctx context.Context, backend common.Backend, request common.FailWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.FailStepTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) FailStepTx(ctx context.Context, tx common.Transaction, request common.FailWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaim(execution, request.Worker, request.FailedStep); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaimToken(execution, request.ClaimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	claimToken := execution.ClaimToken
	execution.ClaimedBy = nil
	execution.ClaimToken = nil
	execution.ClaimExpiresAt = nil
	if execution.Attempt >= uint64(request.MaxAttempts) {
		execution.Status = "Failed"
	} else {
		execution.Status = "Running"
	}
	if err := tx.Put(ctx, workflowExecutionsCollection, common.Key(execution.WorkflowExecutionID), workflowExecutionToJSON(execution)); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := eraseWorkflowHeartbeat(ctx, tx, execution.WorkflowExecutionID, claimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	return execution, nil
}

func (s *WorkflowStore) Cancel(ctx context.Context, backend common.Backend, request common.CancelWorkflowRequest) (common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.CancelTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) CancelTx(ctx context.Context, tx common.Transaction, request common.CancelWorkflowRequest) (common.WorkflowExecutionRecord, error) {
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	claimToken := execution.ClaimToken
	execution.Status = "Canceled"
	execution.ClaimedBy = nil
	execution.ClaimToken = nil
	execution.ClaimExpiresAt = nil
	if err := tx.Put(ctx, workflowExecutionsCollection, common.Key(execution.WorkflowExecutionID), workflowExecutionToJSON(execution)); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := eraseWorkflowHeartbeat(ctx, tx, execution.WorkflowExecutionID, claimToken); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	return execution, nil
}

func (s *WorkflowStore) Inspect(ctx context.Context, backend common.Backend, workflowExecutionID string) (*common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.InspectTx(ctx, tx, workflowExecutionID)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) InspectTx(ctx context.Context, tx common.Transaction, workflowExecutionID string) (*common.WorkflowExecutionRecord, error) {
	record, err := tx.Get(ctx, workflowExecutionsCollection, common.Key(workflowExecutionID))
	if err != nil || record == nil {
		return nil, err
	}
	execution := workflowExecutionFromJSON(record.Document)
	return &execution, nil
}

func (s *WorkflowStore) requireExecution(ctx context.Context, tx common.Transaction, workflowExecutionID string) (common.WorkflowExecutionRecord, error) {
	record, err := s.InspectTx(ctx, tx, workflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if record == nil {
		return common.WorkflowExecutionRecord{}, common.ErrNotFound
	}
	return *record, nil
}

func (s *WorkflowStore) allExecutions(ctx context.Context, tx common.Transaction) ([]common.WorkflowExecutionRecord, error) {
	records, err := tx.Query(ctx, workflowExecutionsCollection, common.AllQuery())
	if err != nil {
		return nil, err
	}
	executions := make([]common.WorkflowExecutionRecord, 0, len(records))
	for _, record := range records {
		executions = append(executions, workflowExecutionFromJSON(record.Document))
	}
	return executions, nil
}

func ensureWorkflowCollections(ctx context.Context, backend common.Backend) error {
	return backend.EnsureCollections(ctx, []common.CollectionDescriptor{
		{Name: string(workflowDefinitionsCollection), KeyFields: []string{common.RuntimeKeyFieldWorkflowDefinition}},
		{Name: string(workflowExecutionsCollection), KeyFields: []string{common.RuntimeKeyFieldWorkflowExecutionID}},
		{Name: string(workflowHeartbeatsCollection), KeyFields: []string{common.RuntimeKeyFieldWorkflowHeartbeat}},
	})
}

func workflowDefinitionKey(name string, version int64) string {
	return definitionKey(name, version)
}

func workflowHeartbeatKey(workflowExecutionID string, claimToken string) string {
	return workflowExecutionID + ":" + claimToken
}

func workflowClaimToken(execution common.WorkflowExecutionRecord, worker string) string {
	return fmt.Sprintf("%s:%s:%d", execution.WorkflowExecutionID, worker, execution.Attempt)
}

func putWorkflowHeartbeat(ctx context.Context, tx common.Transaction, execution common.WorkflowExecutionRecord, worker string, claimExpiresAt time.Time) error {
	if execution.ClaimToken == nil {
		return conflict(common.WorkflowClaimConflict, "workflow step claim token is missing")
	}
	return tx.Put(ctx, workflowHeartbeatsCollection, common.Key(workflowHeartbeatKey(execution.WorkflowExecutionID, *execution.ClaimToken)), workflowHeartbeatToJSON(common.WorkflowHeartbeatRecord{
		WorkflowExecutionID: execution.WorkflowExecutionID,
		ClaimToken:          *execution.ClaimToken,
		Worker:              worker,
		CurrentStep:         execution.CurrentStep,
		ClaimExpiresAt:      claimExpiresAt,
	}))
}

func eraseWorkflowHeartbeat(ctx context.Context, tx common.Transaction, workflowExecutionID string, claimToken *string) error {
	if claimToken == nil {
		return nil
	}
	return tx.Erase(ctx, workflowHeartbeatsCollection, common.Key(workflowHeartbeatKey(workflowExecutionID, *claimToken)))
}

func requireWorkflowClaim(execution common.WorkflowExecutionRecord, worker string, step string) error {
	if execution.ClaimedBy == nil || *execution.ClaimedBy != worker || execution.CurrentStep != step {
		return conflict(common.WorkflowClaimConflict, "workflow step is not claimed by caller")
	}
	return nil
}

func requireWorkflowClaimToken(execution common.WorkflowExecutionRecord, claimToken string) error {
	if execution.ClaimToken == nil || *execution.ClaimToken != claimToken {
		return conflict(common.WorkflowClaimConflict, "workflow step claim token does not match caller")
	}
	return nil
}
