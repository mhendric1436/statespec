package memory

import (
	"context"
	"fmt"
	"strconv"
	"strings"
	"sync"

	common "statespec-generated/common/backend"
)

type state struct {
	mu sync.Mutex

	collections map[common.CollectionName]common.CollectionDescriptor
	records     map[common.CollectionName]map[common.Key]common.VersionedRecord
	indexes     map[common.CollectionName]map[string]indexState
	versions    map[string]common.Version
}

type indexKey []string

type indexState struct {
	descriptor common.IndexDescriptor
	entries    map[string]map[common.Key]struct{}
}

func newState() *state {
	return &state{
		collections: map[common.CollectionName]common.CollectionDescriptor{},
		records:     map[common.CollectionName]map[common.Key]common.VersionedRecord{},
		indexes:     map[common.CollectionName]map[string]indexState{},
		versions:    map[string]common.Version{},
	}
}

func emptyIndexStates(descriptor common.CollectionDescriptor) map[string]indexState {
	states := map[string]indexState{}
	for _, index := range descriptor.Indexes {
		states[index.Name] = indexState{
			descriptor: index,
			entries:    map[string]map[common.Key]struct{}{},
		}
	}
	return states
}

func extractIndexKey(document common.JSON, descriptor common.IndexDescriptor) ([]string, error) {
	key := make([]string, 0, len(descriptor.Fields))
	for _, field := range descriptor.Fields {
		value, ok := document.Find(field)
		encoded, err := encodeIndexValue(value, ok)
		if err != nil {
			return nil, err
		}
		key = append(key, encoded)
	}
	return key, nil
}

func extractIndexKeyFromValues(values []common.IndexValue) ([]string, error) {
	key := make([]string, 0, len(values))
	for _, value := range values {
		encoded, err := encodeQueryIndexValue(value)
		if err != nil {
			return nil, err
		}
		key = append(key, encoded)
	}
	return key, nil
}

func encodeQueryIndexValue(value common.IndexValue) (string, error) {
	switch value.Kind {
	case common.IndexNull:
		return "null:", nil
	case common.IndexString, common.IndexTimestamp:
		raw, ok := value.Value.AsString()
		if !ok {
			return "", common.ErrInvalidSchema
		}
		return "string:" + raw, nil
	case common.IndexInteger:
		raw, ok := value.Value.AsInt()
		if !ok {
			return "", common.ErrInvalidSchema
		}
		return "int:" + strconv.FormatInt(raw, 10), nil
	case common.IndexDecimal:
		return "decimal:" + value.Value.CanonicalString(), nil
	case common.IndexBoolean:
		raw, ok := value.Value.AsBool()
		if !ok {
			return "", common.ErrInvalidSchema
		}
		if raw {
			return "bool:true", nil
		}
		return "bool:false", nil
	default:
		return "", common.ErrInvalidSchema
	}
}

func encodeIndexValue(value common.JSON, present bool) (string, error) {
	if !present {
		return "missing:", nil
	}
	if value.IsNull() {
		return "null:", nil
	}
	if boolValue, ok := value.AsBool(); ok {
		if boolValue {
			return "bool:true", nil
		}
		return "bool:false", nil
	}
	if intValue, ok := value.AsInt(); ok {
		return "int:" + strconv.FormatInt(intValue, 10), nil
	}
	if floatValue, ok := value.AsFloat(); ok {
		jsonValue, err := common.JSONFloat(floatValue)
		if err != nil {
			return "", err
		}
		return "decimal:" + jsonValue.CanonicalString(), nil
	}
	if stringValue, ok := value.AsString(); ok {
		return "string:" + stringValue, nil
	}
	return "", common.ErrInvalidSchema
}

func encodeIndexKey(parts []string) string {
	var builder strings.Builder
	for _, part := range parts {
		builder.WriteString(strconv.Itoa(len(part)))
		builder.WriteByte(':')
		builder.WriteString(part)
	}
	return builder.String()
}

func indexKeyStartsWith(encodedKey string, prefix []string) bool {
	return strings.HasPrefix(encodedKey, encodeIndexKey(prefix))
}

func indexKeyInRange(encodedKey string, lower *common.IndexBound, upper *common.IndexBound) (bool, error) {
	if lower != nil {
		lowerKey, err := extractIndexKeyFromValues(lower.Values)
		if err != nil {
			return false, err
		}
		encodedLower := encodeIndexKey(lowerKey)
		if lower.Inclusive {
			if encodedKey < encodedLower {
				return false, nil
			}
		} else if encodedKey <= encodedLower {
			return false, nil
		}
	}
	if upper != nil {
		upperKey, err := extractIndexKeyFromValues(upper.Values)
		if err != nil {
			return false, err
		}
		encodedUpper := encodeIndexKey(upperKey)
		if upper.Inclusive {
			if encodedKey > encodedUpper {
				return false, nil
			}
		} else if encodedKey >= encodedUpper {
			return false, nil
		}
	}
	return true, nil
}

func cloneIndexStates(indexes map[common.CollectionName]map[string]indexState) map[common.CollectionName]map[string]indexState {
	clone := make(map[common.CollectionName]map[string]indexState, len(indexes))
	for collection, collectionIndexes := range indexes {
		clone[collection] = make(map[string]indexState, len(collectionIndexes))
		for name, index := range collectionIndexes {
			entries := make(map[string]map[common.Key]struct{}, len(index.entries))
			for encodedKey, keys := range index.entries {
				copiedKeys := make(map[common.Key]struct{}, len(keys))
				for key := range keys {
					copiedKeys[key] = struct{}{}
				}
				entries[encodedKey] = copiedKeys
			}
			clone[collection][name] = indexState{
				descriptor: index.descriptor,
				entries:    entries,
			}
		}
	}
	return clone
}

func removeRecordFromIndexes(indexes map[common.CollectionName]map[string]indexState, record common.VersionedRecord) error {
	collectionIndexes, ok := indexes[record.Collection]
	if !ok {
		return nil
	}
	for name, index := range collectionIndexes {
		parts, err := extractIndexKey(record.Document, index.descriptor)
		if err != nil {
			return err
		}
		encodedKey := encodeIndexKey(parts)
		if keys, ok := index.entries[encodedKey]; ok {
			delete(keys, record.Key)
			if len(keys) == 0 {
				delete(index.entries, encodedKey)
			}
		}
		collectionIndexes[name] = index
	}
	return nil
}

func addRecordToIndexes(indexes map[common.CollectionName]map[string]indexState, record common.VersionedRecord) error {
	collectionIndexes, ok := indexes[record.Collection]
	if !ok {
		return nil
	}
	for name, index := range collectionIndexes {
		parts, err := extractIndexKey(record.Document, index.descriptor)
		if err != nil {
			return err
		}
		encodedKey := encodeIndexKey(parts)
		keys := index.entries[encodedKey]
		if keys == nil {
			keys = map[common.Key]struct{}{}
			index.entries[encodedKey] = keys
		}
		if index.descriptor.Unique {
			for existingKey := range keys {
				if existingKey != record.Key {
					return conflict(common.UniqueIndexConflict, "unique index conflict on collection '"+string(record.Collection)+"' index '"+index.descriptor.Name+"'")
				}
			}
		}
		keys[record.Key] = struct{}{}
		collectionIndexes[name] = index
	}
	return nil
}

type Transaction struct {
	state *state
	open  bool

	readVersions map[string]common.Version
	puts         map[string]common.VersionedRecord
	erases       map[string]struct{}
}

func newTransaction(s *state) *Transaction {
	return &Transaction{
		state:        s,
		open:         true,
		readVersions: map[string]common.Version{},
		puts:         map[string]common.VersionedRecord{},
		erases:       map[string]struct{}{},
	}
}

func (tx *Transaction) IsOpen() bool {
	return tx != nil && tx.open
}

func (tx *Transaction) Abort(ctx context.Context) error {
	_ = ctx
	if tx == nil {
		return common.ErrNotFound
	}
	tx.open = false
	tx.readVersions = map[string]common.Version{}
	tx.puts = map[string]common.VersionedRecord{}
	tx.erases = map[string]struct{}{}
	return nil
}

func (tx *Transaction) Get(ctx context.Context, collection common.CollectionName, key common.Key) (*common.VersionedRecord, error) {
	_ = ctx
	if !tx.IsOpen() {
		return nil, common.ErrUnsupported
	}
	versionKey := recordVersionKey(collection, key)
	if _, erased := tx.erases[versionKey]; erased {
		return nil, nil
	}
	if record, ok := tx.puts[versionKey]; ok {
		return &record, nil
	}

	tx.state.mu.Lock()
	defer tx.state.mu.Unlock()
	collectionRecords, ok := tx.state.records[collection]
	if !ok {
		tx.readVersions[versionKey] = 0
		return nil, nil
	}
	record, ok := collectionRecords[key]
	if !ok {
		tx.readVersions[versionKey] = 0
		return nil, nil
	}
	tx.readVersions[versionKey] = record.Version
	return &record, nil
}

func (tx *Transaction) Query(ctx context.Context, collection common.CollectionName, query common.Query) ([]common.VersionedRecord, error) {
	_ = ctx
	if !tx.IsOpen() {
		return nil, common.ErrUnsupported
	}
	byKey := map[string]common.VersionedRecord{}

	tx.state.mu.Lock()
	if isIndexQuery(query) {
		records, err := tx.committedIndexQueryLocked(collection, query)
		if err != nil {
			tx.state.mu.Unlock()
			return nil, err
		}
		for _, record := range records {
			byKey[string(record.Key)] = record
		}
	} else if collectionRecords, ok := tx.state.records[collection]; ok {
		for key, record := range collectionRecords {
			if _, staged := tx.puts[recordVersionKey(record.Collection, record.Key)]; !staged {
				byKey[string(key)] = record
			}
		}
	}
	tx.state.mu.Unlock()

	for _, record := range tx.puts {
		matches := true
		if isIndexQuery(query) {
			var err error
			matches, err = tx.stagedRecordMatchesIndexQuery(record, query)
			if err != nil {
				return nil, err
			}
		}
		if record.Collection == collection && matches {
			byKey[string(record.Key)] = record
		}
	}
	for versionKey := range tx.erases {
		erasedCollection, erasedKey, ok := parseRecordVersionKey(versionKey)
		if ok && erasedCollection == collection {
			delete(byKey, string(erasedKey))
		}
	}

	var records []common.VersionedRecord
	for _, record := range byKey {
		if recordMatchesQuery(record, query) {
			tx.readVersions[recordVersionKey(record.Collection, record.Key)] = record.Version
			records = append(records, record)
		}
	}
	return records, nil
}

func isIndexQuery(query common.Query) bool {
	return query.Kind == common.QueryIndexEquals || query.Kind == common.QueryIndexPrefix || query.Kind == common.QueryIndexRange
}

func (tx *Transaction) committedIndexQueryLocked(collection common.CollectionName, query common.Query) ([]common.VersionedRecord, error) {
	if query.IndexName == nil {
		return nil, nil
	}
	collectionIndexes, ok := tx.state.indexes[collection]
	if !ok {
		return nil, nil
	}
	index, ok := collectionIndexes[*query.IndexName]
	if !ok {
		return nil, nil
	}
	var records []common.VersionedRecord
	for encodedKey, keys := range index.entries {
		matches, err := matchesIndexKey(encodedKey, query)
		if err != nil {
			return nil, err
		}
		if !matches {
			continue
		}
		for key := range keys {
			if record, ok := tx.state.records[collection][key]; ok {
				records = append(records, record)
			}
		}
	}
	return records, nil
}

func (tx *Transaction) stagedRecordMatchesIndexQuery(record common.VersionedRecord, query common.Query) (bool, error) {
	if query.IndexName == nil {
		return false, nil
	}
	tx.state.mu.Lock()
	collectionIndexes, ok := tx.state.indexes[record.Collection]
	if !ok {
		tx.state.mu.Unlock()
		return false, nil
	}
	index, ok := collectionIndexes[*query.IndexName]
	tx.state.mu.Unlock()
	if !ok {
		return false, nil
	}
	parts, err := extractIndexKey(record.Document, index.descriptor)
	if err != nil {
		return false, err
	}
	return matchesIndexKey(encodeIndexKey(parts), query)
}

func matchesIndexKey(encodedKey string, query common.Query) (bool, error) {
	switch query.Kind {
	case common.QueryIndexEquals:
		key, err := extractIndexKeyFromValues(query.IndexValues)
		if err != nil {
			return false, err
		}
		return indexKeyStartsWith(encodedKey, key), nil
	case common.QueryIndexPrefix:
		key, err := extractIndexKeyFromValues(query.IndexValues)
		if err != nil {
			return false, err
		}
		return indexKeyStartsWith(encodedKey, key), nil
	case common.QueryIndexRange:
		return indexKeyInRange(encodedKey, query.LowerBound, query.UpperBound)
	default:
		return false, nil
	}
}

func (tx *Transaction) Put(ctx context.Context, collection common.CollectionName, key common.Key, document common.JSON) error {
	_ = ctx
	if !tx.IsOpen() {
		return common.ErrUnsupported
	}
	if _, err := tx.Get(ctx, collection, key); err != nil {
		return err
	}
	versionKey := recordVersionKey(collection, key)
	tx.puts[versionKey] = common.VersionedRecord{Collection: collection, Key: key, Document: document}
	delete(tx.erases, versionKey)
	return nil
}

func (tx *Transaction) Erase(ctx context.Context, collection common.CollectionName, key common.Key) error {
	_ = ctx
	if !tx.IsOpen() {
		return common.ErrUnsupported
	}
	if _, err := tx.Get(ctx, collection, key); err != nil {
		return err
	}
	versionKey := recordVersionKey(collection, key)
	delete(tx.puts, versionKey)
	tx.erases[versionKey] = struct{}{}
	return nil
}

func (tx *Transaction) commit() error {
	if !tx.IsOpen() {
		return common.ErrUnsupported
	}
	tx.state.mu.Lock()
	defer tx.state.mu.Unlock()

	for versionKey, expectedVersion := range tx.readVersions {
		if versionOrZero(tx.state.versions, versionKey) != expectedVersion {
			return conflict(common.VersionConflict, "in-memory OCC conflict")
		}
	}

	stagedIndexes := cloneIndexStates(tx.state.indexes)
	for versionKey := range tx.erases {
		collection, key, ok := parseRecordVersionKey(versionKey)
		if !ok {
			continue
		}
		if records, exists := tx.state.records[collection]; exists {
			if record, found := records[key]; found {
				if err := removeRecordFromIndexes(stagedIndexes, record); err != nil {
					return err
				}
			}
		}
	}
	for _, record := range tx.puts {
		if records, exists := tx.state.records[record.Collection]; exists {
			if existing, found := records[record.Key]; found {
				if err := removeRecordFromIndexes(stagedIndexes, existing); err != nil {
					return err
				}
			}
		}
		if err := addRecordToIndexes(stagedIndexes, record); err != nil {
			return err
		}
	}

	for versionKey := range tx.erases {
		collection, key, ok := parseRecordVersionKey(versionKey)
		if ok {
			if records, exists := tx.state.records[collection]; exists {
				delete(records, key)
			}
		}
		tx.state.versions[versionKey]++
	}
	for versionKey, record := range tx.puts {
		tx.state.versions[versionKey]++
		record.Version = tx.state.versions[versionKey]
		if _, ok := tx.state.records[record.Collection]; !ok {
			tx.state.records[record.Collection] = map[common.Key]common.VersionedRecord{}
		}
		tx.state.records[record.Collection][record.Key] = record
	}
	tx.state.indexes = stagedIndexes
	return tx.Abort(context.Background())
}

func asMemoryTx(tx common.Transaction) (*Transaction, error) {
	memoryTx, ok := tx.(*Transaction)
	if !ok || memoryTx == nil || !memoryTx.open {
		return nil, common.ErrUnsupported
	}
	return memoryTx, nil
}

func recordMatchesQuery(record common.VersionedRecord, query common.Query) bool {
	switch query.Kind {
	case common.QueryAll:
		return true
	case common.QueryKeyPrefix:
		return query.KeyPrefix != nil && strings.HasPrefix(string(record.Key), *query.KeyPrefix)
	case common.QueryJSONEquals:
		if query.JSONPath == nil || query.JSONValue == nil {
			return false
		}
		value, ok := findJSONPath(record.Document, *query.JSONPath)
		return ok && value.CanonicalString() == query.JSONValue.CanonicalString()
	case common.QueryIndexEquals, common.QueryIndexPrefix, common.QueryIndexRange:
		return true
	default:
		return true
	}
}

func findJSONPath(document common.JSON, path string) (common.JSON, bool) {
	current := document
	for _, segment := range strings.Split(path, ".") {
		next, ok := current.Find(segment)
		if !ok {
			return common.JSON{}, false
		}
		current = next
	}
	return current, true
}

func recordVersionKey(collection common.CollectionName, key common.Key) string {
	return "record:" + string(collection) + ":" + string(key)
}

func versionOrZero(versions map[string]common.Version, key string) common.Version {
	if value, ok := versions[key]; ok {
		return value
	}
	return 0
}

func parseRecordVersionKey(versionKey string) (common.CollectionName, common.Key, bool) {
	const prefix = "record:"
	if !strings.HasPrefix(versionKey, prefix) {
		return "", "", false
	}
	rest := strings.TrimPrefix(versionKey, prefix)
	separator := strings.Index(rest, ":")
	if separator < 0 {
		return "", "", false
	}
	return common.CollectionName(rest[:separator]), common.Key(rest[separator+1:]), true
}

func definitionKey(parts ...any) string {
	out := ""
	for index, part := range parts {
		if index > 0 {
			out += ":"
		}
		out += fmt.Sprint(part)
	}
	return out
}

func conflict(kind common.ConflictKind, message string) error {
	return common.ConflictError{Kind: kind, Message: message}
}
