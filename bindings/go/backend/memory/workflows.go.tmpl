	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) CompleteStepTx(ctx context.Context, tx common.Transaction, request common.CompleteWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaim(execution, request.Worker, request.CompletedStep); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution.State = request.State
	execution.ClaimedBy = nil
	execution.ClaimExpiresAt = nil
	if request.NextStep == nil {
		execution.Status = "Completed"
	} else {
		execution.CurrentStep = *request.NextStep
		execution.Status = "Running"
	}
	memoryTx.workflowExecutionPuts[execution.WorkflowExecutionID] = execution
	return execution, nil
}

func (s *WorkflowStore) FailStep(ctx context.Context, backend common.Backend, request common.FailWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	result, err := s.FailStepTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.WorkflowExecutionRecord{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) FailStepTx(ctx context.Context, tx common.Transaction, request common.FailWorkflowStepRequest) (common.WorkflowExecutionRecord, error) {
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if err := requireWorkflowClaim(execution, request.Worker, request.FailedStep); err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution.ClaimedBy = nil
	execution.ClaimExpiresAt = nil
	if execution.Attempt >= uint64(request.MaxAttempts) {
		execution.Status = "Failed"
	} else {
		execution.Status = "Running"
	}
	memoryTx.workflowExecutionPuts[execution.WorkflowExecutionID] = execution
	return execution, nil
}

