}

func (s *WorkflowStore) CancelTx(ctx context.Context, tx common.Transaction, request common.CancelWorkflowRequest) (common.WorkflowExecutionRecord, error) {
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution, err := s.requireExecution(ctx, tx, request.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	execution.Status = "Canceled"
	execution.ClaimedBy = nil
	execution.ClaimExpiresAt = nil
	memoryTx.workflowExecutionPuts[execution.WorkflowExecutionID] = execution
	return execution, nil
}

func (s *WorkflowStore) Inspect(ctx context.Context, backend common.Backend, workflowExecutionID string) (*common.WorkflowExecutionRecord, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.InspectTx(ctx, tx, workflowExecutionID)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *WorkflowStore) InspectTx(ctx context.Context, tx common.Transaction, workflowExecutionID string) (*common.WorkflowExecutionRecord, error) {
	_ = ctx
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return nil, err
	}
	if execution, ok := memoryTx.workflowExecutionPuts[workflowExecutionID]; ok {
		return &execution, nil
	}
	memoryTx.state.mu.Lock()
	defer memoryTx.state.mu.Unlock()
	if execution, ok := memoryTx.state.workflowExecutions[workflowExecutionID]; ok {
		return &execution, nil
	}
	return nil, nil
}

func (s *WorkflowStore) requireExecution(ctx context.Context, tx common.Transaction, workflowExecutionID string) (common.WorkflowExecutionRecord, error) {
	record, err := s.InspectTx(ctx, tx, workflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if record == nil {
		return common.WorkflowExecutionRecord{}, common.ErrNotFound
	}
	return *record, nil
}

func (s *WorkflowStore) allExecutions(tx *Transaction) []common.WorkflowExecutionRecord {
	byID := map[string]common.WorkflowExecutionRecord{}
	tx.state.mu.Lock()
	for id, execution := range tx.state.workflowExecutions {
		byID[id] = execution
	}
	tx.state.mu.Unlock()
	for id, execution := range tx.workflowExecutionPuts {
		byID[id] = execution
	}
	executions := make([]common.WorkflowExecutionRecord, 0, len(byID))
	for _, execution := range byID {
		executions = append(executions, execution)
	}
	return executions
}

func workflowDefinitionKey(name string, version int64) string {
	return definitionKey(name, version)
}

func requireWorkflowClaim(execution common.WorkflowExecutionRecord, worker string, step string) error {
	if execution.ClaimedBy == nil || *execution.ClaimedBy != worker || execution.CurrentStep != step {
		return conflict(common.WorkflowClaimConflict, "workflow step is not claimed by caller")
	}
	return nil
}
