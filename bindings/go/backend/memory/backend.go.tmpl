package memory

import (
	"context"
	"strings"

	common "statespec-generated/common/backend"
)

type Backend struct {
	state *state
}

func NewBackend() *Backend {
	return &Backend{state: newState()}
}

func (b *Backend) Capabilities(ctx context.Context) common.BackendCapabilities {
	_ = ctx
	return common.BackendCapabilities{
		Transactions:   true,
		CompareAndSwap: true,
		PrefixQuery:    true,
	}
}

func (b *Backend) EnsureCollection(ctx context.Context, descriptor common.CollectionDescriptor) error {
	_ = ctx
	b.state.mu.Lock()
	defer b.state.mu.Unlock()
	b.state.collections[common.CollectionName(descriptor.Name)] = descriptor
	return nil
}

func (b *Backend) EnsureCollections(ctx context.Context, descriptors []common.CollectionDescriptor) error {
	for _, descriptor := range descriptors {
		if err := b.EnsureCollection(ctx, descriptor); err != nil {
			return err
		}
	}
	return nil
}

func (b *Backend) Begin(ctx context.Context) (common.Transaction, error) {
	_ = ctx
	return newTransaction(b.state), nil
}

func (b *Backend) Get(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key) (*common.VersionedRecord, error) {
	_ = ctx
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return nil, err
	}
	versionKey := recordVersionKey(collection, key)
	if _, erased := memoryTx.erases[versionKey]; erased {
		return nil, nil
	}
	if record, ok := memoryTx.puts[versionKey]; ok {
		return &record, nil
	}

	memoryTx.state.mu.Lock()
	defer memoryTx.state.mu.Unlock()
	collectionRecords, ok := memoryTx.state.records[collection]
	if !ok {
		memoryTx.readVersions[versionKey] = 0
		return nil, nil
	}
	record, ok := collectionRecords[key]
	if !ok {
		memoryTx.readVersions[versionKey] = 0
		return nil, nil
	}
	memoryTx.readVersions[versionKey] = record.Version
	return &record, nil
}

func (b *Backend) Query(ctx context.Context, tx common.Transaction, collection common.CollectionName, query common.Query) ([]common.VersionedRecord, error) {
	_ = ctx
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return nil, err
	}
	byKey := map[string]common.VersionedRecord{}

	memoryTx.state.mu.Lock()
	if collectionRecords, ok := memoryTx.state.records[collection]; ok {
		for key, record := range collectionRecords {
			byKey[string(key)] = record
		}
	}
	memoryTx.state.mu.Unlock()

	for versionKey, record := range memoryTx.puts {
		if record.Collection == collection {
			byKey[string(record.Key)] = record
		}
		_ = versionKey
	}
	for versionKey := range memoryTx.erases {
		erasedCollection, erasedKey, ok := parseRecordVersionKey(versionKey)
		if ok && erasedCollection == collection {
			delete(byKey, string(erasedKey))
		}
	}

	var records []common.VersionedRecord
	for _, record := range byKey {
		if recordMatchesQuery(record, query) {
			memoryTx.readVersions[recordVersionKey(record.Collection, record.Key)] = record.Version
			records = append(records, record)
		}
	}
	return records, nil
}

func (b *Backend) Put(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key, document common.JSON) error {
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return err
	}
	if _, err := b.Get(ctx, tx, collection, key); err != nil {
		return err
	}
	versionKey := recordVersionKey(collection, key)
	memoryTx.puts[versionKey] = common.VersionedRecord{Collection: collection, Key: key, Document: document}
	delete(memoryTx.erases, versionKey)
	return nil
}

func (b *Backend) Erase(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key) error {
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return err
	}
	if _, err := b.Get(ctx, tx, collection, key); err != nil {
		return err
	}
	versionKey := recordVersionKey(collection, key)
	delete(memoryTx.puts, versionKey)
	memoryTx.erases[versionKey] = struct{}{}
	return nil
}

func (b *Backend) Commit(ctx context.Context, tx common.Transaction) error {
	_ = ctx
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return err
	}
	memoryTx.state.mu.Lock()
	defer memoryTx.state.mu.Unlock()

	for versionKey, expectedVersion := range memoryTx.readVersions {
		if versionOrZero(memoryTx.state.versions, versionKey) != expectedVersion {
			return conflict(common.VersionConflict, "in-memory OCC conflict")
		}
	}
	for versionKey := range memoryTx.erases {
		collection, key, ok := parseRecordVersionKey(versionKey)
		if ok {
			if records, exists := memoryTx.state.records[collection]; exists {
				delete(records, key)
			}
		}
		memoryTx.state.versions[versionKey]++
	}
	for versionKey, record := range memoryTx.puts {
		memoryTx.state.versions[versionKey]++
		record.Version = memoryTx.state.versions[versionKey]
		if _, ok := memoryTx.state.records[record.Collection]; !ok {
			memoryTx.state.records[record.Collection] = map[common.Key]common.VersionedRecord{}
		}
		memoryTx.state.records[record.Collection][record.Key] = record
	}

	for key, value := range memoryTx.featureFlagDefinitionPuts {
		memoryTx.state.featureFlagDefinitions[key] = value
	}
	for key, value := range memoryTx.featureFlagValuePuts {
		memoryTx.state.featureFlagValues[key] = value
	}
	for key, value := range memoryTx.queueDefinitionPuts {
		memoryTx.state.queueDefinitions[key] = value
	}
	for key, value := range memoryTx.queueMessagePuts {
		memoryTx.state.queueMessages[key] = value
	}
	for key, value := range memoryTx.queueIdempotencyPuts {
		memoryTx.state.queueIdempotencyKeys[key] = value
	}
	for key, value := range memoryTx.leaseDefinitionPuts {
		memoryTx.state.leaseDefinitions[key] = value
	}
	for key := range memoryTx.leaseErases {
		delete(memoryTx.state.leases, key)
	}
	for key, value := range memoryTx.leasePuts {
		memoryTx.state.leases[key] = value
	}
	for key, value := range memoryTx.workflowDefinitionPuts {
		memoryTx.state.workflowDefinitions[key] = value
	}
	for key, value := range memoryTx.workflowExecutionPuts {
		memoryTx.state.workflowExecutions[key] = value
	}
	for key, value := range memoryTx.logDefinitionPuts {
		memoryTx.state.logDefinitions[key] = value
	}
	memoryTx.state.logEvents = append(memoryTx.state.logEvents, memoryTx.logEventAppends...)
	for key, value := range memoryTx.metricDefinitionPuts {
		memoryTx.state.metricDefinitions[key] = value
	}
	memoryTx.state.metricSamples = append(memoryTx.state.metricSamples, memoryTx.metricSampleAppends...)

	return memoryTx.Abort(ctx)
}

func recordMatchesQuery(record common.VersionedRecord, query common.Query) bool {
	switch query.Kind {
	case common.QueryAll:
		return true
	case common.QueryKeyPrefix:
		return query.KeyPrefix != nil && strings.HasPrefix(string(record.Key), *query.KeyPrefix)
	case common.QueryJSONEquals:
		if query.JSONPath == nil || query.JSONValue == nil {
			return false
		}
		value, ok := findJSONPath(record.Document, *query.JSONPath)
		return ok && value.CanonicalString() == query.JSONValue.CanonicalString()
	default:
		return true
	}
}

func findJSONPath(document common.JSON, path string) (common.JSON, bool) {
	current := document
	for _, segment := range strings.Split(path, ".") {
		next, ok := current.Find(segment)
		if !ok {
			return common.JSON{}, false
		}
		current = next
	}
	return current, true
}
