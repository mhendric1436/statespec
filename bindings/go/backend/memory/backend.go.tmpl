package memory

import (
	"context"

	common "statespec-generated/common/backend"
)

type Backend struct {
	state *state
}

func NewBackend() *Backend {
	return &Backend{state: newState()}
}

func (b *Backend) Capabilities(ctx context.Context) common.BackendCapabilities {
	_ = ctx
	return common.BackendCapabilities{
		Transactions:     true,
		CompareAndSwap:   true,
		PrefixQuery:      true,
		SecondaryIndexes: true,
		UniqueIndexes:    true,
	}
}

func (b *Backend) EnsureCollection(ctx context.Context, descriptor common.CollectionDescriptor) error {
	_ = ctx
	b.state.mu.Lock()
	defer b.state.mu.Unlock()
	collection := common.CollectionName(descriptor.Name)
	if existing, ok := b.state.collections[collection]; ok {
		if err := common.ValidateCollectionDescriptorUpgrade(existing, descriptor); err != nil {
			return err
		}
		b.state.collections[collection] = descriptor
		return nil
	}
	b.state.collections[collection] = descriptor
	b.state.indexes[collection] = emptyIndexStates(descriptor)
	return nil
}

func (b *Backend) EnsureCollections(ctx context.Context, descriptors []common.CollectionDescriptor) error {
	_ = ctx
	b.state.mu.Lock()
	defer b.state.mu.Unlock()
	staged := make(map[common.CollectionName]common.CollectionDescriptor, len(b.state.collections)+len(descriptors))
	for collection, descriptor := range b.state.collections {
		staged[collection] = descriptor
	}
	stagedIndexes := make(map[common.CollectionName]map[string]indexState, len(b.state.indexes)+len(descriptors))
	for collection, indexes := range b.state.indexes {
		stagedIndexes[collection] = indexes
	}
	for _, descriptor := range descriptors {
		collection := common.CollectionName(descriptor.Name)
		if existing, ok := staged[collection]; ok {
			if err := common.ValidateCollectionDescriptorUpgrade(existing, descriptor); err != nil {
				return err
			}
		}
		staged[collection] = descriptor
		if _, exists := b.state.collections[collection]; !exists {
			stagedIndexes[collection] = emptyIndexStates(descriptor)
		}
	}
	b.state.collections = staged
	b.state.indexes = stagedIndexes
	return nil
}

func (b *Backend) Begin(ctx context.Context) (common.Transaction, error) {
	_ = ctx
	return newTransaction(b.state), nil
}

func (b *Backend) Get(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key) (*common.VersionedRecord, error) {
	return tx.Get(ctx, collection, key)
}

func (b *Backend) Query(ctx context.Context, tx common.Transaction, collection common.CollectionName, query common.Query) ([]common.VersionedRecord, error) {
	return tx.Query(ctx, collection, query)
}

func (b *Backend) Put(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key, document common.JSON) error {
	return tx.Put(ctx, collection, key, document)
}

func (b *Backend) Erase(ctx context.Context, tx common.Transaction, collection common.CollectionName, key common.Key) error {
	return tx.Erase(ctx, collection, key)
}

func (b *Backend) Commit(ctx context.Context, tx common.Transaction) error {
	_ = ctx
	memoryTx, err := asMemoryTx(tx)
	if err != nil {
		return err
	}
	return memoryTx.commit()
}
