package memory

import (
	"context"

	common "statespec-generated/common/backend"
)

const (
	metricDefinitionsCollection common.CollectionName = "statespec_metric_definitions"
	metricSamplesCollection     common.CollectionName = "statespec_metric_samples"
)

type MetricSink struct {
	nextSampleID uint64
}

func NewMetricSink() *MetricSink {
	return &MetricSink{}
}

func (s *MetricSink) RegisterDefinition(ctx context.Context, backend common.Backend, definition common.MetricInstrumentDefinition) (common.MetricInstrumentRegistration, error) {
	if err := ensureMetricCollections(ctx, backend); err != nil {
		return common.MetricInstrumentRegistration{}, err
	}
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.MetricInstrumentRegistration{}, err
	}
	result, err := s.RegisterDefinitionTx(ctx, tx, definition)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.MetricInstrumentRegistration{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *MetricSink) RegisterDefinitionTx(ctx context.Context, tx common.Transaction, definition common.MetricInstrumentDefinition) (common.MetricInstrumentRegistration, error) {
	existing, err := s.InspectDefinitionTx(ctx, tx, definition.Name)
	if err != nil {
		return common.MetricInstrumentRegistration{}, err
	}
	if err := tx.Put(ctx, metricDefinitionsCollection, common.Key(definition.Name), metricDefinitionToJSON(definition)); err != nil {
		return common.MetricInstrumentRegistration{}, err
	}
	return common.MetricInstrumentRegistration{RegisteredNew: existing == nil, Definition: definition}, nil
}

func (s *MetricSink) InspectDefinition(ctx context.Context, backend common.Backend, name string) (*common.MetricInstrumentDefinition, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.InspectDefinitionTx(ctx, tx, name)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *MetricSink) InspectDefinitionTx(ctx context.Context, tx common.Transaction, name string) (*common.MetricInstrumentDefinition, error) {
	record, err := tx.Get(ctx, metricDefinitionsCollection, common.Key(name))
	if err != nil || record == nil {
		return nil, err
	}
	definition := metricDefinitionFromJSON(record.Document)
	return &definition, nil
}

func (s *MetricSink) RecordMetric(ctx context.Context, backend common.Backend, sample common.MetricSample) error {
	if err := ensureMetricCollections(ctx, backend); err != nil {
		return err
	}
	tx, err := backend.Begin(ctx)
	if err != nil {
		return err
	}
	if err := s.RecordMetricTx(ctx, tx, sample); err != nil {
		_ = tx.Abort(ctx)
		return err
	}
	return backend.Commit(ctx, tx)
}

func (s *MetricSink) RecordMetricTx(ctx context.Context, tx common.Transaction, sample common.MetricSample) error {
	return tx.Put(ctx, metricSamplesCollection, common.Key(eventKey(sample.Name, &s.nextSampleID)), metricSampleToJSON(sample))
}

func (s *MetricSink) InspectSamples(ctx context.Context, backend common.Backend) ([]common.MetricSample, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	samples, err := s.InspectSamplesTx(ctx, tx)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return samples, backend.Commit(ctx, tx)
}

func (s *MetricSink) InspectSamplesTx(ctx context.Context, tx common.Transaction) ([]common.MetricSample, error) {
	records, err := tx.Query(ctx, metricSamplesCollection, common.AllQuery())
	if err != nil {
		return nil, err
	}
	samples := make([]common.MetricSample, 0, len(records))
	for _, record := range records {
		samples = append(samples, metricSampleFromJSON(record.Document))
	}
	return samples, nil
}

func ensureMetricCollections(ctx context.Context, backend common.Backend) error {
	return backend.EnsureCollections(ctx, []common.CollectionDescriptor{
		{Name: string(metricDefinitionsCollection), KeyFields: []string{"name"}},
		{Name: string(metricSamplesCollection), KeyFields: []string{"sample_id"}},
	})
}
