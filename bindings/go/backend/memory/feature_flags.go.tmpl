package memory

import (
	"context"

	common "statespec-generated/common/backend"
)

const (
	featureFlagDefinitionsCollection common.CollectionName = "statespec_feature_flag_definitions"
	featureFlagValuesCollection      common.CollectionName = "statespec_feature_flag_values"
)

type FeatureFlagStore struct{}

func NewFeatureFlagStore() *FeatureFlagStore {
	return &FeatureFlagStore{}
}

func (s *FeatureFlagStore) RegisterDefinition(ctx context.Context, backend common.Backend, definition common.FeatureFlagDefinition) (common.FeatureFlagRegisterDefinitionResult, error) {
	if err := ensureFeatureFlagCollections(ctx, backend); err != nil {
		return common.FeatureFlagRegisterDefinitionResult{}, err
	}
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.FeatureFlagRegisterDefinitionResult{}, err
	}
	result, err := s.RegisterDefinitionTx(ctx, tx, definition)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.FeatureFlagRegisterDefinitionResult{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *FeatureFlagStore) RegisterDefinitionTx(ctx context.Context, tx common.Transaction, definition common.FeatureFlagDefinition) (common.FeatureFlagRegisterDefinitionResult, error) {
	existing, err := s.InspectDefinitionTx(ctx, tx, definition.Name)
	if err != nil {
		return common.FeatureFlagRegisterDefinitionResult{}, err
	}
	if err := tx.Put(ctx, featureFlagDefinitionsCollection, common.Key(definition.Name), featureFlagDefinitionToJSON(definition)); err != nil {
		return common.FeatureFlagRegisterDefinitionResult{}, err
	}
	return common.FeatureFlagRegisterDefinitionResult{RegisteredNew: existing == nil, Definition: definition}, nil
}

func (s *FeatureFlagStore) InspectDefinition(ctx context.Context, backend common.Backend, name string) (*common.FeatureFlagDefinition, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return nil, err
	}
	result, err := s.InspectDefinitionTx(ctx, tx, name)
	if err != nil {
		_ = tx.Abort(ctx)
		return nil, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *FeatureFlagStore) InspectDefinitionTx(ctx context.Context, tx common.Transaction, name string) (*common.FeatureFlagDefinition, error) {
	record, err := tx.Get(ctx, featureFlagDefinitionsCollection, common.Key(name))
	if err != nil || record == nil {
		return nil, err
	}
	definition := featureFlagDefinitionFromJSON(record.Document)
	return &definition, nil
}

func (s *FeatureFlagStore) Evaluate(ctx context.Context, backend common.Backend, request common.FeatureFlagEvaluationRequest) (common.FeatureFlagValue, error) {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return common.FeatureFlagValue{}, err
	}
	result, err := s.EvaluateTx(ctx, tx, request)
	if err != nil {
		_ = tx.Abort(ctx)
		return common.FeatureFlagValue{}, err
	}
	return result, backend.Commit(ctx, tx)
}

func (s *FeatureFlagStore) EvaluateTx(ctx context.Context, tx common.Transaction, request common.FeatureFlagEvaluationRequest) (common.FeatureFlagValue, error) {
	if record, err := tx.Get(ctx, featureFlagValuesCollection, common.Key(featureFlagEvaluationKey(request))); err != nil {
		return common.FeatureFlagValue{}, err
	} else if record != nil {
		return featureFlagValueFromJSON(record.Document), nil
	}
	definition, err := s.InspectDefinitionTx(ctx, tx, request.Name)
	if err != nil {
		return common.FeatureFlagValue{}, err
	}
	if definition == nil {
		return common.FeatureFlagValue{}, common.ErrNotFound
	}
	return definition.DefaultValue, nil
}

func ensureFeatureFlagCollections(ctx context.Context, backend common.Backend) error {
	return backend.EnsureCollections(ctx, []common.CollectionDescriptor{
		{Name: string(featureFlagDefinitionsCollection), KeyFields: []string{"name"}},
		{Name: string(featureFlagValuesCollection), KeyFields: []string{"scope_key"}},
	})
}

func featureFlagEvaluationKey(request common.FeatureFlagEvaluationRequest) string {
	key := request.Name
	if request.Context.TenantID != nil {
		key += "|tenant:" + *request.Context.TenantID
	}
	if request.Context.UserID != nil {
		key += "|user:" + *request.Context.UserID
	}
	if request.Context.EntityType != nil {
		key += "|entity_type:" + *request.Context.EntityType
	}
	if request.Context.EntityID != nil {
		key += "|entity_id:" + *request.Context.EntityID
	}
	return key
}
