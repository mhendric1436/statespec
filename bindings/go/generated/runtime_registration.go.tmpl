func RegisterRuntimeCatalog(ctx context.Context, backend Backend{{runtime_parameters}}) error {
	tx, err := backend.Begin(ctx)
	if err != nil {
		return err
	}
	if err := RegisterRuntimeCatalogTx(ctx, tx{{runtime_arguments}}); err != nil {
		_ = tx.Abort(ctx)
		return err
	}
	return backend.Commit(ctx, tx)
}

func BootstrapRuntimeCatalog(ctx context.Context, backend Backend{{runtime_parameters}}) error {
	if err := EnsureSystemCollections(ctx, backend); err != nil {
		return err
	}
	return RegisterRuntimeCatalog(ctx, backend{{runtime_arguments}})
}
