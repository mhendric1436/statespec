GO ?= go
GOFMT ?= gofmt
BIN_DIR ?= build/bin
DIST_DIR ?= dist

COMMON_PACKAGES := ./common/...
API_PACKAGES := ./api/backend{{api_package_additions}}
WORKER_PACKAGES := ./worker/backend{{worker_package_additions}}

CHECK_TARGETS := check-common
BUILD_TARGETS := build-common
PACKAGE_TARGETS := package-common{{target_additions}}

.PHONY: all help check build package format check-common build-common package-common{{phony_targets}} clean

all: check

help:
	@printf '%s\n' 'StateSpec generated Go bindings Makefile'
	@printf '%s\n' ''
	@printf '%s\n' 'Default target: all -> check'
	@printf '%s\n' '  check   Runs go test for generated packages.'
	@printf '%s\n' '  build   Runs go build for generated packages and entrypoint binaries.'
	@printf '%s\n' '  package Builds and archives generated artifacts under $(DIST_DIR).'
	@printf '%s\n' '  format  Formats generated Go sources with $(GOFMT).'
	@printf '%s\n' '  clean   Clears Go test cache and removes build and $(DIST_DIR).'
	@printf '%s\n' ''
	@printf '%s\n' 'Tier targets:'
	@printf '%s\n' '  check-common  build-common  package-common'
{{help_target_additions}}

check: $(CHECK_TARGETS)

build: $(BUILD_TARGETS)

package: $(PACKAGE_TARGETS)

format:
	for dir in common api worker; do \
		if [ -d $$dir ]; then \
			find $$dir -type f -name '*.go' -exec $(GOFMT) -w {} +; \
		fi; \
	done

$(DIST_DIR):
	mkdir -p $(DIST_DIR)

$(BIN_DIR):
	mkdir -p $(BIN_DIR)

check-common:
	$(GO) test $(COMMON_PACKAGES)

build-common:
	$(GO) build $(COMMON_PACKAGES)

package-common: build-common $(DIST_DIR)
	tar -czf $(DIST_DIR)/statespec-generated-common-go.tgz common go.mod Makefile

{{api_rules}}{{worker_rules}}clean:
	$(GO) clean -testcache
	rm -rf build $(DIST_DIR)
