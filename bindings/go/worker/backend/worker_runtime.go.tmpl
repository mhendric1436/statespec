type WorkerEntityGCWorkerFunc func(ctx context.Context, now string) error

type WorkerTierRuntimeConfig struct {
	EntityGCEnabled      bool
	EntityGCPollInterval time.Duration
}

func DefaultWorkerTierRuntimeConfig() WorkerTierRuntimeConfig {
	return WorkerTierRuntimeConfig{
		EntityGCEnabled:      true,
		EntityGCPollInterval: time.Minute,
	}
}

type WorkerTierRuntime struct {
	Backend      common.Backend
	Config       WorkerTierRuntimeConfig
{{runtime_store_fields}}
	EntityGCWorkers []WorkerEntityGCWorkerFunc
	gcMu            sync.Mutex
	gcCtx           context.Context
	gcCancel        context.CancelFunc
	gcStarted       bool
	gcWait          sync.WaitGroup
}

func NewWorkerTierRuntime(backend common.Backend) *WorkerTierRuntime {
	return NewWorkerTierRuntimeWithConfig(backend, DefaultWorkerTierRuntimeConfig())
}

func NewWorkerTierRuntimeWithConfig(backend common.Backend, config WorkerTierRuntimeConfig) *WorkerTierRuntime {
	return &WorkerTierRuntime{
		Backend:      backend,
		Config:       config,
{{runtime_store_initializers}}
	}
}

func (runtime *WorkerTierRuntime) AddEntityGCWorker(worker WorkerEntityGCWorkerFunc) error {
	runtime.gcMu.Lock()
	defer runtime.gcMu.Unlock()
	if runtime.gcStarted {
		return fmt.Errorf("cannot add entity GC worker after Worker runtime start")
	}
	runtime.EntityGCWorkers = append(runtime.EntityGCWorkers, worker)
	return nil
}

func (runtime *WorkerTierRuntime) StartEntityGCWorkers(ctx context.Context, pollInterval time.Duration) error {
	runtime.gcMu.Lock()
	defer runtime.gcMu.Unlock()
	if runtime.gcStarted {
		return fmt.Errorf("Worker runtime entity GC workers already started")
	}
	if !runtime.Config.EntityGCEnabled {
		runtime.gcStarted = true
		return nil
	}
	if pollInterval <= 0 {
		pollInterval = runtime.Config.EntityGCPollInterval
	}
	if pollInterval <= 0 {
		pollInterval = time.Minute
	}
	runtime.gcCtx, runtime.gcCancel = context.WithCancel(ctx)
	runtime.gcStarted = true
	for _, worker := range runtime.EntityGCWorkers {
		runtime.gcWait.Add(1)
		go func(worker WorkerEntityGCWorkerFunc) {
			defer runtime.gcWait.Done()
			ticker := time.NewTicker(pollInterval)
			defer ticker.Stop()
			for {
				now := time.Now().UTC().Format(time.RFC3339)
				_ = worker(runtime.gcCtx, now)
				select {
				case <-runtime.gcCtx.Done():
					return
				case <-ticker.C:
				}
			}
		}(worker)
	}
	return nil
}

func (runtime *WorkerTierRuntime) RequestStop() {
	runtime.gcMu.Lock()
	cancel := runtime.gcCancel
	runtime.gcMu.Unlock()
	if cancel != nil {
		cancel()
	}
}

func (runtime *WorkerTierRuntime) JoinEntityGCWorkers() {
	runtime.gcWait.Wait()
}

func (runtime *WorkerTierRuntime) RegisterDefinitions(ctx context.Context) error {
	return runtime.Bootstrap(ctx)
}

func (runtime *WorkerTierRuntime) Bootstrap(ctx context.Context) error {
{{entity_collection_bootstrap}}
