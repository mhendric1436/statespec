package backend

import (
	"context"
	"fmt"
	"sync"
	"time"
)

type WorkerProcessConfig struct {
	BootstrapOnStart bool
	WorkerPollInterval time.Duration
}

func DefaultWorkerProcessConfig() WorkerProcessConfig {
	return WorkerProcessConfig{
		BootstrapOnStart: true,
		WorkerPollInterval: time.Second,
	}
}

type WorkerProcess struct {
	Runtime *WorkerTierRuntime
	Invokers WorkflowStepInvokerMap
	Config  WorkerProcessConfig

	lifecycleMu sync.Mutex
	workerWait  sync.WaitGroup
	ctx         context.Context
	cancel      context.CancelFunc
	done        chan struct{}
	runErr      error
	started     bool
	running     bool
}

func NewWorkerProcess(runtime *WorkerTierRuntime, invokers WorkflowStepInvokerMap) *WorkerProcess {
	return NewWorkerProcessWithConfig(runtime, invokers, DefaultWorkerProcessConfig())
}

func NewWorkerProcessWithConfig(runtime *WorkerTierRuntime, invokers WorkflowStepInvokerMap, config WorkerProcessConfig) *WorkerProcess {
	return &WorkerProcess{
		Runtime: runtime,
		Invokers: invokers,
		Config:  config,
	}
}

func (process *WorkerProcess) Run(ctx context.Context) error {
	if process.Config.BootstrapOnStart {
		if err := process.Runtime.Bootstrap(ctx); err != nil {
			return err
		}
	}
	if err := process.Runtime.StartEntityGCWorkers(ctx, 0); err != nil {
		return err
	}
	process.startWorkerLoops(ctx)
	<-ctx.Done()
	process.Runtime.RequestStop()
	process.workerWait.Wait()
	process.Runtime.JoinEntityGCWorkers()
	return ctx.Err()
}

func (process *WorkerProcess) startWorkerLoops(ctx context.Context) {
	interval := process.Config.WorkerPollInterval
	if interval <= 0 {
		interval = time.Second
	}
	for _, workerContext := range WorkerTierContexts() {
		workerContext := workerContext
		if workerContext.Executes == nil {
			continue
		}
		concurrency := workerContext.Concurrency
		if concurrency < 1 {
			concurrency = 1
		}
		for index := 0; index < concurrency; index++ {
			process.workerWait.Add(1)
			go func() {
				defer process.workerWait.Done()
				for {
					select {
					case <-ctx.Done():
						return
					default:
					}
					_, _ = process.Runtime.RunOnce(ctx, workerContext, process.Invokers, "")
					timer := time.NewTimer(interval)
					select {
					case <-ctx.Done():
						timer.Stop()
						return
					case <-timer.C:
					}
				}
			}()
		}
	}
}

func (process *WorkerProcess) Start(ctx context.Context) error {
	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	if process.started {
		return fmt.Errorf("generated Worker process already started")
	}

	process.ctx, process.cancel = context.WithCancel(ctx)
	process.done = make(chan struct{})
	process.started = true
	process.running = true
	go func() {
		err := process.Run(process.ctx)
		process.RequestStop()
		process.lifecycleMu.Lock()
		process.runErr = err
		process.running = false
		close(process.done)
		process.lifecycleMu.Unlock()
	}()
	return nil
}

func (process *WorkerProcess) Join() error {
	process.lifecycleMu.Lock()
	if !process.started {
		process.lifecycleMu.Unlock()
		return fmt.Errorf("generated Worker process not started")
	}
	done := process.done
	process.lifecycleMu.Unlock()

	<-done

	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	return process.runErr
}

func (process *WorkerProcess) Running() bool {
	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	return process.running
}

func (process *WorkerProcess) RequestStop() {
	process.lifecycleMu.Lock()
	cancel := process.cancel
	process.lifecycleMu.Unlock()
	if cancel != nil {
		cancel()
	}
	process.Runtime.RequestStop()
}
