package backend

import (
	"context"
	"fmt"
	"sync"
	"time"

	common "statespec-generated/common/backend"
)

type WorkflowRunner struct {
	Backend       common.Backend
	WorkflowStore common.WorkflowStore
	Invokers      WorkflowStepInvokerMap
	WorkerName    string
	LeaseDuration time.Duration
	MaxAttempts   uint32
}

func (runner WorkflowRunner) RunOnce(ctx context.Context, workflowExecutionID string, workflowName string, workflowVersion int64) (*common.WorkflowExecutionRecord, error) {
	claimed, err := runner.WorkflowStore.ClaimSteps(ctx, runner.Backend, common.ClaimWorkflowStepRequest{
		WorkflowExecutionID: workflowExecutionID,
		WorkflowName:        workflowName,
		WorkflowVersion:     workflowVersion,
		Worker:              runner.WorkerName,
		Now:                 time.Now(),
		LeaseDuration:       runner.LeaseDuration,
		MaxSteps:            1,
	})
	if err != nil || len(claimed) == 0 {
		return nil, err
	}
	record := claimed[0]
	keepAlive := newPeriodicWorkflowKeepAlive(ctx, runner.Backend, runner.WorkflowStore, runner.WorkerName, record, runner.LeaseDuration, workflowKeepAliveInterval(runner.LeaseDuration))
	keepAlive.Start()
	tx, err := runner.Backend.Begin(ctx)
	if err != nil {
		keepAlive.Stop()
		return nil, err
	}
	committed := false
	defer func() {
		keepAlive.Stop()
		if !committed && tx.IsOpen() {
			_ = tx.Abort(ctx)
		}
	}()
	current, err := runner.revalidateClaimedStep(ctx, tx, record)
	if err != nil {
		return nil, err
	}
	stepContext := WorkflowStepHandlerContext{
		WorkflowName:    current.WorkflowName,
		WorkflowVersion: current.WorkflowVersion,
		StepName:        current.CurrentStep,
		ExecutionID:     &current.WorkflowExecutionID,
		Input:           current.State,
	}
	handlerErr := error(nil)
	stepKey := WorkflowStepKeyString(current.WorkflowName, int(current.WorkflowVersion), current.CurrentStep)
	invoker, handled := runner.Invokers[stepKey]
	result := WorkflowStepResult{}
	if !handled {
		result = Fail(fmt.Sprintf("unknown generated workflow step handler: %s", stepKey))
	} else {
		result, err = invoker(ctx, runner.Backend, tx, stepContext)
		handlerErr = err
		if handlerErr != nil {
			result = Fail(handlerErr.Error())
		}
	}
	keepAlive.Stop()
	if err := keepAlive.Err(); err != nil {
		return nil, fmt.Errorf("workflow keep alive failed: %w", err)
	}
	switch result.Kind {
	case WorkflowStepFail:
		failed, failErr := runner.WorkflowStore.FailStepTx(ctx, tx, common.FailWorkflowStepRequest{
			WorkflowExecutionID: current.WorkflowExecutionID,
			Worker:              runner.WorkerName,
			FailedStep:          current.CurrentStep,
			Reason:              result.Reason,
			Now:                 time.Now(),
			MaxAttempts:         runner.MaxAttempts,
			ClaimToken:          stringValue(current.ClaimToken),
		})
		if failErr != nil {
			return nil, failErr
		}
		if err := runner.Backend.Commit(ctx, tx); err != nil {
			return nil, err
		}
		committed = true
		return &failed, handlerErr
	case WorkflowStepCancel:
		canceled, cancelErr := runner.WorkflowStore.CancelTx(ctx, tx, common.CancelWorkflowRequest{
			WorkflowExecutionID: current.WorkflowExecutionID,
			Reason:              result.Reason,
		})
		if cancelErr != nil {
			return nil, cancelErr
		}
		if err := runner.Backend.Commit(ctx, tx); err != nil {
			return nil, err
		}
		committed = true
		return &canceled, nil
	default:
		completed, completeErr := runner.WorkflowStore.CompleteStepTx(ctx, tx, common.CompleteWorkflowStepRequest{
			WorkflowExecutionID: current.WorkflowExecutionID,
			Worker:              runner.WorkerName,
			CompletedStep:       current.CurrentStep,
			NextStep:            result.NextStep,
			State:               current.State,
			ClaimToken:          stringValue(current.ClaimToken),
		})
		if completeErr != nil {
			return nil, completeErr
		}
		if err := runner.Backend.Commit(ctx, tx); err != nil {
			return nil, err
		}
		committed = true
		return &completed, nil
	}
}

type periodicWorkflowKeepAlive struct {
	ctx           context.Context
	backend       common.Backend
	workflowStore common.WorkflowStore
	workerName    string
	record        common.WorkflowExecutionRecord
	leaseDuration time.Duration
	interval      time.Duration
	stop          chan struct{}
	done          chan struct{}
	stopOnce      sync.Once
	mu            sync.Mutex
	err           error
}

func newPeriodicWorkflowKeepAlive(ctx context.Context, backend common.Backend, workflowStore common.WorkflowStore, workerName string, record common.WorkflowExecutionRecord, leaseDuration time.Duration, interval time.Duration) *periodicWorkflowKeepAlive {
	return &periodicWorkflowKeepAlive{
		ctx:           ctx,
		backend:       backend,
		workflowStore: workflowStore,
		workerName:    workerName,
		record:        record,
		leaseDuration: leaseDuration,
		interval:      interval,
		stop:          make(chan struct{}),
		done:          make(chan struct{}),
	}
}

func (keepAlive *periodicWorkflowKeepAlive) Start() {
	keepAlive.keepAliveOnce()
	go keepAlive.run()
}

func (keepAlive *periodicWorkflowKeepAlive) Stop() {
	keepAlive.stopOnce.Do(func() {
		close(keepAlive.stop)
		<-keepAlive.done
	})
}

func (keepAlive *periodicWorkflowKeepAlive) Err() error {
	keepAlive.mu.Lock()
	defer keepAlive.mu.Unlock()
	return keepAlive.err
}

func (keepAlive *periodicWorkflowKeepAlive) run() {
	defer close(keepAlive.done)
	ticker := time.NewTicker(keepAlive.interval)
	defer ticker.Stop()
	for {
		select {
		case <-keepAlive.ctx.Done():
			keepAlive.recordError(keepAlive.ctx.Err())
			return
		case <-keepAlive.stop:
			return
		case <-ticker.C:
			keepAlive.keepAliveOnce()
		}
	}
}

func (keepAlive *periodicWorkflowKeepAlive) keepAliveOnce() {
	if _, err := keepAlive.workflowStore.KeepAliveStep(keepAlive.ctx, keepAlive.backend, common.KeepAliveWorkflowStepRequest{
		WorkflowExecutionID: keepAlive.record.WorkflowExecutionID,
		Worker:              keepAlive.workerName,
		CurrentStep:         keepAlive.record.CurrentStep,
		ClaimToken:          stringValue(keepAlive.record.ClaimToken),
		Now:                 time.Now(),
		LeaseDuration:       keepAlive.leaseDuration,
	}); err != nil {
		keepAlive.recordError(err)
	}
}

func (keepAlive *periodicWorkflowKeepAlive) recordError(err error) {
	if err == nil {
		return
	}
	keepAlive.mu.Lock()
	defer keepAlive.mu.Unlock()
	if keepAlive.err == nil {
		keepAlive.err = err
	}
}

func workflowKeepAliveInterval(leaseDuration time.Duration) time.Duration {
	interval := leaseDuration / 3
	if interval < 250*time.Millisecond {
		interval = 250 * time.Millisecond
	}
	if leaseDuration > 250*time.Millisecond && interval >= leaseDuration {
		interval = leaseDuration / 2
	}
	return interval
}

func (runner WorkflowRunner) revalidateClaimedStep(ctx context.Context, tx common.Transaction, claimed common.WorkflowExecutionRecord) (common.WorkflowExecutionRecord, error) {
	current, err := runner.WorkflowStore.InspectTx(ctx, tx, claimed.WorkflowExecutionID)
	if err != nil {
		return common.WorkflowExecutionRecord{}, err
	}
	if current == nil {
		return common.WorkflowExecutionRecord{}, fmt.Errorf("claimed workflow execution disappeared")
	}
	if current.WorkflowName != claimed.WorkflowName || current.WorkflowVersion != claimed.WorkflowVersion || current.CurrentStep != claimed.CurrentStep {
		return common.WorkflowExecutionRecord{}, fmt.Errorf("claimed workflow execution changed before execution")
	}
	if current.ClaimedBy == nil || *current.ClaimedBy != runner.WorkerName {
		return common.WorkflowExecutionRecord{}, fmt.Errorf("claimed workflow execution is no longer owned by worker")
	}
	if current.ClaimToken == nil || claimed.ClaimToken == nil || *current.ClaimToken != *claimed.ClaimToken {
		return common.WorkflowExecutionRecord{}, fmt.Errorf("claimed workflow execution token changed before execution")
	}
	if current.ClaimExpiresAt == nil || !current.ClaimExpiresAt.After(time.Now()) {
		return common.WorkflowExecutionRecord{}, fmt.Errorf("claimed workflow execution lease expired before execution")
	}
	return *current, nil
}

func stringValue(value *string) string {
	if value == nil {
		return ""
	}
	return *value
}
