package backend

import (
	"context"
	"fmt"
	"time"

	common "statespec-generated/common/backend"
)

type WorkflowRunner struct {
	Backend       common.Backend
	WorkflowStore common.WorkflowStore
	Handlers      WorkflowStepHandlerBundle
	WorkerName    string
	LeaseDuration time.Duration
	MaxAttempts   uint32
}

func (runner WorkflowRunner) RunOnce(ctx context.Context, workflowExecutionID string, workflowName string, workflowVersion int64) (*common.WorkflowExecutionRecord, error) {
	claimed, err := runner.WorkflowStore.ClaimSteps(ctx, runner.Backend, common.ClaimWorkflowStepRequest{
		WorkflowExecutionID: workflowExecutionID,
		WorkflowName:        workflowName,
		WorkflowVersion:     workflowVersion,
		Worker:              runner.WorkerName,
		Now:                 time.Now(),
		LeaseDuration:       runner.LeaseDuration,
		MaxSteps:            1,
	})
	if err != nil || len(claimed) == 0 {
		return nil, err
	}
	record := claimed[0]
	if _, err := runner.WorkflowStore.KeepAliveStep(ctx, runner.Backend, common.KeepAliveWorkflowStepRequest{
		WorkflowExecutionID: record.WorkflowExecutionID,
		Worker:              runner.WorkerName,
		CurrentStep:         record.CurrentStep,
		Now:                 time.Now(),
		LeaseDuration:       runner.LeaseDuration,
	}); err != nil {
		return nil, err
	}
	stepContext := WorkflowStepHandlerContext{
		WorkflowName:    record.WorkflowName,
		WorkflowVersion: record.WorkflowVersion,
		StepName:        record.CurrentStep,
		ExecutionID:     &record.WorkflowExecutionID,
		Input:           record.State,
	}
	handlerErr := error(nil)
	stepKey := WorkflowStepKeyString(record.WorkflowName, int(record.WorkflowVersion), record.CurrentStep)
	invoker, handled := WorkflowStepInvokers()[stepKey]
	if !handled {
		handlerErr = fmt.Errorf("unknown generated workflow step handler: %s", stepKey)
	} else {
		result, err := invoker(ctx, runner.Handlers, runner.Backend, stepContext)
		handlerErr = err
		if handlerErr == nil {
			switch result.Kind {
			case WorkflowStepFail:
				failed, failErr := runner.WorkflowStore.FailStep(ctx, runner.Backend, common.FailWorkflowStepRequest{
					WorkflowExecutionID: record.WorkflowExecutionID,
					Worker:              runner.WorkerName,
					FailedStep:          record.CurrentStep,
					Reason:              result.Reason,
					Now:                 time.Now(),
					MaxAttempts:         runner.MaxAttempts,
				})
				if failErr != nil {
					return nil, failErr
				}
				return &failed, nil
			case WorkflowStepCancel:
				canceled, cancelErr := runner.WorkflowStore.Cancel(ctx, runner.Backend, common.CancelWorkflowRequest{
					WorkflowExecutionID: record.WorkflowExecutionID,
					Reason:              result.Reason,
				})
				if cancelErr != nil {
					return nil, cancelErr
				}
				return &canceled, nil
			default:
				completed, completeErr := runner.WorkflowStore.CompleteStep(ctx, runner.Backend, common.CompleteWorkflowStepRequest{
					WorkflowExecutionID: record.WorkflowExecutionID,
					Worker:              runner.WorkerName,
					CompletedStep:       record.CurrentStep,
					NextStep:            result.NextStep,
					State:               record.State,
				})
				if completeErr != nil {
					return nil, completeErr
				}
				return &completed, nil
			}
		}
	}
	if handlerErr != nil {
		failed, failErr := runner.WorkflowStore.FailStep(ctx, runner.Backend, common.FailWorkflowStepRequest{
			WorkflowExecutionID: record.WorkflowExecutionID,
			Worker:              runner.WorkerName,
			FailedStep:          record.CurrentStep,
			Reason:              handlerErr.Error(),
			Now:                 time.Now(),
			MaxAttempts:         runner.MaxAttempts,
		})
		if failErr != nil {
			return nil, failErr
		}
		return &failed, handlerErr
	}
	return nil, nil
}
