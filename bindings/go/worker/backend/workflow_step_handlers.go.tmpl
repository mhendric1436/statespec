package backend

import (
	"context"
	"strconv"

	common "statespec-generated/common/backend"
	workflowmodules "statespec-generated/worker/backend/workflows"
)

type WorkflowStepKey struct {
	WorkflowName    string
	WorkflowVersion int
	StepName        string
}

func (key WorkflowStepKey) Encode() string {
	return WorkflowStepKeyString(key.WorkflowName, key.WorkflowVersion, key.StepName)
}

func WorkflowStepKeyString(workflowName string, workflowVersion int, stepName string) string {
	return workflowName + ":" + strconv.Itoa(workflowVersion) + ":" + stepName
}

type WorkflowStepHandlerContext = workflowmodules.WorkflowStepHandlerContext
type WorkflowStepResultKind = workflowmodules.WorkflowStepResultKind
type WorkflowStepResult = workflowmodules.WorkflowStepResult

const (
	WorkflowStepComplete = workflowmodules.WorkflowStepComplete
	WorkflowStepFail     = workflowmodules.WorkflowStepFail
	WorkflowStepCancel   = workflowmodules.WorkflowStepCancel
)

func Complete(nextStep *string) WorkflowStepResult {
	return workflowmodules.Complete(nextStep)
}

func Fail(reason string) WorkflowStepResult {
	return workflowmodules.Fail(reason)
}

func Cancel(reason string) WorkflowStepResult {
	return workflowmodules.Cancel(reason)
}

type WorkflowStepInvoker func(context.Context, common.Backend, common.Transaction, WorkflowStepHandlerContext) (WorkflowStepResult, error)

type WorkflowStepInvokerMap map[string]WorkflowStepInvoker
