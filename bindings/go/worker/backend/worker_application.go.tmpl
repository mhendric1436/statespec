package backend

import (
	"context"

	common "statespec-generated/common/backend"
)

type WorkerTierApplication struct {
	Context common.WorkerContext
	Runtime *WorkerTierRuntime
	Handler WorkflowStepHandler
}

func (app WorkerTierApplication) RunOnce(ctx context.Context, workflowExecutionID string) (*common.WorkflowExecutionRecord, error) {
	return app.Runtime.RunOnce(ctx, app.Context, app.Handler, workflowExecutionID)
}
