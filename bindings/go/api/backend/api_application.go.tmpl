func NewAPITierApplication(backend common.Backend, serverName string, handler APITierHandler) (*APITierApplication, bool) {
	descriptor, ok := FindAPITierServer(serverName)
	if !ok {
		return nil, false
	}
	return &APITierApplication{
		Backend:      backend,
{{runtime_store_initializers}}
		Server: APITierServer{
			Descriptor: descriptor,
			Handler:    handler,
		},
	}, true
}

func NewDefaultAPITierApplication(backend common.Backend, serverName string) (*APITierApplication, bool) {
	return NewAPITierApplication(backend, serverName, DefaultAPITierHandler{Backend: backend})
}

