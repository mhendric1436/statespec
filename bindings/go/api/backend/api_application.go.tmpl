package backend

import (
	"context"

	common "statespec-generated/common/backend"
	runtime "statespec-generated/common/backend/runtime"
)

type APITierApplication struct {
	Backend      common.Backend
	FeatureFlags *runtime.FeatureFlagStore
	Leases       *runtime.LeaseStore
	Logs         *runtime.LogSink
	Metrics      *runtime.MetricSink
	Queues       *runtime.QueueStore
	Workflows    *runtime.WorkflowStore
	Server       APITierServer
}

func NewAPITierApplication(backend common.Backend, serverName string, handler APITierHandler) (*APITierApplication, bool) {
	descriptor, ok := FindAPITierServer(serverName)
	if !ok {
		return nil, false
	}
	return &APITierApplication{
		Backend:      backend,
		FeatureFlags: runtime.NewFeatureFlagStore(),
		Leases:       runtime.NewLeaseStore(),
		Logs:         runtime.NewLogSink(),
		Metrics:      runtime.NewMetricSink(),
		Queues:       runtime.NewQueueStore(),
		Workflows:    runtime.NewWorkflowStore(),
		Server: APITierServer{
			Descriptor: descriptor,
			Handler:    handler,
		},
	}, true
}

func NewDefaultAPITierApplication(backend common.Backend, serverName string) (*APITierApplication, bool) {
	return NewAPITierApplication(backend, serverName, DefaultAPITierHandler{})
}

func (app *APITierApplication) Bootstrap(ctx context.Context) error {
	return common.BootstrapRuntimeCatalog(ctx, app.Backend, app.FeatureFlags, app.Queues, app.Leases, app.Workflows, app.Logs, app.Metrics)
}

var _ = common.APIResponse{}
