package backend

import (
	"context"
	"fmt"
	"sync"
	"time"

	common "statespec-generated/common/backend"
)

type EntityGCWorkerFunc func(ctx context.Context, now string) error

type APIProcessConfig struct {
	ServerNames       []string
	BootstrapOnStart  bool
	EntityGCEnabled   bool
	ShutdownTimeoutMS int
	EntityGCPollInterval time.Duration
}

func DefaultAPIProcessConfig() APIProcessConfig {
	config := APIProcessConfig{
		BootstrapOnStart:  true,
		EntityGCEnabled:   true,
		ShutdownTimeoutMS: 30000,
		EntityGCPollInterval: time.Minute,
	}
	for _, descriptor := range APITierServerDescriptors() {
		config.ServerNames = append(config.ServerNames, descriptor.Name)
	}
	return config
}

type APIProcess struct {
	Config       APIProcessConfig
	Backend      common.Backend
	Handler      DefaultAPITierHandler
	Transport    APITierTransport
	Applications []*APITierApplication
	EntityGCWorkers []EntityGCWorkerFunc

	bootstrapMu  sync.Mutex
	bootstrapped bool
	lifecycleMu  sync.Mutex
	ctx          context.Context
	cancel       context.CancelFunc
	done         chan struct{}
	runErr       error
	started      bool
	running      bool
	gcWait       sync.WaitGroup
}

func NewAPIProcess(config APIProcessConfig, backend common.Backend, handler DefaultAPITierHandler, transport APITierTransport) (*APIProcess, error) {
	if len(config.ServerNames) == 0 {
		for _, descriptor := range APITierServerDescriptors() {
			config.ServerNames = append(config.ServerNames, descriptor.Name)
		}
	}
	if transport == nil {
		transport = NewLocalBlockingAPITierTransport()
	}

	process := &APIProcess{
		Config:    config,
		Backend:   backend,
		Handler:   handler,
		Transport: transport,
	}
	for _, serverName := range config.ServerNames {
		application, ok := NewAPITierApplication(backend, serverName, handler)
		if !ok {
			return nil, fmt.Errorf("unknown generated API server %q", serverName)
		}
		process.Applications = append(process.Applications, application)
	}
	return process, nil
}

func (process *APIProcess) AddEntityGCWorker(worker EntityGCWorkerFunc) error {
	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	if process.started {
		return fmt.Errorf("cannot add entity GC worker after generated API process start")
	}
	process.EntityGCWorkers = append(process.EntityGCWorkers, worker)
	return nil
}

func NewDefaultAPIProcess(backend common.Backend) (*APIProcess, error) {
	return NewAPIProcess(
		DefaultAPIProcessConfig(), backend, DefaultAPITierHandler{Backend: backend},
		NewLocalBlockingAPITierTransport(),
	)
}

func (process *APIProcess) Bootstrap(ctx context.Context) error {
	process.bootstrapMu.Lock()
	defer process.bootstrapMu.Unlock()
	if process.bootstrapped {
		return nil
	}
	for _, application := range process.Applications {
		if err := application.Bootstrap(ctx); err != nil {
			return err
		}
	}
	process.bootstrapped = true
	return nil
}

func (process *APIProcess) Run(ctx context.Context) error {
	if process.Config.BootstrapOnStart {
		if err := process.Bootstrap(ctx); err != nil {
			return err
		}
	}

	return process.Transport.Run(ctx)
}

func (process *APIProcess) Start(ctx context.Context) error {
	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	if process.started {
		return fmt.Errorf("generated API process already started")
	}

	process.ctx, process.cancel = context.WithCancel(ctx)
	process.done = make(chan struct{})
	process.started = true
	process.running = true
	process.startEntityGCWorkersLocked()
	go func() {
		err := process.Run(process.ctx)
		process.RequestStop()
		process.lifecycleMu.Lock()
		process.runErr = err
		process.running = false
		close(process.done)
		process.lifecycleMu.Unlock()
	}()
	return nil
}

func (process *APIProcess) startEntityGCWorkersLocked() {
	if !process.Config.EntityGCEnabled {
		return
	}
	interval := process.Config.EntityGCPollInterval
	if interval <= 0 {
		interval = time.Minute
	}
	for _, worker := range process.EntityGCWorkers {
		process.gcWait.Add(1)
		go func(worker EntityGCWorkerFunc) {
			defer process.gcWait.Done()
			ticker := time.NewTicker(interval)
			defer ticker.Stop()
			for {
				now := time.Now().UTC().Format(time.RFC3339)
				_ = worker(process.ctx, now)
				select {
				case <-process.ctx.Done():
					return
				case <-ticker.C:
				}
			}
		}(worker)
	}
}

func (process *APIProcess) Join() error {
	process.lifecycleMu.Lock()
	if !process.started {
		process.lifecycleMu.Unlock()
		return fmt.Errorf("generated API process not started")
	}
	done := process.done
	process.lifecycleMu.Unlock()

	<-done
	process.gcWait.Wait()

	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	return process.runErr
}

func (process *APIProcess) Running() bool {
	process.lifecycleMu.Lock()
	defer process.lifecycleMu.Unlock()
	return process.running
}

func (process *APIProcess) RequestStop() {
	process.lifecycleMu.Lock()
	cancel := process.cancel
	process.lifecycleMu.Unlock()
	if cancel != nil {
		cancel()
	}
	process.Transport.RequestStop()
}
