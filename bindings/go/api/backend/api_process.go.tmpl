package backend

import (
	"context"
	"fmt"
	"sync"

	common "statespec-generated/common/backend"
)

type APIProcessConfig struct {
	ServerNames       []string
	BootstrapOnStart  bool
	ShutdownTimeoutMS int
}

func DefaultAPIProcessConfig() APIProcessConfig {
	config := APIProcessConfig{
		BootstrapOnStart:  true,
		ShutdownTimeoutMS: 30000,
	}
	for _, descriptor := range APITierServerDescriptors() {
		config.ServerNames = append(config.ServerNames, descriptor.Name)
	}
	return config
}

type APIProcess struct {
	Config       APIProcessConfig
	Backend      common.Backend
	Handler      APITierHandler
	Transport    APITierTransport
	Applications []*APITierApplication

	bootstrapMu  sync.Mutex
	bootstrapped bool
}

func NewAPIProcess(config APIProcessConfig, backend common.Backend, handler APITierHandler, transport APITierTransport) (*APIProcess, error) {
	if len(config.ServerNames) == 0 {
		for _, descriptor := range APITierServerDescriptors() {
			config.ServerNames = append(config.ServerNames, descriptor.Name)
		}
	}
	if transport == nil {
		transport = NewLocalBlockingAPITierTransport()
	}

	process := &APIProcess{
		Config:    config,
		Backend:   backend,
		Handler:   handler,
		Transport: transport,
	}
	for _, serverName := range config.ServerNames {
		application, ok := NewAPITierApplication(backend, serverName, handler)
		if !ok {
			return nil, fmt.Errorf("unknown generated API server %q", serverName)
		}
		process.Applications = append(process.Applications, application)
	}
	return process, nil
}

func NewDefaultAPIProcess(backend common.Backend) (*APIProcess, error) {
	return NewAPIProcess(
		DefaultAPIProcessConfig(), backend, DefaultAPITierHandler{Backend: backend},
		NewLocalBlockingAPITierTransport(),
	)
}

func (process *APIProcess) Bootstrap(ctx context.Context) error {
	process.bootstrapMu.Lock()
	defer process.bootstrapMu.Unlock()
	if process.bootstrapped {
		return nil
	}
	for _, application := range process.Applications {
		if err := application.Bootstrap(ctx); err != nil {
			return err
		}
	}
	process.bootstrapped = true
	return nil
}

func (process *APIProcess) Run(ctx context.Context) error {
	if process.Config.BootstrapOnStart {
		if err := process.Bootstrap(ctx); err != nil {
			return err
		}
	}

	return process.Transport.Run(ctx)
}

func (process *APIProcess) RequestStop() {
	process.Transport.RequestStop()
}
