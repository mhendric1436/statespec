package backend

import (
	"context"

	descriptortypes "statespec-generated/common/backend/descriptortypes"
)

type APITierServer struct {
	Descriptor descriptortypes.ApiServerDescriptor
	Handler    APITierHandler
}

func FindAPITierServer(serverName string) (descriptortypes.ApiServerDescriptor, bool) {
	for _, server := range APITierServerDescriptors() {
		if server.Name == serverName {
			return server, true
		}
	}
	return descriptortypes.ApiServerDescriptor{}, false
}

func (server APITierServer) Handle(ctx context.Context, routeName string, request descriptortypes.APIRequestContext) (descriptortypes.APIResponse, bool, error) {
	route, ok := FindAPITierRoute(routeName)
	if !ok || route.ServerName != server.Descriptor.Name {
		return descriptortypes.APIResponse{}, false, nil
	}
	return DispatchAPITierRoute(ctx, server.Handler, routeName, request)
}
