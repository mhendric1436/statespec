package backend

import (
	"context"
	"sync"

	descriptortypes "statespec-generated/common/backend/descriptortypes"
)

type APITierTransport interface {
	Handle(ctx context.Context, server APITierServer, routeName string, request descriptortypes.APIRequestContext) (descriptortypes.APIResponse, bool, error)
	Run(ctx context.Context) error
	RequestStop()
}

type LocalBlockingAPITierTransport struct {
	stopOnce sync.Once
	stopCh   chan struct{}
}

func NewLocalBlockingAPITierTransport() *LocalBlockingAPITierTransport {
	return &LocalBlockingAPITierTransport{
		stopCh: make(chan struct{}),
	}
}

func (transport *LocalBlockingAPITierTransport) Handle(ctx context.Context, server APITierServer, routeName string, request descriptortypes.APIRequestContext) (descriptortypes.APIResponse, bool, error) {
	return server.Handle(ctx, routeName, request)
}

func (transport *LocalBlockingAPITierTransport) Run(ctx context.Context) error {
	select {
	case <-transport.stopCh:
		return nil
	default:
	}

	select {
	case <-transport.stopCh:
		return nil
	case <-ctx.Done():
		select {
		case <-transport.stopCh:
			return nil
		default:
			return ctx.Err()
		}
	}
}

func (transport *LocalBlockingAPITierTransport) RequestStop() {
	transport.stopOnce.Do(func() {
		close(transport.stopCh)
	})
}
