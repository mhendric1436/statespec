package main

import (
	"context"
	"errors"
	"fmt"
	"os"
	"os/signal"
	api "statespec-generated/api/backend"
	"statespec-generated/common/backend/memory"
{{api_main_entity_gc_import}}	"syscall"
)

func main() {
	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	backend := memory.NewBackend()
	handler := api.DefaultAPITierHandler{Backend: backend}
	transport := api.NewLocalBlockingAPITierTransport()
	config := api.DefaultAPIProcessConfig()
	process, err := api.NewAPIProcess(config, backend, handler, transport)
	if err != nil {
		fmt.Fprintf(os.Stderr, "statespec generated API process failed: %v\n", err)
		os.Exit(1)
	}

{{api_main_entity_gc_registration}}	if err := process.Start(ctx); err != nil {
		fmt.Fprintf(os.Stderr, "statespec generated API process failed: %v\n", err)
		os.Exit(1)
	}

	<-ctx.Done()
	process.RequestStop()
	if err := process.Join(); err != nil && !errors.Is(err, context.Canceled) {
		fmt.Fprintf(os.Stderr, "statespec generated API process failed: %v\n", err)
		os.Exit(1)
	}
}
