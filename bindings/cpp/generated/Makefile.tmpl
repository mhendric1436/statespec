CXX ?= clang++
CXXFLAGS ?= -std=c++20 -Wall -Wextra -Wpedantic -I. -Icommon
BUILD_DIR ?= build

DIST_DIR ?= dist

CHECK_TARGETS := check-common
BUILD_TARGETS := build-common
PACKAGE_TARGETS := package-common{{target_additions}}

.PHONY: all help check build package check-common build-common package-common{{phony_targets}} clean

all: check

help:
	@printf '%s\n' 'StateSpec generated C++ bindings Makefile'
	@printf '%s\n' ''
	@printf '%s\n' 'Default target: all -> check'
	@printf '%s\n' '  check   Compiles generated headers and compile-check surfaces only.'
	@printf '%s\n' '  build   Builds generated runnable entrypoints when present.'
	@printf '%s\n' '  package Builds and archives generated artifacts under $(DIST_DIR).'
	@printf '%s\n' '  clean   Removes $(BUILD_DIR) and $(DIST_DIR).'
	@printf '%s\n' ''
	@printf '%s\n' 'Tier targets:'
	@printf '%s\n' '  check-common  build-common  package-common'
{{help_target_additions}}

check: $(CHECK_TARGETS)

build: $(BUILD_TARGETS)

package: $(PACKAGE_TARGETS)

$(BUILD_DIR)/.dir:
	mkdir -p $(BUILD_DIR)
	touch $(BUILD_DIR)/.dir

$(DIST_DIR):
	mkdir -p $(DIST_DIR)

check-common: $(BUILD_DIR)/.dir
	printf '#include "common/descriptors.hpp"\n#include "common/memory/backend.hpp"\n{{common_runtime_includes}}int main() { return 0; }\n' | $(CXX) $(CXXFLAGS) -x c++ - -o $(BUILD_DIR)/check-common

build-common: check-common

package-common: build-common $(DIST_DIR)
	tar -czf $(DIST_DIR)/statespec-generated-common-cpp.tgz common Makefile

{{api_rules}}{{worker_rules}}clean:
	rm -rf $(BUILD_DIR) $(DIST_DIR)
