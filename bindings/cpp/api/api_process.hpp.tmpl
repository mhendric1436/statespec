#pragma once

#include "api_application.hpp"
#include "api_transport.hpp"

#include <atomic>
#include <chrono>
#include <condition_variable>
#include <functional>
#include <memory>
#include <mutex>
#include <optional>
#include <stdexcept>
#include <string>
#include <string_view>
#include <thread>
#include <utility>
#include <vector>

namespace statespec_generated::api
{

struct ApiProcessConfig
{
    std::vector<std::string> server_names;
    bool bootstrap_on_start = true;
    bool entity_gc_enabled = true;
    int shutdown_timeout_ms = 30000;
    int entity_gc_poll_interval_ms = 60000;

    static ApiProcessConfig all_servers()
    {
        ApiProcessConfig config;
        for (const auto& descriptor : api_server_descriptors())
        {
            config.server_names.push_back(descriptor.name);
        }
        return config;
    }
};

class ApiProcess
{
  public:
    using EntityGcWorkerTask = std::function<void(const std::string& now)>;

    ApiProcess(
        ApiProcessConfig config,
        IApiOperationHandler& handler,
        statespec::backend::IBackend& backend,
        IApiTransport& transport
    )
        : config_(std::move(config)),
          handler_(handler),
          backend_(backend),
          transport_(transport)
    {
        if (config_.server_names.empty())
        {
            for (const auto& descriptor : api_server_descriptors())
            {
                config_.server_names.push_back(descriptor.name);
            }
        }
        for (const auto& server_name : config_.server_names)
        {
            applications_.push_back(
                std::make_unique<ApiApplication>(server_name, handler_, backend_)
            );
        }
    }

    ApiProcess(
        IApiOperationHandler& handler,
        statespec::backend::IBackend& backend,
        IApiTransport& transport
    )
        : ApiProcess(
              ApiProcessConfig::all_servers(),
              handler,
              backend,
              transport
          )
    {
    }

    ~ApiProcess()
    {
        request_stop();
        if (worker_.joinable() && worker_.get_id() != std::this_thread::get_id())
        {
            worker_.join();
        }
    }

    ApiProcess(const ApiProcess&) = delete;
    ApiProcess& operator=(const ApiProcess&) = delete;
    ApiProcess(ApiProcess&&) = delete;
    ApiProcess& operator=(ApiProcess&&) = delete;

    const ApiProcessConfig& config() const
    {
        return config_;
    }

    std::vector<ApiApplication*> applications()
    {
        std::vector<ApiApplication*> result;
        result.reserve(applications_.size());
        for (const auto& application : applications_)
        {
            result.push_back(application.get());
        }
        return result;
    }

    void add_entity_gc_worker(EntityGcWorkerTask task)
    {
        std::lock_guard<std::mutex> lifecycle_lock(lifecycle_mutex_);
        if (started_)
        {
            throw std::runtime_error("cannot add entity GC worker after API process start");
        }
        entity_gc_tasks_.push_back(std::move(task));
    }

    void bootstrap()
    {
        std::lock_guard<std::mutex> lock(bootstrap_mutex_);
        if (bootstrapped_)
        {
            return;
        }
        for (const auto& application : applications_)
        {
            application->bootstrap();
        }
        bootstrapped_ = true;
    }

    int start()
    {
        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        if (started_)
        {
            return 1;
        }

        started_ = true;
        running_ = true;
        status_.reset();
        start_entity_gc_workers();
        worker_ = std::thread(
            [this]
            {
                int status = 1;
                try
                {
                    status = run();
                }
                catch (...)
                {
                    status = 1;
                }
                stop_entity_gc_workers();
                join_entity_gc_workers();

                std::lock_guard<std::mutex> status_lock(lifecycle_mutex_);
                status_ = status;
                running_ = false;
            }
        );
        return 0;
    }

    int join()
    {
        {
            std::lock_guard<std::mutex> lock(lifecycle_mutex_);
            if (!started_)
            {
                return 1;
            }
        }

        if (worker_.joinable())
        {
            worker_.join();
        }
        join_entity_gc_workers();

        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        return status_.value_or(1);
    }

    bool running() const
    {
        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        return running_;
    }

    void request_stop()
    {
        stop_entity_gc_workers();
        transport_.request_stop();
    }

  private:
    static std::string current_time_string()
    {
        const auto now = std::chrono::system_clock::now().time_since_epoch();
        const auto seconds = std::chrono::duration_cast<std::chrono::seconds>(now).count();
        return std::to_string(seconds);
    }

    void start_entity_gc_workers()
    {
        if (!config_.entity_gc_enabled)
        {
            return;
        }
        std::lock_guard<std::mutex> lock(entity_gc_mutex_);
        entity_gc_stop_requested_ = false;
        for (const auto& task : entity_gc_tasks_)
        {
            entity_gc_threads_.emplace_back(
                [this, task]
                {
                    while (!entity_gc_stop_requested_.load())
                    {
                        try
                        {
                            task(current_time_string());
                        }
                        catch (...)
                        {
                        }
                        std::unique_lock<std::mutex> lock(entity_gc_mutex_);
                        entity_gc_cv_.wait_for(
                            lock, std::chrono::milliseconds(config_.entity_gc_poll_interval_ms),
                            [this] { return entity_gc_stop_requested_.load(); }
                        );
                    }
                }
            );
        }
    }

    void stop_entity_gc_workers()
    {
        entity_gc_stop_requested_ = true;
        entity_gc_cv_.notify_all();
    }

    void join_entity_gc_workers()
    {
        std::vector<std::thread> threads;
        {
            std::lock_guard<std::mutex> lock(entity_gc_mutex_);
            threads.swap(entity_gc_threads_);
        }
        for (auto& thread : threads)
        {
            if (thread.joinable() && thread.get_id() != std::this_thread::get_id())
            {
                thread.join();
            }
        }
    }

    int run()
    {
        if (config_.bootstrap_on_start)
        {
            bootstrap();
        }
        return transport_.run();
    }

    ApiProcessConfig config_;
    IApiOperationHandler& handler_;
    statespec::backend::IBackend& backend_;
    IApiTransport& transport_;
    std::vector<std::unique_ptr<ApiApplication>> applications_;
    std::vector<EntityGcWorkerTask> entity_gc_tasks_;
    mutable std::mutex lifecycle_mutex_;
    std::mutex bootstrap_mutex_;
    std::mutex entity_gc_mutex_;
    std::condition_variable entity_gc_cv_;
    std::thread worker_;
    std::vector<std::thread> entity_gc_threads_;
    std::optional<int> status_;
    std::atomic_bool entity_gc_stop_requested_ = false;
    bool started_ = false;
    bool running_ = false;
    bool bootstrapped_ = false;
};

} // namespace statespec_generated::api
