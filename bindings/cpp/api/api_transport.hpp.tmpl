#pragma once

#include "api_server.hpp"

#include <condition_variable>
#include <mutex>
#include <optional>
#include <string_view>

namespace statespec_generated::api
{

class IApiTransport
{
  public:
    virtual ~IApiTransport() = default;

    virtual std::optional<ApiResponse> handle(
        ApiServer& server,
        std::string_view route_name,
        const ApiRequestContext& context
    ) = 0;

    virtual int run() = 0;

    virtual void request_stop() = 0;
};

class LocalBlockingApiTransport final : public IApiTransport
{
  public:
    std::optional<ApiResponse> handle(
        ApiServer& server,
        std::string_view route_name,
        const ApiRequestContext& context
    ) override
    {
        return server.handle(route_name, context);
    }

    int run() override
    {
        std::unique_lock<std::mutex> lock(mutex_);
        stop_requested_.wait(lock, [&] { return stopping_; });
        return 0;
    }

    void request_stop() override
    {
        {
            std::lock_guard<std::mutex> lock(mutex_);
            stopping_ = true;
        }
        stop_requested_.notify_all();
    }

  private:
    std::mutex mutex_;
    std::condition_variable stop_requested_;
    bool stopping_ = false;
};

} // namespace statespec_generated::api
