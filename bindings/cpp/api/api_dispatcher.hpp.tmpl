inline const std::unordered_map<
    std::string,
    ApiRouteDescriptor>&
api_route_descriptor_map()
{
    static const auto routes = []
    {
        std::unordered_map<std::string, ApiRouteDescriptor> map;
        for (const auto& route : api_route_descriptors())
        {
            map.emplace(route.name, route);
        }
        return map;
    }();
    return routes;
}

inline const std::unordered_map<
    std::string_view,
    ApiHandlerInvoker>&
api_handler_lookup_map()
{
    static const ApiHandlerLookupMap handlers = []
    {
        ApiHandlerLookupMap map;
        // clang-format off
{{api_handler_lookup_registrations}} // clang-format on
        return map;
    }();
    return handlers;
}

inline const std::unordered_map<
    std::string_view,
    BusinessApiHandlerInvoker>&
business_api_handler_lookup_map()
{
    static const BusinessApiHandlerLookupMap handlers = []
    {
        BusinessApiHandlerLookupMap map;
        // clang-format off
{{api_business_handler_lookup_entries}} // clang-format on
        return map;
    }();
    return handlers;
}

inline std::optional<ApiRouteDescriptor> find_api_route(std::string_view route_name)
{
    const auto& routes = api_route_descriptor_map();
    const auto it = routes.find(std::string{route_name});
    if (it == routes.end())
    {
        return std::nullopt;
    }
    return it->second;
}

inline std::optional<ApiResponse> dispatch_api_route(
    statespec::backend::IBackend& backend,
    IBusinessApiOperationHandler* business_handler,
    std::string_view route_name,
    const ApiRequestContext& context
)
{
    const auto route = find_api_route(route_name);
    if (!route.has_value())
    {
        return std::nullopt;
    }
    const auto& handlers = api_handler_lookup_map();
    const auto handler_it = handlers.find(std::string_view{route->api_name});
    if (handler_it != handlers.end())
    {
        return handler_it->second(backend, context);
    }

    const auto& business_handlers = business_api_handler_lookup_map();
    const auto business_handler_it = business_handlers.find(std::string_view{route->api_name});
    if (business_handler_it == business_handlers.end())
    {
        return std::nullopt;
    }
    if (business_handler == nullptr)
    {
        return ApiResponse{501, statespec::backend::Json::object({})};
    }
    return business_handler_it->second(*business_handler, context);
}

} // namespace statespec_generated::api
