#include "../common/memory/backend.hpp"
// clang-format off
{{api_main_entity_gc_include}} // clang-format on
#include "api_handler_registry.hpp"
#include "api_process.hpp"
#include "api_transport.hpp"

#include <csignal>
#include <exception>
#include <iostream>
#include <stdexcept>

namespace
{

statespec_generated::api::ApiProcess* g_api_process = nullptr;

void request_api_stop(int)
{
    if (g_api_process != nullptr)
    {
        g_api_process->request_stop();
    }
}

} // namespace

int main()
{
    try
    {
        statespec::backend::memory::InMemoryBackend backend;
        statespec_generated::api::DefaultApiHandler handler{backend};
        statespec_generated::api::LocalBlockingApiTransport transport;
        auto config = statespec_generated::api::ApiProcessConfig::all_servers();
        statespec_generated::api::ApiProcess process{config, handler, backend, transport};

        // clang-format off
{{api_main_entity_gc_registration}} // clang-format on
        g_api_process = &process;
        std::signal(SIGINT, request_api_stop);
        std::signal(SIGTERM, request_api_stop);

        const auto start_status = process.start();
        if (start_status != 0)
        {
            throw std::runtime_error("statespec generated API process already started");
        }
        const auto status = process.join();
        g_api_process = nullptr;
        return status;
    }
    catch (const std::exception& error)
    {
        std::cerr << "statespec generated API process failed: " << error.what() << '\n';
        return 1;
    }
}
