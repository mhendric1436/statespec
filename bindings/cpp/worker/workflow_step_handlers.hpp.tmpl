inline std::string workflow_step_key(
    const std::string& workflow_name,
    std::int64_t workflow_version,
    const std::string& step_name
)
{
    return workflow_name + ":" + std::to_string(workflow_version) + ":" + step_name;
}

struct WorkflowStepKey
{
    std::string workflow_name;
    std::int64_t workflow_version = 1;
    std::string step_name;

    std::string encode() const
    {
        return workflow_step_key(workflow_name, workflow_version, step_name);
    }
};

struct WorkflowStepHandlerContext
{
