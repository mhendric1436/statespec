#pragma once

#include "workflow_step_types.hpp"

#include <chrono>
#include <cstdint>
#include <exception>
#include <optional>
#include <stdexcept>
#include <string>

#include <utility>

namespace statespec_generated::worker
{

class WorkflowRunner
{
  public:
    WorkflowRunner(
        statespec::backend::IBackend& backend,
        statespec::backend::IWorkflowStore& workflow_store,
        const WorkflowStepInvokerMap& invokers,
        std::string worker_name,
        std::chrono::seconds lease_duration,
        std::uint32_t max_attempts
    )
        : backend_(backend),
          workflow_store_(workflow_store),
          invokers_(invokers),
          worker_name_(std::move(worker_name)),
          lease_duration_(lease_duration),
          max_attempts_(max_attempts)
    {
    }

    std::optional<statespec::backend::WorkflowExecutionRecord> run_once(
        const std::string& workflow_execution_id,
        const std::string& workflow_name,
        std::int64_t workflow_version
    )
    {
        const auto now = std::chrono::system_clock::now();
        auto claimed = workflow_store_.claim_steps(
            backend_, statespec::backend::ClaimWorkflowStepRequest{
                          workflow_execution_id,
                          workflow_name,
                          workflow_version,
                          worker_name_,
                          now,
                          lease_duration_,
                          1,
                      }
        );
        if (claimed.empty())
        {
            return std::nullopt;
        }
        const auto record = claimed.front();
        workflow_store_.keep_alive_step(
            backend_, statespec::backend::KeepAliveWorkflowStepRequest{
                          record.workflow_execution_id,
                          worker_name_,
                          record.current_step,
                          std::chrono::system_clock::now(),
                          lease_duration_,
                      }
        );
        auto tx = backend_.begin();
        try
        {
            const auto current = revalidate_claimed_step(*tx, record);
            WorkflowStepHandlerContext context{
                current.workflow_name, static_cast<int>(current.workflow_version),
                current.current_step,  current.workflow_execution_id,
                current.state,
            };
            const auto key = workflow_step_key(
                current.workflow_name, current.workflow_version, current.current_step
            );
            const auto invoker = invokers_.find(key);
            WorkflowStepResult result;
            if (invoker == invokers_.end())
            {
                result = WorkflowStepResult::fail("unknown generated workflow step handler: " + key);
            }
            else
            {
                try
                {
                    result = invoker->second(backend_, *tx, context);
                }
                catch (const std::exception& ex)
                {
                    result = WorkflowStepResult::fail(ex.what());
                }
            }
            if (result.kind == WorkflowStepResultKind::Fail)
            {
                auto failed = workflow_store_.fail_stepTx(
                    *tx, statespec::backend::FailWorkflowStepRequest{
                                  current.workflow_execution_id,
                                  worker_name_,
                                  current.current_step,
                                  result.reason,
                                  std::chrono::system_clock::now(),
                                  max_attempts_,
                              }
                );
                backend_.commit(*tx);
                return failed;
            }
            if (result.kind == WorkflowStepResultKind::Cancel)
            {
                auto canceled = workflow_store_.cancelTx(
                    *tx, statespec::backend::CancelWorkflowRequest{
                             current.workflow_execution_id, result.reason
                         }
                );
                backend_.commit(*tx);
                return canceled;
            }
            auto completed = workflow_store_.complete_stepTx(
                *tx, statespec::backend::CompleteWorkflowStepRequest{
                              current.workflow_execution_id,
                              worker_name_,
                              current.current_step,
                              result.next_step,
                              current.state,
                          }
            );
            backend_.commit(*tx);
            return completed;
        }
        catch (...)
        {
            if (tx->is_open())
            {
                tx->abort();
            }
            throw;
        }
    }

  private:
    statespec::backend::WorkflowExecutionRecord revalidate_claimed_step(
        statespec::backend::ITransaction& tx,
        const statespec::backend::WorkflowExecutionRecord& claimed
    )
    {
        auto current = workflow_store_.inspectTx(tx, claimed.workflow_execution_id);
        if (!current.has_value())
        {
            throw std::runtime_error("claimed workflow execution disappeared");
        }
        if (current->workflow_name != claimed.workflow_name ||
            current->workflow_version != claimed.workflow_version ||
            current->current_step != claimed.current_step)
        {
            throw std::runtime_error("claimed workflow execution changed before execution");
        }
        if (!current->claimed_by.has_value() || *current->claimed_by != worker_name_)
        {
            throw std::runtime_error("claimed workflow execution is no longer owned by worker");
        }
        const auto now = std::chrono::system_clock::now();
        if (!current->claim_expires_at.has_value() || *current->claim_expires_at <= now)
        {
            throw std::runtime_error("claimed workflow execution lease expired before execution");
        }
        return *current;
    }

    statespec::backend::IBackend& backend_;
    statespec::backend::IWorkflowStore& workflow_store_;
    const WorkflowStepInvokerMap& invokers_;
    std::string worker_name_;
    std::chrono::seconds lease_duration_;
    std::uint32_t max_attempts_;
};

} // namespace statespec_generated::worker
