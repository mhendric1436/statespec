#pragma once

#include "workflow_step_types.hpp"

#include <chrono>
#include <condition_variable>
#include <cstdint>
#include <exception>
#include <mutex>
#include <optional>
#include <stdexcept>
#include <string>
#include <thread>

#include <utility>

namespace statespec_generated::worker
{

class WorkflowRunner
{
  public:
    WorkflowRunner(
        statespec::backend::IBackend& backend,
        statespec::backend::IWorkflowStore& workflow_store,
        const WorkflowStepInvokerMap& invokers,
        std::string worker_name,
        std::chrono::seconds lease_duration,
        std::uint32_t max_attempts
    )
        : backend_(backend),
          workflow_store_(workflow_store),
          invokers_(invokers),
          worker_name_(std::move(worker_name)),
          lease_duration_(lease_duration),
          max_attempts_(max_attempts)
    {
    }

    std::optional<statespec::backend::WorkflowExecutionRecord> run_once(
        const std::string& workflow_execution_id,
        const std::string& workflow_name,
        std::int64_t workflow_version
    )
    {
        const auto now = std::chrono::system_clock::now();
        auto claimed = workflow_store_.claim_steps(
            backend_, statespec::backend::ClaimWorkflowStepRequest{
                          workflow_execution_id,
                          workflow_name,
                          workflow_version,
                          worker_name_,
                          now,
                          lease_duration_,
                          1,
                      }
        );
        if (claimed.empty())
        {
            return std::nullopt;
        }
        const auto record = claimed.front();
        PeriodicWorkflowKeepAlive keep_alive{
            backend_, workflow_store_, worker_name_,
            record,   lease_duration_, keep_alive_interval(lease_duration_),
        };
        keep_alive.start();
        auto tx = backend_.begin();
        try
        {
            const auto current = revalidate_claimed_step(*tx, record);
            WorkflowStepHandlerContext context{
                current.workflow_name, static_cast<int>(current.workflow_version),
                current.current_step,  current.workflow_execution_id,
                current.state,
            };
            const auto key = workflow_step_key(
                current.workflow_name, current.workflow_version, current.current_step
            );
            const auto invoker = invokers_.find(key);
            WorkflowStepResult result;
            if (invoker == invokers_.end())
            {
                result =
                    WorkflowStepResult::fail("unknown generated workflow step handler: " + key);
            }
            else
            {
                try
                {
                    result = invoker->second(backend_, *tx, context);
                }
                catch (const std::exception& ex)
                {
                    result = WorkflowStepResult::fail(ex.what());
                }
            }
            keep_alive.stop();
            if (const auto error = keep_alive.error(); error.has_value())
            {
                throw std::runtime_error("workflow keep alive failed: " + *error);
            }
            if (result.kind == WorkflowStepResultKind::Fail)
            {
                auto failed = workflow_store_.fail_stepTx(
                    *tx, statespec::backend::FailWorkflowStepRequest{
                             current.workflow_execution_id,
                             worker_name_,
                             current.current_step,
                             result.reason,
                             std::chrono::system_clock::now(),
                             max_attempts_,
                             current.claim_token.value_or(""),
                         }
                );
                backend_.commit(*tx);
                return failed;
            }
            if (result.kind == WorkflowStepResultKind::Cancel)
            {
                auto canceled = workflow_store_.cancelTx(
                    *tx, statespec::backend::CancelWorkflowRequest{
                             current.workflow_execution_id, result.reason
                         }
                );
                backend_.commit(*tx);
                return canceled;
            }
            auto completed = workflow_store_.complete_stepTx(
                *tx, statespec::backend::CompleteWorkflowStepRequest{
                         current.workflow_execution_id,
                         worker_name_,
                         current.current_step,
                         result.next_step,
                         current.state,
                         current.claim_token.value_or(""),
                     }
            );
            backend_.commit(*tx);
            return completed;
        }
        catch (...)
        {
            keep_alive.stop();
            if (tx->is_open())
            {
                tx->abort();
            }
            throw;
        }
    }

  private:
    class PeriodicWorkflowKeepAlive
    {
      public:
        PeriodicWorkflowKeepAlive(
            statespec::backend::IBackend& backend,
            statespec::backend::IWorkflowStore& workflow_store,
            std::string worker_name,
            statespec::backend::WorkflowExecutionRecord record,
            std::chrono::seconds lease_duration,
            std::chrono::milliseconds interval
        )
            : backend_(backend),
              workflow_store_(workflow_store),
              worker_name_(std::move(worker_name)),
              record_(std::move(record)),
              lease_duration_(lease_duration),
              interval_(interval)
        {
        }

        ~PeriodicWorkflowKeepAlive()
        {
            stop();
        }

        PeriodicWorkflowKeepAlive(const PeriodicWorkflowKeepAlive&) = delete;
        PeriodicWorkflowKeepAlive& operator=(const PeriodicWorkflowKeepAlive&) = delete;
        PeriodicWorkflowKeepAlive(PeriodicWorkflowKeepAlive&&) = delete;
        PeriodicWorkflowKeepAlive& operator=(PeriodicWorkflowKeepAlive&&) = delete;

        void start()
        {
            {
                std::lock_guard<std::mutex> lock(mutex_);
                if (started_)
                {
                    return;
                }
                started_ = true;
                stop_requested_ = false;
            }

            keep_alive_once();

            std::lock_guard<std::mutex> lock(mutex_);
            if (stop_requested_)
            {
                return;
            }
            thread_ = std::thread([this] { run(); });
        }

        void stop()
        {
            {
                std::lock_guard<std::mutex> lock(mutex_);
                stop_requested_ = true;
            }
            cv_.notify_all();
            if (thread_.joinable() && thread_.get_id() != std::this_thread::get_id())
            {
                thread_.join();
            }
        }

        std::optional<std::string> error() const
        {
            std::lock_guard<std::mutex> lock(mutex_);
            return error_;
        }

      private:
        void run()
        {
            while (true)
            {
                std::unique_lock<std::mutex> lock(mutex_);
                if (cv_.wait_for(lock, interval_, [this] { return stop_requested_; }))
                {
                    return;
                }
                lock.unlock();
                keep_alive_once();
            }
        }

        bool stop_requested() const
        {
            std::lock_guard<std::mutex> lock(mutex_);
            return stop_requested_;
        }

        void keep_alive_once()
        {
            try
            {
                workflow_store_.keep_alive_step(
                    backend_, statespec::backend::KeepAliveWorkflowStepRequest{
                                  record_.workflow_execution_id,
                                  worker_name_,
                                  record_.current_step,
                                  record_.claim_token.value_or(""),
                                  std::chrono::system_clock::now(),
                                  lease_duration_,
                              }
                );
            }
            catch (const std::exception& ex)
            {
                record_error(ex.what());
            }
            catch (...)
            {
                record_error("unknown keep alive failure");
            }
        }

        void record_error(std::string message)
        {
            std::lock_guard<std::mutex> lock(mutex_);
            if (!error_.has_value())
            {
                error_ = std::move(message);
            }
        }

        statespec::backend::IBackend& backend_;
        statespec::backend::IWorkflowStore& workflow_store_;
        std::string worker_name_;
        statespec::backend::WorkflowExecutionRecord record_;
        std::chrono::seconds lease_duration_;
        std::chrono::milliseconds interval_;
        mutable std::mutex mutex_;
        std::condition_variable cv_;
        std::thread thread_;
        std::optional<std::string> error_;
        bool started_ = false;
        bool stop_requested_ = false;
    };

    static std::chrono::milliseconds keep_alive_interval(std::chrono::seconds lease_duration)
    {
        const auto lease_ms = std::chrono::duration_cast<std::chrono::milliseconds>(lease_duration);
        auto interval = lease_ms / 3;
        if (interval < std::chrono::milliseconds{250})
        {
            interval = std::chrono::milliseconds{250};
        }
        if (lease_ms > std::chrono::milliseconds{250} && interval >= lease_ms)
        {
            interval = lease_ms / 2;
        }
        return interval;
    }

    statespec::backend::WorkflowExecutionRecord revalidate_claimed_step(
        statespec::backend::ITransaction& tx,
        const statespec::backend::WorkflowExecutionRecord& claimed
    )
    {
        auto current = workflow_store_.inspectTx(tx, claimed.workflow_execution_id);
        if (!current.has_value())
        {
            throw std::runtime_error("claimed workflow execution disappeared");
        }
        if (current->workflow_name != claimed.workflow_name ||
            current->workflow_version != claimed.workflow_version ||
            current->current_step != claimed.current_step)
        {
            throw std::runtime_error("claimed workflow execution changed before execution");
        }
        if (!current->claimed_by.has_value() || *current->claimed_by != worker_name_)
        {
            throw std::runtime_error("claimed workflow execution is no longer owned by worker");
        }
        if (!current->claim_token.has_value() || current->claim_token != claimed.claim_token)
        {
            throw std::runtime_error("claimed workflow execution token changed before execution");
        }
        const auto now = std::chrono::system_clock::now();
        if (!current->claim_expires_at.has_value() || *current->claim_expires_at <= now)
        {
            throw std::runtime_error("claimed workflow execution lease expired before execution");
        }
        return *current;
    }

    statespec::backend::IBackend& backend_;
    statespec::backend::IWorkflowStore& workflow_store_;
    const WorkflowStepInvokerMap& invokers_;
    std::string worker_name_;
    std::chrono::seconds lease_duration_;
    std::uint32_t max_attempts_;
};

} // namespace statespec_generated::worker
