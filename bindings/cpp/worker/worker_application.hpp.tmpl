#pragma once

#include "worker_registry.hpp"
#include "worker_runtime.hpp"
#include "workflow_step_handlers.hpp"

#include <utility>

namespace statespec_generated::worker
{

class WorkerApplication
{
  public:
    WorkerApplication(
        WorkerContext context,
        WorkerRuntime& runtime,
        IWorkflowStepHandler& handler
    )
        : context_(std::move(context)),
          runtime_(runtime),
          handler_(handler)
    {
    }

    const WorkerContext& context() const
    {
        return context_;
    }

    std::optional<statespec::backend::WorkflowExecutionRecord>
    run_once(const std::string& workflow_execution_id)
    {
        return runtime_.run_once(context_, handler_, workflow_execution_id);
    }

  private:
    WorkerContext context_;
    WorkerRuntime& runtime_;
    IWorkflowStepHandler& handler_;
};

} // namespace statespec_generated::worker
