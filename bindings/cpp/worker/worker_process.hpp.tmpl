#pragma once

#include "worker_contexts.hpp"
#include "worker_runtime.hpp"
#include "workflow_step_handlers.hpp"

#include <algorithm>
#include <atomic>
#include <chrono>
#include <condition_variable>
#include <mutex>
#include <optional>
#include <thread>
#include <vector>

namespace statespec_generated::worker
{

struct WorkerProcessConfig
{
    bool bootstrap_on_start = true;
    int worker_poll_interval_ms = 1000;
};

class WorkerProcess
{
  public:
    explicit WorkerProcess(
        WorkerRuntime& runtime,
        IWorkflowStepHandler& handler,
        WorkerProcessConfig config = {}
    )
        : runtime_(runtime),
          handler_(handler),
          config_(config)
    {
    }

    WorkerRuntime& runtime()
    {
        return runtime_;
    }

    const WorkerProcessConfig& config() const
    {
        return config_;
    }

    ~WorkerProcess()
    {
        request_stop();
        if (worker_.joinable() && worker_.get_id() != std::this_thread::get_id())
        {
            worker_.join();
        }
    }

    WorkerProcess(const WorkerProcess&) = delete;
    WorkerProcess& operator=(const WorkerProcess&) = delete;
    WorkerProcess(WorkerProcess&&) = delete;
    WorkerProcess& operator=(WorkerProcess&&) = delete;

    int start()
    {
        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        if (started_)
        {
            return 1;
        }

        started_ = true;
        running_ = true;
        stop_requested_ = false;
        status_.reset();
        worker_ = std::thread(
            [this]
            {
                int status = 1;
                try
                {
                    status = run();
                }
                catch (...)
                {
                    stop_requested_ = true;
                    runtime_.request_stop();
                    stop_cv_.notify_all();
                    join_worker_loops();
                    runtime_.join_entity_gc_workers();
                    status = 1;
                }

                std::lock_guard<std::mutex> status_lock(lifecycle_mutex_);
                status_ = status;
                running_ = false;
            }
        );
        return 0;
    }

    int join()
    {
        {
            std::lock_guard<std::mutex> lock(lifecycle_mutex_);
            if (!started_)
            {
                return 1;
            }
        }

        if (worker_.joinable())
        {
            worker_.join();
        }

        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        return status_.value_or(1);
    }

    bool running() const
    {
        std::lock_guard<std::mutex> lock(lifecycle_mutex_);
        return running_;
    }

    void request_stop()
    {
        stop_requested_ = true;
        runtime_.request_stop();
        stop_cv_.notify_all();
    }

  private:
    int run()
    {
        if (config_.bootstrap_on_start)
        {
            runtime_.bootstrap();
        }
        runtime_.start_entity_gc_workers();
        start_worker_loops();
        {
            std::unique_lock<std::mutex> lock(stop_mutex_);
            stop_cv_.wait(lock, [this] { return stop_requested_.load(); });
        }
        runtime_.request_stop();
        join_worker_loops();
        runtime_.join_entity_gc_workers();
        return 0;
    }

    void start_worker_loops()
    {
        const auto poll_interval =
            std::chrono::milliseconds{std::max(1, config_.worker_poll_interval_ms)};
        for (const auto& context : worker_contexts())
        {
            if (!context.executes.has_value())
            {
                continue;
            }
            const auto concurrency = std::max(1, context.concurrency);
            for (int index = 0; index < concurrency; ++index)
            {
                worker_loop_threads_.emplace_back(
                    [this, context, poll_interval]
                    {
                        while (!stop_requested_.load())
                        {
                            try
                            {
                                (void)runtime_.run_once(context, handler_, "");
                            }
                            catch (...)
                            {
                            }
                            std::unique_lock<std::mutex> lock(stop_mutex_);
                            stop_cv_.wait_for(
                                lock, poll_interval, [this] { return stop_requested_.load(); }
                            );
                        }
                    }
                );
            }
        }
    }

    void join_worker_loops()
    {
        std::vector<std::thread> threads;
        {
            std::lock_guard<std::mutex> lock(stop_mutex_);
            threads.swap(worker_loop_threads_);
        }
        for (auto& thread : threads)
        {
            if (thread.joinable() && thread.get_id() != std::this_thread::get_id())
            {
                thread.join();
            }
        }
    }

    WorkerRuntime& runtime_;
    IWorkflowStepHandler& handler_;
    WorkerProcessConfig config_;
    mutable std::mutex lifecycle_mutex_;
    std::mutex stop_mutex_;
    std::condition_variable stop_cv_;
    std::thread worker_;
    std::vector<std::thread> worker_loop_threads_;
    std::optional<int> status_;
    std::atomic_bool stop_requested_ = false;
    bool started_ = false;
    bool running_ = false;
};

} // namespace statespec_generated::worker
