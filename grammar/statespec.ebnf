(*
  StateSpec v0.1 Grammar

  Purpose:
    Canonical grammar for the StateSpec software design language.

  Scope:
    - system declarations
    - includes, imports, and namespaces
    - system-wide tenant scoping
    - values and reusable data shapes
    - feature flags
    - entities and state machines
    - entity relationships and ownership
    - APIs
    - API servers
    - workflows and workflow steps
    - queues and messages
    - leases and workers
    - policies
    - generator/runtime target declarations

  Ecosystem model:
    StateSpec defines.
    cpp, go, java, and rust bindings consume generated backend descriptors.

  Notes:
    - This grammar defines syntax only.
    - Semantic validation is handled by the StateSpec compiler.
    - Canonical declaration ordering is enforced by formatter + validator.
    - Language-specific names such as cpp, go, java, and rust are generator
      targets, not required language dependencies.
*)

(* ============================================================ *)
(* Root                                                         *)
(* ============================================================ *)

spec                    ::= file_header? include_decl* import_decl* system_decl EOF ;

file_header             ::= "statespec" version_literal ";" ;
version_literal         ::= IntegerLiteral "." IntegerLiteral ;

include_decl            ::= "include" StringLiteral ";" ;
import_decl             ::= "import" QualifiedName ("as" Identifier)? ";" ;

system_decl             ::= "system" Identifier system_block ;

system_block            ::= "{"
                              system_member*
                            "}" ;

system_member           ::= system_tenant_scope_decl
                          | system_tenant_decl
                          | namespace_decl
                          | value_decl
                          | enum_decl
                          | shape_decl
                          | external_system_decl
                          | feature_flag_decl
                          | log_decl
                          | metric_decl
                          | entity_decl
                          | event_decl
                          | queue_decl
                          | lease_decl
                          | worker_decl
                          | api_server_decl
                          | api_decl
                          | workflow_decl
                          | policy_decl
                          | annotations_block ;

system_tenant_scope_decl ::= "tenant" "scoped_by" Identifier ";"? ;
system_tenant_decl       ::= "system_tenant" "configured" ";"? ;

namespace_decl          ::= "namespace" QualifiedName "{" system_member* "}" ;


(* ============================================================ *)
(* Lexical Elements                                             *)
(* ============================================================ *)

Identifier              ::= Letter (Letter | Digit | "_")* ;
QualifiedName           ::= Identifier ("." Identifier)* ;

StringLiteral           ::= '"' StringCharacter* '"' ;
IntegerLiteral          ::= Digit+ ;
DecimalLiteral          ::= Digit+ "." Digit+ ;
BooleanLiteral          ::= "true" | "false" ;
DurationLiteral         ::= ? ISO-8601 duration string, for example PT30S or P1DT2H ? ;

Letter                  ::= "A".."Z" | "a".."z" ;
Digit                   ::= "0".."9" ;
StringCharacter         ::= ? any character except unescaped double quote ? ;

Comment                 ::= LineComment | BlockComment ;
LineComment             ::= "//" ? characters until end of line ? ;
BlockComment            ::= "/*" ? characters until closing marker ? "*/" ;
Whitespace              ::= ? spaces, tabs, newlines, carriage returns ? ;
EOF                     ::= ? end of file ? ;


(* ============================================================ *)
(* Tenancy                                                      *)
(* ============================================================ *)

(*
  StateSpec systems are tenant-scoped by design.

  tenant scoped_by identifies the field that carries tenant identity.
  system_tenant configured declares that control-plane/system resources use a
  deployment-configured tenant id supplied by runtime configuration.

  There is no tenant global override. Control-plane resources use the system tenant id.
*)


(* ============================================================ *)
(* Types                                                        *)
(* ============================================================ *)

type                    ::= scalar_type
                          | QualifiedName
                          | collection_type
                          | reference_type
                          | optional_type ;

scalar_type             ::= "string"
                          | "bool"
                          | "int"
                          | "int32"
                          | "int64"
                          | "long"
                          | "double"
                          | "decimal"
                          | "json"
                          | "timestamp"
                          | "duration"
                          | "uuid" ;

collection_type         ::= "list" "<" type ">"
                          | "set" "<" type ">"
                          | "map" "<" type "," type ">"
                          | type "[" "]" ;

reference_type          ::= "ref" "<" QualifiedName ">" ;
optional_type           ::= "optional" "<" type ">" | type "?" ;


(* ============================================================ *)
(* Literals                                                     *)
(* ============================================================ *)

literal                 ::= StringLiteral
                          | IntegerLiteral
                          | DecimalLiteral
                          | BooleanLiteral
                          | duration_value
                          | object_literal
                          | list_literal ;

duration_value          ::= DurationLiteral | StringLiteral ;

object_literal          ::= "{" object_member_list? "}" ;
object_member_list      ::= object_member ("," object_member)* ;
object_member           ::= Identifier ":" literal ;

list_literal            ::= "[" expression_list? "]" ;
expression_list         ::= expression ("," expression)* ;


(* ============================================================ *)
(* Values, Enums, and Shapes                                    *)
(* ============================================================ *)

value_decl              ::= "value" Identifier ":" type constraint_clause? ";"? ;
constraint_clause       ::= "where" expression ;

enum_decl               ::= "enum" Identifier "{"
                              enum_member* 
                            "}" ;
enum_member             ::= Identifier ("=" literal)? ";"? ;

shape_decl              ::= "shape" Identifier shape_block ;
shape_block             ::= "{"
                              field_decl*
                            "}" ;


(* ============================================================ *)
(* External Systems                                             *)
(* ============================================================ *)

external_system_decl    ::= "external_system" Identifier external_system_block ;

external_system_block   ::= "{"
                              external_system_member*
                            "}" ;

external_system_member  ::= property_assignment
                          | annotations_block ;

property_assignment     ::= Identifier ":" literal ";"? ;


(* ============================================================ *)
(* Feature Flags                                                *)
(* ============================================================ *)

feature_flag_decl       ::= "feature_flag" Identifier feature_flag_block ;

feature_flag_block      ::= "{"
                              feature_flag_member*
                            "}" ;

feature_flag_member     ::= "type" feature_flag_type ";"?
                          | "default" literal ";"?
                          | "scope" feature_flag_scope ";"?
                          | "owner" StringLiteral ";"?
                          | "description" StringLiteral ";"?
                          | "expires" StringLiteral ";"?
                          | annotations_block ;

feature_flag_type       ::= "bool"
                          | "string"
                          | "int"
                          | "decimal" ;

feature_flag_scope      ::= "system"
                          | "tenant"
                          | "user"
                          | "entity" QualifiedName ;


(* ============================================================ *)
(* Observability                                                *)
(* ============================================================ *)

log_decl                ::= "log" Identifier log_block ;

log_block               ::= "{"
                              log_member*
                            "}" ;

log_member              ::= "level" log_level ";"?
                          | "event_name" StringLiteral ";"?
                          | "fields" "{"
                              field_decl*
                            "}"
                          | annotations_block ;

log_level               ::= "debug" | "info" | "warn" | "error" ;

metric_decl             ::= "metric" Identifier metric_block ;

metric_block            ::= "{"
                              metric_member*
                            "}" ;

metric_member           ::= "kind" metric_kind ";"?
                          | "name" StringLiteral ";"?
                          | "unit" Identifier ";"?
                          | "labels" "{"
                              field_decl*
                            "}"
                          | annotations_block ;

metric_kind             ::= "counter" | "gauge" | "histogram" ;


(* ============================================================ *)
(* Entities                                                     *)
(* ============================================================ *)

entity_decl             ::= "entity" Identifier entity_block ;

entity_block            ::= "{"
                              entity_metadata_member*
                              ownership_block
                              entity_metadata_member*
                              fields_block
                              entity_metadata_member*
                              state_machine_block
                              entity_metadata_member*
                            "}" ;

entity_metadata_member  ::= key_decl
                          | version_decl
                          | relations_block
                          | children_block
                          | invariants_block
                          | indexes_block
                          | annotations_block ;

key_decl                ::= "key" key_field_list ";"? ;
key_field_list          ::= Identifier ("," Identifier)* ;

version_decl            ::= "version" type? ";"? ;

fields_block            ::= "fields" "{"
                              entity_management_fields
                              field_decl*
                            "}" ;

entity_management_fields ::= created_at_field_decl
                              updated_at_field_decl
                              status_field_decl ;

created_at_field_decl   ::= "created_at" "timestamp" field_options? constraint_clause? ";"? ;
updated_at_field_decl   ::= "updated_at" "timestamp" field_options? constraint_clause? ";"? ;
status_field_decl       ::= "status" "string" field_options? constraint_clause? ";"? ;

field_decl              ::= Identifier type field_options? constraint_clause? ";"? ;
field_options           ::= "{"
                              field_option*
                            "}" ;
field_option            ::= "required" ":" BooleanLiteral ";"?
                          | "default" ":" literal ";"?
                          | "index" ":" BooleanLiteral ";"?
                          | "unique" ":" BooleanLiteral ";"?
                          | annotations_block ;


(* ============================================================ *)
(* State Machines                                               *)
(* ============================================================ *)

(*
  Terminal-state garbage collection syntax shape:

    state Deleted {
      terminal: true
      garbage_collection {
        after: P30D
        mode: tombstone
      }
    }

  GC policy belongs to terminal states. Initial policy fields are:
    - after: duration before collection eligibility
    - mode: delete | tombstone | archive
*)

state_machine_block     ::= "state_machine" state_machine_body ;

state_machine_body      ::= "{"
                              state_machine_member*
                            "}" ;

state_machine_member    ::= state_decl
                          | initial_state_decl
                          | terminal_states_decl
                          | transition_decl
                          | annotations_block ;

state_decl              ::= "state" Identifier state_options? ";"? ;
state_options           ::= "{"
                              state_option*
                            "}" ;
state_option            ::= "terminal" ":" BooleanLiteral ";"?
                          | garbage_collection_block
                          | annotations_block ;

garbage_collection_block ::= "garbage_collection" "{"
                              garbage_collection_member*
                            "}" ;

garbage_collection_member ::= "after" ":" duration_value ";"?
                            | "mode" ":" garbage_collection_mode ";"?
                            | annotations_block ;

garbage_collection_mode ::= "delete" | "tombstone" | "archive" ;

initial_state_decl      ::= "initial" Identifier ";"? ;
terminal_states_decl    ::= "terminal" identifier_list ";"? ;

transition_decl         ::= Identifier "->" Identifier transition_options? ";"? ;
transition_options      ::= "{"
                              transition_option*
                            "}" ;
transition_option       ::= "when" ":" expression ";"?
                          | "action" ":" QualifiedName ";"?
                          | annotations_block ;


(* ============================================================ *)
(* Ownership and Relationships                                  *)
(* ============================================================ *)

ownership_block         ::= "ownership" "{"
                              ownership_member*
                            "}" ;

ownership_member        ::= "authority" ":" ownership_authority ";"?
                          | "system_of_record" ":" system_of_record ";"?
                          | "lifecycle" ":" lifecycle_mode ";"?
                          | control_block
                          | annotations_block ;

ownership_authority     ::= "system" | "external" ;
system_of_record        ::= "self" | QualifiedName ;
lifecycle_mode          ::= "authoritative" | "managed" | "observed" | "projected" ;

control_block           ::= "control" "{"
                              control_member*
                            "}" ;
control_member          ::= "create" ":" control_mode ";"?
                          | "update" ":" control_mode ";"?
                          | "delete" ":" control_mode ";"?
                          | "sync" ":" sync_mode ";"? ;
control_mode            ::= "none" | "request" | "direct" ;
sync_mode               ::= "none" | "poll" | "push" | "import" ;

relations_block         ::= "relations" "{"
                              relation_decl*
                            "}" ;

relation_decl           ::= parent_relation_decl
                          | reference_relation_decl ;

parent_relation_decl    ::= "parent" Identifier ":" parent_ref relation_options? ";"? ;
reference_relation_decl ::= "ref" Identifier ":" reference_type relation_options? ";"? ;

parent_ref              ::= reference_type | "optional" reference_type | reference_type "?" ;

relation_options        ::= "{"
                              relation_option*
                            "}" ;
relation_option         ::= "kind" ":" relation_kind ";"?
                          | "on_parent_delete" ":" parent_delete_behavior ";"?
                          | "parent_must_be_in" ":" identifier_list ";"?
                          | "unique_within_parent" ":" identifier_list ";"?
                          | annotations_block ;

relation_kind           ::= "composition" | "aggregation" | "reference" ;
parent_delete_behavior  ::= "cascade" | "block" | "detach" | "fail" ;

children_block          ::= "children" "{"
                              child_collection_decl*
                            "}" ;
child_collection_decl   ::= Identifier ":" QualifiedName "by" Identifier ";"? ;


(* ============================================================ *)
(* Invariants and Indexes                                       *)
(* ============================================================ *)

invariants_block        ::= "invariants" "{"
                              invariant_decl*
                            "}" ;
invariant_decl          ::= Identifier ":" expression ";"? ;

indexes_block           ::= "indexes" "{"
                              index_decl*
                            "}" ;
index_decl              ::= index_kind Identifier "on" index_field_list index_options? ";"? ;
index_kind              ::= "index" | "unique" ;
index_field_list        ::= Identifier ("," Identifier)* ;
index_options           ::= "{"
                              index_option*
                            "}" ;
index_option            ::= "where" ":" expression ";"?
                          | annotations_block ;


(* ============================================================ *)
(* Annotations                                                  *)
(* ============================================================ *)

annotations_block       ::= "annotations" "{"
                              annotation_decl*
                            "}" ;
annotation_decl         ::= Identifier ":" literal ";"? ;


(* ============================================================ *)
(* Events                                                       *)
(* ============================================================ *)

event_decl              ::= "event" Identifier event_block ;
event_block             ::= "{"
                              event_member*
                            "}" ;
event_member            ::= fields_block
                          | field_decl
                          | annotations_block ;


(* ============================================================ *)
(* Queues and Messages                                          *)
(* ============================================================ *)

queue_decl              ::= "queue" Identifier queue_block ;

queue_block             ::= "{"
                              queue_member*
                            "}" ;

queue_member            ::= "namespace" qualified_or_string ";"?
                          | "channel" qualified_or_string ";"?
                          | "visibility_timeout" duration_value ";"?
                          | "max_attempts" IntegerLiteral ";"?
                          | "dead_letter" QualifiedName ";"?
                          | message_decl
                          | annotations_block ;

message_decl            ::= "message" Identifier message_block ;

message_block           ::= "{"
                              message_member*
                            "}" ;

message_member          ::= "idempotency_key" Identifier ";"?
                          | payload_block
                          | annotations_block ;

payload_block           ::= "payload" "{"
                              field_decl*
                            "}" ;


(* ============================================================ *)
(* Leases                                                       *)
(* ============================================================ *)

lease_decl              ::= "lease" Identifier lease_block ;

lease_block             ::= "{"
                              lease_member*
                            "}" ;

lease_member            ::= "resource" expression ";"?
                          | "ttl" duration_value ";"?
                          | "renew_every" duration_value ";"?
                          | "holder" Identifier ";"?
                          | "fencing_token" BooleanLiteral ";"?
                          | "max_ttl" duration_value ";"?
                          | annotations_block ;


(* ============================================================ *)
(* Workers                                                      *)
(* ============================================================ *)

worker_decl             ::= "worker" Identifier worker_block ;

worker_block            ::= "{"
                              worker_member*
                            "}" ;

worker_member           ::= "singleton" BooleanLiteral ";"?
                          | "lease" lease_ref_or_inline ";"?
                          | "polls" QualifiedName ";"?
                          | "executes" QualifiedName ";"?
                          | "concurrency" IntegerLiteral ";"?
                          | annotations_block ;

lease_ref_or_inline     ::= QualifiedName | lease_block ;


(* ============================================================ *)
(* APIs                                                         *)
(* ============================================================ *)

api_server_decl         ::= "api_server" Identifier api_server_block ;

api_server_block        ::= "{"
                              api_server_member*
                            "}" ;

api_server_member       ::= "serves" QualifiedName ";"?
                          | "concurrency" IntegerLiteral ";"?
                          | annotations_block ;

api_decl                ::= "api" Identifier api_block ;

api_block               ::= "{"
                              api_member*
                            "}" ;

api_member              ::= "method" http_method ";"?
                          | "path" StringLiteral ";"?
                          | "input" QualifiedName ";"?
                          | "output" QualifiedName ";"?
                          | "error" QualifiedName ";"?
                          | "authz" authz_expr ";"?
                          | "starts" "workflow" QualifiedName ";"?
                          | "enqueues" QualifiedName ";"?
                          | behavior_block
                          | annotations_block ;

http_method             ::= "GET" | "POST" | "PUT" | "PATCH" | "DELETE" ;

authz_expr              ::= "permission" QualifiedName
                          | QualifiedName
                          | expression ;

behavior_block          ::= "behavior" "{"
                              behavior_stmt*
                            "}" ;

behavior_stmt           ::= require_stmt
                          | allocates_stmt
                          | load_stmt
                          | set_stmt
                          | emits_stmt
                          | enqueue_stmt
                          | acquire_lease_stmt
                          | starts_workflow_stmt
                          | returns_stmt ;

allocates_stmt          ::= "allocates" QualifiedName "as" Identifier ";"? ;
load_stmt               ::= "load" QualifiedName "by" Identifier "=" expression "as" Identifier ";"? ;
returns_stmt            ::= "returns" IntegerLiteral ";"? ;


(* ============================================================ *)
(* Workflows                                                    *)
(* ============================================================ *)

workflow_decl           ::= "workflow" Identifier workflow_block ;

workflow_block          ::= "{"
                              workflow_member*
                            "}" ;

workflow_member         ::= "version" IntegerLiteral ";"?
                          | "singleton" BooleanLiteral ";"?
                          | "expected_execution_time" duration_value ";"?
                          | "start" Identifier ";"?
                          | "on" QualifiedName ";"?
                          | "input" QualifiedName ";"?
                          | "state" QualifiedName ";"?
                          | workflow_load_decl
                          | child_set_block
                          | workflow_step
                          | annotations_block ;

workflow_load_decl      ::= "load" QualifiedName "by" Identifier "as" Identifier ";"? ;

child_set_block         ::= "child_set" Identifier "{"
                              child_set_member*
                            "}" ;

child_set_member        ::= "entity" QualifiedName ";"?
                          | "parent_field" Identifier ";"?
                          | "id_type" type ";"?
                          | "pending" Identifier ";"?
                          | "creating" Identifier ";"?
                          | "succeeded" Identifier ";"?
                          | "failed" Identifier ";"?
                          | "desired_count" expression ";"?
                          | annotations_block ;

workflow_step           ::= "step" Identifier workflow_step_block ;

workflow_step_block     ::= "{"
                              workflow_step_member*
                            "}" ;

workflow_step_member    ::= "expected_execution_time" duration_value ";"?
                          | "max_retries" IntegerLiteral ";"?
                          | workflow_stmt
                          | annotations_block ;

workflow_stmt           ::= require_stmt
                          | set_stmt
                          | atomic_block
                          | for_each_block
                          | when_block
                          | create_child_stmt
                          | observe_child_stmt
                          | move_stmt
                          | emit_stmt
                          | enqueue_stmt
                          | acquire_lease_stmt
                          | renew_lease_stmt
                          | release_lease_stmt
                          | starts_workflow_stmt
                          | transition_to_stmt
                          | complete_stmt
                          | fail_stmt
                          | reserve_child_set_stmt
                          | materialize_child_set_stmt
                          | reconcile_child_set_stmt ;

require_stmt            ::= "require" expression ";"? ;
set_stmt                ::= "set" assignable "=" expression ";"? ;

emit_stmt               ::= "emit" QualifiedName event_payload? ";"? ;
emits_stmt              ::= "emits" QualifiedName event_payload? ";"? ;

enqueue_stmt            ::= "enqueue" QualifiedName event_payload? ";"? ;
starts_workflow_stmt    ::= "start" "workflow" QualifiedName event_payload? ";"? ;

acquire_lease_stmt      ::= "acquire" "lease" QualifiedName ("as" Identifier)? ";"? ;
renew_lease_stmt        ::= "renew" "lease" QualifiedName ";"? ;
release_lease_stmt      ::= "release" "lease" QualifiedName ";"? ;

event_payload           ::= "{"
                              assignment_stmt*
                            "}" ;
assignment_stmt         ::= Identifier "=" expression ";"? ;

atomic_block            ::= "atomic" "{"
                              workflow_stmt*
                            "}" ;

for_each_block          ::= "for_each" Identifier "in" expression "{"
                              workflow_stmt*
                            "}" ;

when_block              ::= "when" expression "{"
                              workflow_stmt*
                            "}" ;

transition_to_stmt      ::= "transition_to" Identifier ";"? ;
complete_stmt           ::= "complete" ";"? ;
fail_stmt               ::= "fail" expression? ";"? ;


(* ============================================================ *)
(* Child Workflow Operations                                    *)
(* ============================================================ *)

create_child_stmt       ::= "create" "child" QualifiedName "{"
                              child_init_stmt*
                            "}" ;

child_init_stmt         ::= "key" Identifier "=" expression ";"?
                          | "parent" Identifier "=" expression ";"?
                          | Identifier "=" expression ";"? ;

observe_child_stmt      ::= "observe" "child" QualifiedName "by" Identifier "=" expression ";"? ;
move_stmt               ::= "move" expression "from" assignable "to" assignable ";"? ;

reserve_child_set_stmt      ::= "reserve" "child_set" Identifier ";"? ;
materialize_child_set_stmt  ::= "materialize" "child_set" Identifier ";"? ;
reconcile_child_set_stmt    ::= "reconcile" "child_set" Identifier ";"? ;


(* ============================================================ *)
(* Policies                                                     *)
(* ============================================================ *)

policy_decl             ::= "policy" Identifier policy_block ;

policy_block            ::= "{"
                              policy_member*
                            "}" ;

policy_member           ::= tenant_scope_decl
                          | allow_decl
                          | deny_decl
                          | quota_decl
                          | audit_decl
                          | annotations_block ;

tenant_scope_decl       ::= "tenant" "scoped_by" Identifier ";"? ;
allow_decl              ::= "allow" QualifiedName "when" expression ";"? ;
deny_decl               ::= "deny" QualifiedName "when" expression ";"? ;
quota_decl              ::= "quota" Identifier ":" expression ";"? ;
audit_decl              ::= "audit" QualifiedName ";"? ;


(* ============================================================ *)
(* Expressions                                                  *)
(* ============================================================ *)

expression              ::= logical_or ;

logical_or              ::= logical_and ("||" logical_and)* ;
logical_and             ::= equality ("&&" equality)* ;
equality                ::= comparison (("==" | "!=") comparison)* ;
comparison              ::= additive (("<" | "<=" | ">" | ">=" | "in") additive)* ;
additive                ::= multiplicative (("+" | "-") multiplicative)* ;
multiplicative          ::= unary (("*" | "/" | "%") unary)* ;

unary                   ::= ("!" | "-") unary
                          | primary ;

primary                 ::= literal
                          | assignable
                          | function_call
                          | "(" expression ")" ;

assignable              ::= QualifiedName selector* ;
selector                ::= "." Identifier | "[" expression "]" ;

function_call           ::= QualifiedName "(" argument_list? ")" ;
argument_list           ::= expression ("," expression)* ;

identifier_list         ::= "[" Identifier ("," Identifier)* "]" ;
qualified_or_string     ::= QualifiedName | StringLiteral ;


(* ============================================================ *)
(* Semantic Built-ins                                           *)
(* ============================================================ *)

(*
  The following names are reserved semantic built-ins. They are parsed
  as normal function calls but validated specially by the compiler.

  Collection and predicate helpers:
    count(list)
    empty(list)
    contains(list, value)
    disjoint(list1, list2, ...)
    exists(value)

  Entity and transition helpers:
    current_state(entity)
    can_transition(entity, target_state)
    changed(field)

  Child orchestration helpers:
    generate_ids(count)
    ordinal_of(childId)
    child_state(childId)
    all_children(child_set, predicate)
    any_child(child_set, predicate)

  Time and lease helpers:
    now()
    duration(value)
    expired(timestamp)

  Feature flag helpers:
    feature_enabled(flag)
    feature_value(flag)
*)


(* ============================================================ *)
(* Semantic Validation Rules                                    *)
(* ============================================================ *)

(*
  The compiler must enforce at least the following rules:

  General:
    1. All referenced identifiers must resolve within scope.
    2. Top-level names must be unique within a system or namespace.
    3. Canonical declaration ordering should be enforced by formatter + validator.
    4. Type names must resolve to scalar, enum, value, shape, entity, or collection types.
    5. Runtime targets must not leak runtime-specific symbols into the canonical model.
    6. Every system must declare tenant scoped_by and system_tenant configured.
    7. Control-plane resources use the configured system tenant id.
    8. Policy tenant scopes must match the system tenant scope.

  Entities:
    9. Every entity must have exactly one key declaration.
   10. Key fields must exist in the entity fields block unless generated by the runtime.
   11. Tenant-scoped entities must include the system tenant field in their key.
   12. Every entity must declare created_at timestamp, updated_at timestamp, and status string.
   13. Every entity must declare a state_machine block.
   14. Entity lifecycle mutations must follow the declared state_machine.
   15. Transition endpoints must be declared states or valid implicit state names.
   16. garbage_collection is valid only on terminal states.
   17. garbage_collection must declare after and mode.
   18. garbage_collection.after must be a supported duration.
   19. garbage_collection.mode must be delete, tombstone, or archive.
   20. Invariants must type-check as boolean expressions.
   21. Index fields must exist on the entity.

  Ownership:
   22. authority: system requires system_of_record: self unless explicitly relaxed later.
   23. authority: external requires system_of_record to name an external system.
   24. lifecycle: managed is valid only for authority: external.
   25. lifecycle: authoritative is valid only for authority: system in v0.1.

  Parent/child relationships:
   26. A parent relation must reference an existing entity.
   27. A child entity may have at most one composition parent in v0.1.
   28. parent_must_be_in entries must exist in the parent state machine.
   29. unique_within_parent fields must exist on the child entity.
   30. on_parent_delete: detach requires an optional parent reference.
   31. composition relationships must not form cycles.
   32. Parent-side children declarations must match child-side parent relations.

  APIs:
   33. API input and output types must resolve.
   34. starts workflow must reference a declared workflow.
   35. enqueues must reference a declared queue message.
   36. allocates/load targets must resolve to entities.
   37. emitted events must resolve.
   38. POST, PUT, and PATCH APIs must declare input.
   39. Non-DELETE APIs must declare output.
   40. Tenant-scoped API paths must include tenant identity.

  Workflows:
   41. Workflow start must target a declared step.
   42. Workflow singleton must be explicit.
   43. Workflow expected_execution_time must be explicit and supported.
   44. Workflow trigger events must resolve when specified.
   45. Workflow load entity must resolve.
   46. Workflow state mutations must follow declared state_machine transitions.
   47. transition_to must target a declared step in the same workflow.
   48. enqueue statements must target declared queue messages.
   49. acquire/renew/release lease statements must target declared leases.
   50. Step expected_execution_time must be explicit and supported.
   51. Step max_retries must be explicit and non-negative.

  Queues:
   52. Queue messages must have payload fields or reference a shape in later versions.
   53. idempotency_key must refer to a payload field or generated message metadata.
   54. dead_letter must reference a queue or queue message according to target policy.
   55. visibility_timeout must be explicit and supported.
   56. max_attempts must be explicit and positive.

  Leases:
   57. Lease ttl, renew_every, and max_ttl must be explicit and supported durations.
   58. renew_every must be less than ttl.
   59. ttl must be less than or equal to max_ttl.
   60. holder must be explicit and resolve to worker identity, caller identity, or generated context.
   61. fencing_token must be explicit; true requires the selected runtime to support fencing tokens.

  Workers:
   62. singleton true requires either an inline lease or resolvable lease binding.
   63. polls must reference a queue or queue message.
   64. executes must reference a workflow or workflow step.

  Policies:
   65. Policy subjects and actions must resolve to APIs, workflows, queues, leases, or workers.
   66. Policy expressions must type-check as boolean expressions.
   67. Policies must declare tenant scoped_by matching the system tenant scope.
   68. Policies must include at least one allow, deny, quota, or audit declaration.
   69. Tenant scoped fields must exist on the relevant entity, payload, or request shape.

  Child sets:
   70. child_set.entity must refer to a valid child entity.
   71. The child entity must have a parent relation to the workflow's loaded parent entity.
   72. child_set.parent_field must match the child's parent relation field.
   73. pending, creating, succeeded, and failed fields must exist on the parent entity.
   74. Child bucket fields must all be list<id_type>.
   75. desired_count must type-check as an integer.
   76. Child buckets must be disjoint.
   77. Child bucket union must represent the reserved child set.

  Feature flags:
   67. Feature flag names must be unique within a system or namespace.
   68. Feature flag names must use PascalCase.
   69. Feature flags must declare type and default.
   70. Feature flag defaults must match the declared feature flag type.
   71. scope entity must reference an existing entity.
   72. feature_enabled(flag) requires a declared bool feature flag.
   73. feature_value(flag) requires a declared feature flag.

*)
