statespec 0.1;

system IncludedBindings {
  tenant scoped_by tenant_id
  system_tenant configured

  entity IncludedEntity {
    key tenant_id, included_id
    ownership {
      authority: system
      system_of_record: self
      lifecycle: authoritative
    }
    fields {
      created_at timestamp
      updated_at timestamp
      status string
      tenant_id string
      included_id string
    }
    state_machine {
      state Active
      initial Active
    }
  }

  queue IncludedQueue {
    namespace included_ns
    channel included
    visibility_timeout PT30S
    max_attempts 3
    message IncludedMessage {
      idempotency_key message_id
      payload {
        message_id string
        tenant_id string
        included_id string
      }
    }
  }

  workflow IncludedWorkflow {
    version 1
    singleton false
    expected_execution_time PT30S
    start included_step
    step included_step {
      expected_execution_time PT10S
      max_retries 1
    }
  }
}
